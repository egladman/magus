// render.buzz - the docs SSG composition root. magusfile.buzz imports it and calls the
// exported entry points: site_render() (sets the input paths on Site and runs the whole
// render) and updateUrlLock(). The rendering machinery lives across the engine/ and site/
// modules flat-imported below; this file wires them and holds the Site-coupled steps that
// must sit at the root. A flat sibling of magusfile.buzz, resolvable via buzz's
// project-relative import search paths.
namespace render;

import "markdown";
import "fs";
import "io";
import "os";
import "std";
import "serialize";
import "encoding";
import "time";
import "template";
import "crypto";
import "assert";
import "yaml";
// Text/path/URL helpers. Flat import (`as _`) merges a module's exports into this scope,
// so callers name them unqualified (escapeAttr, relativePath, ...); same for the imports
// below.
import "lib/text" as _;
// Source-path -> clean-URL mapping (directory-index scheme, blog date scoping):
// cleanURL/cleanDepth/blogURLPath.
import "lib/url" as _;
// Sitemap/Atom XML serialization + Atom date normalization: escapeXml/xmlElement/atomDate.
import "lib/feed" as _;
// Date formatting (bylines, feed dates, recent-changes stamps): formatISO/blogDate/...
import "lib/date" as _;
// Directory-index link rewriting (resolve, old->new URL map, re-relativize):
// rewriteHref/resolvePath/cleanTarget.
import "lib/html" as _;
import "lib/glossary" as _;
import "lib/conventions" as _;
// Content-Security-Policy construction + the content hashing under it:
// computeCSP/scriptHash/fileSha256/cspForRedirectStub and the CSP_* constants.
import "lib/csp" as _;
// Per-page facts read from a page's Markdown (title, tags, page_type, reading time,
// fallback description, since-badge): deriveTitle/parseTags/pageType/readingTime/
// deriveDescription/insertSinceBadge.
import "engine/meta" as _;
// Pure release-data transforms (semver ordering, artifact descriptions, release.json
// encoding): semverSortKey/sortNamesSemverDesc/artifactDesc/jsonStr/jsonStrList. The
// Site-coupled loaders/writers stay below.
import "site/release" as _;
// Filesystem/walk predicates (isDirectory + the docs-root generator-file/dir skips); a
// leaf shared with engine/types.buzz.
import "engine/path" as _;
// The Site data model + record types (the walk's build state); shared with every writer
// module so they take a `site: Site` without a cycle back to this file.
import "engine/types" as _;
// Path/URL routing helpers (clean URLs, ../ depth, deploy base path).
import "engine/route" as _;
// The persistent site chrome (nav/footer/panels/announcement/TOC) built as fragments.
import "engine/nav" as _;
// Build-correctness + provenance layer (integrity/orphan/abandoned gates, git metadata,
// output pruning, the URL ledger); free functions over a Site.
import "engine/gates" as _;
import "engine/feeds" as _;
import "engine/discovery" as _;
import "engine/pwa" as _;
import "engine/page" as _;
import "site/public" as _;
import "engine/blog" as _;
import "engine/search" as _;
import "site/tour" as _;
import "site/development" as _;
// The concrete site configuration (base URL, title, nav, generated-tree names) - the only
// site/-specific value the composition root injects so the engine stays generic.
import "site/config" as _;

// Pico CSS is vendored at assets/pico.min.css (copied to gen/assets/ each generate).
// Same-origin, never fetched remotely. Version: @picocss/pico@2.1.1. SRI provenance
// (for reference; unused with a same-origin link):
//   sha384-L1dWfspMTHU/ApYnFiMz2QID/PlP1xCW9visvBdbEkOLkSSWsP6ZJWhPw6apiXxU
// To upgrade: drop the new pico.min.css into assets/ (not gen/assets/), bump the version
// above, recompute the SRI only if reverting to CDN delivery, and regenerate.




// walkBlog visits every blog/*.md post (skipping index.md and _underscored fixtures) in
// fs.list's sorted order, so the walk is deterministic. Posts are flat: no nested subdirs
// under blog/.
fun walkBlog(site: Site) > void {
    if (isDirectory(site.root + "/" + site.blog) == false) { return; }
    foreach (name in fs\list(site.root + "/" + site.blog)) {
        if (name.endsWith(".md") and name != "index.md" and name.startsWith("_") == false) {
            renderBlogPost(name, site);
        }
    }
    renderBlogIndex(site);
}

// Recursively walk docs/ (the render reads its co-located markdown; the SSG's own
// root children - gen/, src/, tour/, node_modules/, MAGUS.md - are skipped at the root).
fun walk(rel: str, site: Site) > void {
    var dir = site.root + "/" + site.docs;
    if (rel != "") { dir = site.root + "/" + site.docs + "/" + rel; }

    foreach (name in fs\list(dir)) {
        var childRel = name;
        if (rel != "") { childRel = rel + "/" + name; }

        if (isDirectory(site.root + "/" + site.docs + "/" + childRel)) {
            if (rel == "" and isGeneratorDir(name, site.config.generatorDirs)) { continue; }
            walk(childRel, site);
        } else {
            if (name.endsWith(".md") and (rel != "" or isGeneratorFile(name, site.config.generatorFiles) == false)) {
                // glossary.md renders AFTER the walk (in site_render), once glossaryRefs is
                // complete, so its per-term "referenced on" backlinks are the full set.
                if (childRel == "glossary.md") { continue; }
                renderFile(childRel, site);
            }
        }
    }
}




// site_render rebuilds gen/ from ../docs and the root README. Pure function of git
// history (footers) and the source tree - reproducible and gate-stable.
export fun site_render(root: str, docs: str, blog: str, outDir: str) > Site {
    // Generator state for one render pass, threaded explicitly into every renderer as a
    // `site` arg - no module-global singleton, so parallel renders never share state.
    // (outDir, not out: `out` is a reserved word in buzz.)
    var site: Site = mut Site{};
    site.config = magusConfig();
    site.root = root;
    site.docs = docs;
    site.blog = blog;
    site.outDir = outDir;
    loadMeta(site);
    site.searchRecords = mut [];
    site.aliasTarget = mut {};
    site.pageUrls = mut {};
    site.writtenPaths = mut {};
    site.docPages = mut [<DocPage>];
    site.glossaryTerms = mut [<GlossaryTerm>];
    site.glossaryRefs = mut {};
    site.pageTerms = mut {};
    site.codeEntities = mut [<Entity>];
    site.demoBySlug = mut {};
    site.blogPosts = mut [<BlogPost>];
    site.hasBlogPosts = false;
    if (isDirectory(site.root + "/" + site.blog)) {
        foreach (name in fs\list(site.root + "/" + site.blog)) {
            if (name.endsWith(".md") and name != "index.md" and name.startsWith("_") == false) {
                site.hasBlogPosts = true;
            }
        }
    }
    // Computed once so every page threads a stable string instead of recomputing per
    // page. See Site.csp/Site.cspHome and computeCSP for which pages get which.
    site.csp = computeCSP(CSP_IMG_SRC_DEFAULT);
    site.cspHome = computeCSP(CSP_IMG_SRC_HOME);
    // gen/ is NOT wiped and rebuilt: outDir is created if missing, every render below
    // overwrites in place, and pruneStaleOutputs() (near the end, once every write is
    // known) deletes only the leftovers whose source is gone - a renamed page, a deleted
    // post, a dropped alias, a release out of CHANGELOG.md. Committed-but-not-rendered
    // artifacts (the playground WASM/editor bundle) persist untouched, since nothing here
    // writes or deletes them.
    fs\makeDirectory(site.outDir);
    std\print("generating site from " + site.root + "/" + site.docs + "/ -> " + site.outDir + "/");

    // Copy static assets the root README references (images, badges). Scoped delete-
    // then-recopy: cp -r alone wouldn't drop a since-deleted source image, so the copied
    // files are cleared first. Preserve the committed esbuild outputs (mermaid.js,
    // hljs.js) - they live in gen/assets, not site.root/assets, so a blind wipe would
    // delete them on `serve` (which re-renders without rebuilding bundles); generate
    // rebuilds them afterward anyway.
    os\execute(["sh", "-c", "mkdir -p " + site.outDir + "/assets && find " + site.outDir + "/assets -mindepth 1 -maxdepth 1 ! -name mermaid.js ! -name hljs.js -exec rm -rf \{\} +"]);
    os\execute(["sh", "-c", "[ -d " + site.root + "/assets ] && cp -r " + site.root + "/assets/. " + site.outDir + "/assets/ || true"]);

    // Bundle + minify the client assets with esbuild (pinned in mise.toml). Two outputs:
    // theme.js (head-critical, no imports so no bundle) and main.js (the deferred bundle
    // of every feature module). mermaid is a lazy dynamic import() of the same-origin
    // gen/assets/mermaid.js bundle (built by build-mermaid); esbuild leaves dynamic
    // imports external. CSS is minified per-file, not bundled. Pinned esbuild ->
    // byte-stable output, so the drift gate holds.
    os\execute(["sh", "-c", "esbuild src/styles/site.css --minify --outfile=" + site.outDir + "/site.css"]);
    // console.css: the console-app-only shell (app bar, launcher, status bar, full-height
    // layout), loaded by /dashboard/, /logs/, /graph/ and the playground status bar but NOT
    // the docs corpus. Minified to gen root, enumerated in the precache/allowlist next to
    // site.css.
    os\execute(["sh", "-c", "esbuild src/styles/console.css --minify --outfile=" + site.outDir + "/console.css"]);
    // ui-panels.css: the shared nav-triggered UI panels (settings gear dropdown + reference
    // drawer) used by BOTH docs pages and console apps. Separate from console.css so the docs
    // corpus can load only this. Gen-root, precached like the others.
    os\execute(["sh", "-c", "esbuild src/styles/ui-panels.css --minify --outfile=" + site.outDir + "/ui-panels.css"]);
    os\execute(["sh", "-c", "esbuild src/styles/theme.css --minify --outfile=" + site.outDir + "/theme.css"]);
    // The console surfaces (graph/logs/dashboard/activity) live in the standalone console/
    // project (its own build, deployed to /console/); the docs site renders none of them.
    os\execute(["sh", "-c", "esbuild src/theme.ts --minify --outfile=" + site.outDir + "/theme.js"]);
    os\execute(["sh", "-c", "esbuild src/site/main.ts --bundle --minify --format=esm --outfile=" + site.outDir + "/main.js"]);

    // buzz.wasm, wasm_exec.js, and editor.js are committed in gen/playground/ - rebuilt in
    // place by build-playground / build-playground-editor, never by this render - so
    // renderPlayground (below) only adds index.html alongside them. pruneStaleOutputs()
    // leaves these three paths alone (its alwaysKeep set).
    // Gather every docs page's relatedness metadata BEFORE any page renders, so each page's
    // "Related" cards resolve titles/URLs against the full corpus. collectDocPages reads only
    // frontmatter, so it is free of the render state below.
    site.collectDocPages("");
    // Parse the glossary vocabulary before the walk so every page can auto-link its terms.
    site.collectGlossaryTerms();
    site.collectConventions();
    // Record which glossary terms each page mentions (native, fast) so renderRelated can rank
    // neighbors by shared vocabulary. Needs docPages + glossaryTerms.
    site.collectPageTerms();
    // Catalog inline-code entities (diagnostic codes + CLI commands) for auto-linking.
    site.collectEntities();
    // Map each concept to the tour step that demos it, for the "see the demo" callout.
    collectDemos(site);

    renderPlayground(site);

    // Load release manifests from releases/*.yaml BEFORE the walk so renderPage() knows
    // whether the releases Atom feed exists and can gate its <link rel=alternate> discovery
    // tag (advertising a missing feed would trip the asset check). Changelog parsing runs
    // only at release-cut time (cmd/magus-utils cut), not here.
    loadReleases(site);

    renderRoot(site);
    walk("", site);
    // glossary.md last: it aggregates the cross-references collected across the whole walk
    // into per-term backlinks (renderFile injects them for this page).
    renderFile("glossary.md", site);
    walkBlog(site);

    // Build /development/ before writeAliases so its pages are in site.pageUrls for the
    // collision guard, and its collectAlias redirects (retired /development/projects/ URLs)
    // get stubs in the same pass.
    renderDevelopment(site);

    // Emit a redirect stub per frontmatter alias (after the walk, so every real page URL is
    // known for the collision guard). Aliases stay out of the search index/sitemap/feeds -
    // only their target page appears. docs/reference/console.md aliases the old /console/ URL,
    // so a stub lands at gen/console/index.html, keeping internal links to /console/ resolving
    // for the asset gate. The console SPA is a separate project copied over gen/console/ at
    // deploy (.github/workflows/pages.yaml), so the app wins there.
    site.writeAliases();

    writeSEOFiles(site);
    renderBlogAtom(site);
    renderReleasesAtom(site);
    renderPublic(site);
    render404(site);
    writeOffline(site);
    renderSearchPage(site);
    renderTourPage(site);
    writeManifest(site);

    // llms.txt: the index an AI agent reads to discover pages and fetch each one's Markdown
    // at <url>index.md. A post-walk aggregate over the corpus, like search-index.json below.
    writeLLMsIndex(site);

    // Flat {url, title, text, tags, description?} record per page; search.js fetches it
    // lazily on first focus. serialize sorts keys and the walk order is fs.list's (sorted),
    // so the file is byte-stable across runs.
    fs\writeFile(site.outDir + "/search-index.json", "[" + site.searchRecords.join(",") + "]");

    // Built last: the cache version digests the precached assets (incl. search-index.json
    // just above), so every one of them must already exist.
    buildServiceWorker(site);

    // Delete anything on disk from a previous render whose source is gone (see
    // pruneStaleOutputs' doc). Runs before the gates below so neither trips on a stale
    // page's dangling reference to content removed with it.
    pruneStaleOutputs(site);

    // writeSiteManifest is NOT called here: generate() (magusfile.buzz) still writes
    // gen/assets/mermaid.js and hljs.js - both served assets - AFTER site_render returns,
    // so computing the manifest here would miss them. generate() calls
    // render.writeSiteManifest(site) once every write to gen/ is done.

    // Reproducibility guard: throw on any dangling href/src. Runs after every asset + page
    // is written, so a missing file (renamed bundle, deleted image, forgotten alias) fails
    // the build here instead of shipping a 404. See docs/engines.md.
    assetIntegrityCheck(site);

    // Orphan gate: prove each docs page is reachable by clicking from the front door. Runs
    // after assetIntegrityCheck so link targets are already known-good.
    orphanCheck(site);

    // Parity gate: no previously-shipped URL may silently start 404-ing.
    abandonedLinkCheck(site);

    std\print("done");
    // Hand the populated state back; the caller threads it into updateUrlLock (no
    // module-global carries it between the two calls).
    return site;
}
