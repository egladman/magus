import "lib/date" as _;
// Directory-index link rewriting (resolve, old->new URL map, re-relativize), split
// into its own unit-tested module and flat-imported so rewriteHref/resolvePath/
// cleanTarget resolve unqualified at their call sites here.
import "lib/html" as _;
// Content-Security-Policy construction and the content hashing under it, split into
// its own unit-tested module and flat-imported so computeCSP/scriptHash/fileSha256/
// cspForRedirectStub and the CSP_* constants resolve here unqualified.
import "lib/csp" as _;
// Per-page facts read from a source page's Markdown (title, tags, page_type,
// reading time, fallback description, since-badge), flat-imported so deriveTitle/
// parseTags/pageType/readingTime/deriveDescription/insertSinceBadge resolve here.
import "engine/meta" as _;
// Pure release-data transforms (semver ordering, artifact descriptions, release.json
// string encoding), flat-imported so semverSortKey/sortNamesSemverDesc/artifactDesc/
// jsonStr/jsonStrList resolve here; the Site-coupled loaders/writers stay below.
import "site/release" as _;
// Filesystem/walk predicates (isDirectory + the docs-root generator-file/dir skips),
// a leaf module shared with render_types.buzz so the content walks resolve them here.
import "engine/path" as _;
// The Site data model + record types (the walk's build state), shared with every
