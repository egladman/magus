// A magusfile: the build definition magus reads. This one models a single
// project (a service with a protobuf API, a Go server, and a TypeScript client,
// built as one unit) and wires the conventional pipeline: preflight, generate,
// format, lint, build, test, a ci anchor, and a release image.
//
// A larger workspace gives EACH project its own magusfile in its own directory
// and wires cross-project order with depends_on; magus discovers them and fans a
// target out across every project that declares it. This single-buffer example
// instead binds several toolchains to ONE project (the co-binding pattern) so it
// is runnable here. See the docs on projects/workspaces for the multi-file setup.

import "magus";                 // project registration, targets, dependency edges
import "magus/spell/buf";       // protobuf toolchain: buf-generate, buf-lint, buf-format
import "magus/spell/go";        // Go toolchain: go-build, go-test, go-vet, go-fmt, ...
import "magus/spell/ts";        // TypeScript toolchain: tsc, eslint, prettier, vitest
import "magus/spell/docker";    // container image: docker-build, hadolint

final VERSION: str = "1.4.0";
final IMAGE: str = "ghcr.io/example/api";

// eslint is CPU- and memory-hungry, so we size it once as an N-core job and feed
// that number to BOTH levers below: magus reserves this many scheduler slots for
// the js-lint target (the `slots` policy), and eslint is told to use this many
// worker threads (--concurrency). Reserving slots without telling the tool to use
// them wastes the reservation; telling the tool to use more than we reserved
// oversubscribes the machine. Keeping them equal makes the two agree. slots is a
// per-target policy (a target is the unit the scheduler acquires slots for), so
// eslint runs in its own js-lint target rather than riding the broader lint stage.
final LINT_SLOTS: int = 4;

// One project binding every toolchain it uses; the targets below compose ops
// across all of them. Per-target policy: the js-lint target holds LINT_SLOTS
// scheduler slots (eslint is the heavy one); release runs alone (exclusive).
// Everything else relies on the cache by default (magus keys each target on its
// declared inputs and replays outputs when they are unchanged), which is the whole
// point, so we do NOT opt targets out of it here.
magus.project({
    "spells": [buf, go, ts, docker],
    "outputs": ["gen/**", "bin/**"],
    "targets": {
        "js-lint": {"slots": LINT_SLOTS},
        "release": {"exclusive": true},
    },
});

// A plain Buzz helper that assembles the -ldflags stamping the version into the
// server binary (used by build below). Try `ldflags(VERSION)` in the console to
// see Buzz evaluate it; the interpreter is real, only the build tools are stubbed.
fun ldflags(version: str) > str {
    return "-s -w -X main.version=" + version;
}

// Each exported function is a runnable target. Its name is normalized to
// kebab-case, so casing and separators do not matter: image_build, imageBuild,
// and IMAGE_BUILD all define (and run) the target image-build. `magus run
// imageBuild` and `magus run image-build` are the same command; try `run
// mockGenerate` in the console below. Dependencies are declared with
// magus.needs(magus.target.literal("name")): needs takes a magus.target.* query
// wrapping a string literal (not a bare string or the function itself), so magus
// can recover the whole DAG statically, without running the file. magus runs the
// dependencies first, deduplicated, and in parallel wherever the graph allows.
//
// A spell's ops are its contributed targets, keyed by the kebab-case CLI name
// (go-build, buf-lint). Call one by indexing the handle with that name, the same
// name `magus run go-build` and the cache use.

// Gate the pipeline on a healthy workspace before anything builds.
export fun preflight(args: [str]) > void {}

// Codegen is one `*-generate` target per generator. Each is ordinary cached
// codegen: magus keys it on its inputs and its gen/** outputs, so it reruns only
// when those inputs change. (Contrast with a drift-gate target that verifies
// committed output is current on every run; that one would set skip_cache because
// its point is the check, not a cacheable artifact.)
export fun proto_generate(args: [str]) > void { buf["buf-generate"](); }
export fun mock_generate(args: [str])  > void { go["go-generate"](); }

// The umbrella `generate` target pulls in every `*-generate` target with ONE glob
// instead of listing each by hand: magus.target.glob("*-generate") matches every
// target ending in -generate, so adding a `sql-generate` later needs no edit here.
// (For arbitrary patterns there is also magus.target.regex(...).) That is the
// payoff of naming targets by a shared convention. Try `run generate` to fan out.
export fun generate(args: [str]) > void {
    magus.needs(magus.target.literal("preflight"), magus.target.glob("*-generate"));
}

// Format every language. These ops CHECK by default; run `magus run format:rw`
// to APPLY the fixes: the rw charm flips gofmt -l to -w, prettier --check to
// --write, buf format to -w. The charm rides down from the run, so no branch is
// needed here. (Try `run format` then `run format:rw` in the console to compare.)
export fun format(args: [str]) > void {
    magus.needs(magus.target.literal("generate"));
    buf["buf-format"]();
    go["go-fmt"]();
    ts["prettier"]();
}

// Linting is a `*-lint` set too, one target per toolchain, so `lint` can glob
// them the same way `generate` globs its generators. js-lint is split out on its
// own because it carries the load: eslint is the heavy one, so this target holds
// LINT_SLOTS slots and runs eslint with a matching --concurrency (the cheap buf/go
// checks stay at the default of 1 slot). `magus run lint:rw` applies the
// auto-fixable findings where a tool supports it (e.g. golangci-lint --fix).
export fun proto_lint(args: [str]) > void {
    magus.needs(magus.target.literal("format"));
    buf["buf-lint"]();
}
export fun go_lint(args: [str]) > void {
    magus.needs(magus.target.literal("format"));
    go["go-vet"]();
    go["golangci-lint"]();
}
export fun js_lint(args: [str]) > void {
    magus.needs(magus.target.literal("format"));
    ts["eslint"]({"args": ["--concurrency=" + LINT_SLOTS]});
}

// The umbrella `lint` fans out across the whole family with one glob.
export fun lint(args: [str]) > void {
    magus.needs(magus.target.glob("*-lint"));
}

// Compile the version-stamped server binary and type-check the client.
export fun build(args: [str]) > void {
    magus.needs(magus.target.literal("format"));
    go["go-build"]({"args": ["-ldflags", ldflags(VERSION), "-o", "bin/api", "./cmd/api"]});
    ts["tsc"]();
}

// Run both suites.
export fun test(args: [str]) > void {
    magus.needs(magus.target.literal("format"));
    go["go-test"]();
    ts["vitest"]();
}

// The conventional anchor `magus affected ci` keys off. It declares no work of
// its own; it fans out to lint, build, and test, which share the format ->
// generate -> preflight spine and each run once. Try `run ci` to see the plan.
export fun ci(args: [str]) > void {
    magus.needs(magus.target.literal("lint"), magus.target.literal("build"), magus.target.literal("test"));
}

// Build the container image from the compiled binary. Default: a single-arch
// image loaded into the local daemon. Under the `cd` charm: a multi-arch image
// pushed to the registry. Kept as its own target so `magus run image-build`
// works standalone.
export fun image_build(args: [str]) > void {
    magus.needs(magus.target.literal("build"));
    final tag = IMAGE + ":" + VERSION;
    if (magus.has_charm("cd")) {
        docker["docker-build"]({"args": ["--platform", "linux/amd64,linux/arm64", "--push", "-t", tag, "."]});
    } else {
        docker["docker-build"]({"args": ["--load", "-t", tag, "."]});
    }
}

// Ship a release: a needs() edge onto image-build, so it shows up in `graph`/`ls`
// as part of the DAG. Charms ride down needs() edges from the run, so `magus run
// release:cd` flows the cd charm into image-build and it switches to a multi-arch
// push. (magus.run(["image-build:cd"]) would instead invoke it imperatively with
// the charm pinned in the call, but an imperative call is not a static edge, so it
// would not appear in the graph. Both are valid; needs keeps the DAG complete.)
export fun release(args: [str]) > void {
    magus.needs(magus.target.literal("image-build"));
}
