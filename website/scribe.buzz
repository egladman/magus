// scribe.buzz - the static site generator ("scribe") for the magus docs site.
//
// All the rendering machinery lives here as a self-contained library: the page
// template, shared nav/footer, per-page renderers, the /public/ autoindex tree, the
// sitemap and Atom feeds, the search index, and the build-time gates (asset
// integrity, reachability, abandoned-link). magusfile.buzz imports this module and
// its targets call the exported entry points - site_render() (which sets the input
// paths on the Site object) and updateUrlLock(). Split out of
// magusfile.buzz so the generator is its own module (a flat sibling, resolvable
// since magus adopted buzz's project-relative import search paths).
import "markdown";
import "fs";
import "io";
import "os";
import "std";
import "serialize";
import "encoding";
import "time";
import "template";
import "crypto";
import "assert";
import "yaml";
// Pure text, path, and URL helpers, split into their own unit-tested module. Flat
// import (`as _`) merges its exported functions into this scope, so callers here
// name them directly (escapeAttr, relativePath, ...) as before the extraction.
import "scribe_text" as _;
// Source-path -> clean-URL mapping (the directory-index scheme and blog date
// scoping), likewise split into its own unit-tested module and flat-imported so
// cleanURL/cleanDepth/blogURLPath resolve here unqualified.
import "scribe_url" as _;
// Sitemap/Atom XML serialization and Atom date normalization, split into their own
// unit-tested module and flat-imported so escapeXml/xmlElement/atomDate resolve here
// unqualified at their many feed-building call sites.
import "scribe_feed" as _;
// Date formatting (bylines, feed dates, recent-changes stamps), split into its own
// unit-tested module and flat-imported so formatISO/blogDate/... resolve unqualified.
import "scribe_date" as _;
// Directory-index link rewriting (resolve, old->new URL map, re-relativize), split
// into its own unit-tested module and flat-imported so rewriteHref/resolvePath/
// cleanTarget resolve unqualified at their call sites here.
import "scribe_html" as _;

// Path config, set by site_render() from the arguments the magusfile passes in - the
// generator does not hardcode where the workspace, docs, or output live, so it stays
// a config-agnostic library rather than owning project layout the caller reaches into.
// Pico CSS is vendored at assets/pico.min.css (copied to gen/assets/ on each generate).
// Same-origin; served from this site, never fetched remotely. Version: @picocss/pico@2.1.1.
// SRI provenance (for reference, not used with same-origin link):
//   sha384-L1dWfspMTHU/ApYnFiMz2QID/PlP1xCW9visvBdbEkOLkSSWsP6ZJWhPw6apiXxU
// To upgrade: download the new pico.min.css into assets/ (not gen/assets/), update the
// version comment, recompute the SRI if ever reverting to CDN delivery, and regenerate.
final GH   = "https://github.com/egladman/magus";

// SITE_URL is the site's public base (with trailing slash), used for the canonical
// link, sitemap, and (later) the Atom feeds. Set non-empty to enable them; leave ""
// to ship those surfaces dark until the host is confirmed. SITE_DESC is the
// belt-and-suspenders page description when a page has neither a frontmatter
// description nor a derivable first paragraph.
final SITE_URL  = "https://eli.gladman.cc/magus/";
final SITE_DESC = "magus is a fast, cross-platform task orchestrator for polyglot (mono)repos. Single binary, code as configuration, statically typed.";


// Value objects. They must precede Site, which holds arrays of them - Buzz has no
// forward references to types.

// BlogPost is one blog entry's index record, built by renderBlogPost() as the walk
// visits each post; the blog index, the Atom feed, and the prev/next pager consume
// it. base is the source filename (sort tiebreak + commit key); urlPath is the
// date-scoped clean path (YYYY/MM/DD/slug).
object BlogPost {
    base: str = "",
    slug: str = "",
    urlPath: str = "",
    title: str = "",
    date: str = "",
    description: str = "",
    url: str = "",
}

// DocPage is one docs page's relatedness metadata. tags is ||-joined (split back out
// by sharedTagCount); overview is true for a landing/index page (page_type: overview).
// renderRelated() scores these to fill each page's "Related" cards, and
// renderBreadcrumb() looks one up by url for its title.
object DocPage {
    url: str = "",
    title: str = "",
    desc: str = "",
    tags: str = "",
    section: str = "",
    overview: bool = false,
    srcRel: str = "",
}

// Release is one release entry read from releases/v<semver>.yaml. The body field
// holds the trimmed markdown for the Atom feed; artifacts is the list of release
// assets with their integrity data (name, platform, size, sha256).
// notes* fields carry the Keep-a-Changelog sections as structured string lists;
// yanked marks a release that should not be used (security issue, etc.).
// These fields mirror the Go ReleaseManifest struct (cmd/magus-utils/release.go)
// so the index.json schema is a proper frozen v1.
object Release {
    version: str = "",
    date: str = "",
    body: str = "",
    notesAdded: [str] = mut [<str>],
    notesChanged: [str] = mut [<str>],
    notesFixed: [str] = mut [<str>],
    notesRemoved: [str] = mut [<str>],
    yanked: bool = false,
    // artifacts holds the release assets. Each entry has: name, platform, size, sha256.
    // size and sha256 may be "" for historical releases migrated without artifact data.
    artifacts: [{str: str}] = mut [<{str: str}>],
}

// Site holds ALL the generator's state on one object instead of a scatter of module
// globals: the input paths (set once by site_render), the per-page commit metadata,
// the search-index records, the URL-alias / written-URL bookkeeping, and the
// blog/doc/release collections. A single module-global instance (`site`) carries it;
// the walk-scoped parts are reset per site_render().
object Site {
    // Input paths, set once by site_render(). root is the magus/ workspace dir
    // (relative to this project); docs and blog are source subtrees under root; out
    // is the generated site output under this project.
    root: str = "",
    docs: str = "",
    blog: str = "",
    outDir: str = "",

    // Per-page commit metadata, loaded lazily by loadMeta() at render time (NOT at
    // magusfile load - these shell out to git, and a magusfile is parsed on every
    // `magus ls`). metaHistory maps a repo-relative path to the last N commits that
    // touched it ("full|short|stamp|subject" each), from one git-log pass.
    metaPrefix: str = "",
    metaBranch: str = "",
    metaFull: str = "",
    metaShort: str = "",
    metaStamp: str = "",
    metaCommits: {str: str} = mut {},
    metaHistory: {str: [str]} = mut {},
    metaLoaded: bool = false,

    // One JSON-encoded search record per rendered page, joined into
    // gen/search-index.json at the end of a render, in the sorted walk order so the
    // index is deterministic and the drift gate stays stable.
    searchRecords: [str] = mut [<str>],

    // URL-alias bookkeeping. aliasTarget maps a declared old path (frontmatter
    // aliases:) to the clean URL of the page that owns it; pageUrls is the set of
    // real written page URLs. Both feed the alias pass after the walk, which writes a
    // redirect stub per alias and throws on a collision.
    aliasTarget: {str: str} = mut {},
    pageUrls: {str: bool} = mut {},

    // Every gen-root-relative file this render pass actually wrote, populated at the
    // handful of choke points that own an output write (addRecord, writeAliases,
    // renderAutoindex; a couple of one-off index.md siblings track themselves
    // directly). pruneStaleOutputs() diffs this against what's really on disk after
    // the render completes and deletes anything left over from a previous run whose
    // source (a docs page, a blog post, an alias, a release) is gone - so a rename or
    // deletion cleans up its old gen/ output without needing to nuke and rebuild the
    // entire tree on every run.
    writtenPaths: {str: bool} = mut {},

    // Blog posts (consumed by the blog index, Atom feed, and pager). hasBlogPosts is
    // precomputed before the walk so an early page (README) can decide whether to
    // advertise the blog Atom feed in <head>.
    blogPosts: [BlogPost] = mut [<BlogPost>],
    hasBlogPosts: bool = false,

    // Docs relatedness corpus, built pre-walk by collectDocPages so each page can
    // pick its Related neighbors.
    docPages: [DocPage] = mut [<DocPage>],

    // Releases loaded from releases/*.yaml, for the Atom feed, announcement bar,
    // and /public/release/ artifact listing. Ordered newest-first (by file sort,
    // which matches semver descending for vX.Y.Z names).
    releases: [Release] = mut [<Release>],

    // The default Content-Security-Policy meta content, computed once by
    // computeCSP() at the top of site_render() and threaded verbatim into every
    // page's head EXCEPT the home page (renderPage's pageTmpl for every non-home
    // page, render404, writeOffline, and the hand-authored playground.html/
    // graph.html - none of them embed the README's status badges, so none of them
    // need img-src widened past same-origin). A build-once value rather than a
    // per-page recomputation.
    csp: str = "",

    // The home-page-only Content-Security-Policy: identical to csp except its
    // img-src also allows the two hosts the README's status badges load from (see
    // computeCSP's doc comment). Only renderPage() reaches for this, and only when
    // rendering README.md - every other page keeps the tighter default so an
    // img-src GET (a channel connect-src cannot restrict) is not left open on
    // pages that hold the reader's own dependency graph or source code.
    cspHome: str = "",

    // --- Methods that manage this state (pure helpers stay free functions below) ---

    // addRecord appends one page's search-index record and marks its URL as written
    // (so the alias pass can catch a redirect that shadows a real page). Called once
    // per rendered page. Also records the page's index.html in writtenPaths (root's
    // url is the bare "index.html" filename, every other url ends in "/") so
    // pruneStaleOutputs knows this page is current.
    fun addRecord(url: str, title: str, desc: str, md: str) > void {
        this.pageUrls[url] = true;
        var filePath = url;
        if (filePath.endsWith("/")) { filePath = filePath + "index.html"; }
        this.writtenPaths[filePath] = true;
        final rec = mut {<str: any>};
        rec["url"] = url;
        rec["title"] = title;
        rec["text"] = cleanBody(markdown.stripFrontmatter(md));
        rec["tags"] = parseTags(md);
        if (desc != "") { rec["description"] = desc; }
        this.searchRecords.append(serialize.jsonEncode(serialize.Boxed.init(rec)));
    }

    // collectAlias records that the clean old path `alias` should redirect to
    // `target`. It throws if two pages claim the same alias, so a rename can never
    // silently shadow another page's redirect. Leading/trailing slashes normalize away.
    fun collectAlias(alias: str, target: str) > void {
        var a = alias;
        while (a.startsWith("/")) { a = a.sub(1); }
        while (a.endsWith("/")) { a = a.sub(0, a.len() - 1); }
        if (a == "") { return; }
        final owner = this.aliasTarget[a];
        if (owner != null and owner != target) {
            throw "alias \"" + a + "\" is claimed by two pages (" + owner + " and " + target + ")";
        }
        this.aliasTarget[a] = target;
    }

    // writeAliases writes one redirect stub per collected alias (after the walk, so
    // every real page URL is known for the collision guard). It throws if an alias
    // would shadow a real generated page.
    fun writeAliases() > void {
        foreach (a in this.aliasTarget.keys()) {
            if (this.pageUrls[a + "/"] != null or this.pageUrls[a] != null) {
                throw "alias \"" + a + "\" collides with a real page at the same path";
            }
            fs.makeDirectory(this.outDir + "/" + a);
            final rel = relativePath(a, this.aliasTarget[a]);
            final csp = cspForRedirectStub(redirectScript(rel));
            fs.writeFile(this.outDir + "/" + a + "/index.html", aliasStub(rel, csp));
            this.writtenPaths[a + "/index.html"] = true;
        }
    }

    // collectDocPage reads one docs page's frontmatter into a DocPage on docPages
    // (the relatedness/breadcrumb corpus). rel is the path under docs/.
    fun collectDocPage(rel: str) > void {
        final f = io.File.open(this.root + "/" + this.docs + "/" + rel, io.FileMode.read);
        final md = f.readAll();
        f.close();
        final fm = serialize.jsonDecode(markdown.frontmatter(md));
        var title = fm.q("title").stringValue();
        if (title == "") { title = deriveTitle(md, rel); }
        final desc = fm.q("description").stringValue();
        final url = cleanURL(rel, this.blog);
        // Join tags with "||" (never present in a tag) so the record stays flat;
        // sharedTagCount splits it back out.
        var joined = "";
        var first = true;
        foreach (t in parseTags(md)) {
            if (first) { joined = t; first = false; }
            else { joined = joined + "||" + t; }
        }
        this.docPages.append(DocPage{
            url = url,
            title = title,
            desc = desc,
            tags = joined,
            section = firstPathSegment(url),
            overview = pageType(md) == "overview",
            srcRel = this.docs + "/" + rel,
        });
    }

    // collectDocPages walks the docs/ subtree (same order as walk()) filling docPages
    // before any page renders, so renderRelated() sees the whole corpus.
    fun collectDocPages(rel: str) > void {
        var dir = this.root + "/" + this.docs;
        if (rel != "") { dir = this.root + "/" + this.docs + "/" + rel; }
        foreach (name in fs.list(dir)) {
            var childRel = name;
            if (rel != "") { childRel = rel + "/" + name; }
            if (isDirectory(this.root + "/" + this.docs + "/" + childRel)) {
                this.collectDocPages(childRel);
            } else {
                if (name.endsWith(".md")) { this.collectDocPage(childRel); }
            }
        }
    }

    // renderBreadcrumb builds the breadcrumb <nav> for one page. Blog, search, tour,
    // /public/, and /development/ get their own flat trails; docs pages hang off the
    // documentation index, each intermediate crumb showing the linked page's real
    // title (looked up in docPages via lookupTitle).
    fun renderBreadcrumb(srcRel: str, title: str, root: str) > str {
        if (srcRel == "README.md") { return ""; }
        // The crumb <li>s are computed per branch below (titles, links, current
        // markers); this one template wraps whichever list a branch builds. li is
        // injected raw - it is already-assembled markup, not a value to escape.
        final bcTmpl = `    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ul>{{{li}}}</ul>
    </nav>
`;
        var rel = srcRel;
        if (rel.startsWith(this.docs + "/")) { rel = rel.sub((this.docs + "/").len()); }
        final segsRaw = rel.split("/");

        var li = "<li><a href=\"" + root + "index.html\">Home</a></li>";

        // Blog pages have their own root: Home / Blog / <post> (the blog index itself
        // becomes the leaf). srcRel is blog/<file>.md for posts, or blog/index.md for
        // the listing page.
        if (srcRel == this.blog + "/index.md") {
            return template.render(bcTmpl, {"li": li + "<li aria-current=\"page\">Blog</li>"});
        }
        // The search page is a top-level tool surface: Home / Search (no Documentation
        // root, it does not hang off the documentation index).
        if (srcRel == "search/index.md") {
            return template.render(bcTmpl, {"li": li + "<li aria-current=\"page\">Search</li>"});
        }
        // The tour page is a top-level onboarding surface: Home / Tour.
        if (srcRel == "tour/index.md") {
            return template.render(bcTmpl, {"li": li + "<li aria-current=\"page\">Tour</li>"});
        }
        if (srcRel.startsWith(this.blog + "/")) {
            li = li + "<li><a href=\"" + root + "blog/\">Blog</a></li>"
                + "<li aria-current=\"page\">" + title + "</li>";
            return template.render(bcTmpl, {"li": li});
        }
        // The /public/ autoindex tree also skips the Documentation root; each level
        // gets a bare Home / <path> breadcrumb (the autoindex itself lists the parent
        // link in its own body, so the breadcrumb stays flat).
        if (srcRel.startsWith("public/")) {
            li = li + "<li aria-current=\"page\">" + title + "</li>";
            return template.render(bcTmpl, {"li": li});
        }

        // /development/ contributor surface. Home / Development for the landing; Home /
        // Development / <page> for a direct child (Contributing or a per-project target
        // catalog). Its own root, not the documentation index.
        if (srcRel.startsWith("development/")) {
            if (srcRel == "development/_index.md") {
                li = li + "<li aria-current=\"page\">Development</li>";
            } else {
                li = li + "<li><a href=\"" + root + "development/\">Development</a></li>"
                    + "<li aria-current=\"page\">" + title + "</li>";
            }
            return template.render(bcTmpl, {"li": li});
        }

        // The documentation index roots every docs trail; on that page itself it is
        // the current leaf rather than a link back to where you already are.
        if (rel == "documentation.md") {
            return template.render(bcTmpl, {"li": li + "<li aria-current=\"page\">Documentation</li>"});
        }
        li = li + "<li><a href=\"" + root + "documentation/\">Documentation</a></li>";

        // Drop the build-artifact "gen" segment so a manpage trail reads
        // Documentation / Manpage / <cmd>, not / Gen / <cmd> (matches the flattened URL).
        var segs: [str] = mut [<str>];
        foreach (s in segsRaw) { if (s != "gen") { segs.append(s); } }
        final base = segs[segs.len() - 1];

        final landing = (base == "index.md" or base == "README.md");
        var dirCount = segs.len() - 1;                              // directory segments before the file
        if (landing and dirCount > 0) { dirCount = dirCount - 1; }  // a landing's own dir is the leaf

        // Each intermediate crumb reads as the exact title of the page it links to
        // (looked up in docPages by URL), so the trail is consistent with the site's
        // own naming instead of a first-letter-capped URL segment. A crumb links when a
        // real page owns that URL - whether from an in-dir index (codes/race/README.md)
        // or a sibling-file landing (targets.md next to the targets/ subtree). Segments
        // with no page (e.g. the bare "codes/" grouping) fall back to a capitalized label.
        var acc = "";
        var i = 0;
        while (i < dirCount) {
            final seg = segs[i];
            if (acc == "") { acc = seg; } else { acc = acc + "/" + seg; }
            var label = capitalizeFirst(seg);
            final t = lookupTitle(acc + "/", this);
            if (t != "") {
                li = li + "<li><a href=\"" + root + acc + "/\">" + t + "</a></li>";
            } else {
                li = li + "<li>" + label + "</li>";
            }
            i = i + 1;
        }

        // The leaf is the current page's own title (faithful for both a landing and a
        // regular page), matching how the intermediate crumbs now read.
        li = li + "<li aria-current=\"page\">" + title + "</li>";
        return template.render(bcTmpl, {"li": li});
    }

    // renderRelated builds the "Related" card grid for the page whose source is
    // srcRel, or "" when it is not a docs page or is an overview page (those
    // enumerate their children in the body). Scores docPages: shared tags (x3),
    // same section (+4), overview (+3), the documentation index (+1); leads with the
    // nearest-ancestor overview. Up to four cards, ties broken by URL for stability.
    fun renderRelated(srcRel: str, root: str) > str {
        var curTags = "";
        var curSection = "";
        var curUrl = "";
        var curOverview = false;
        var found = false;
        foreach (p in this.docPages) {
            if (p.srcRel == srcRel) {
                curTags = p.tags;
                curSection = p.section;
                curUrl = p.url;
                curOverview = p.overview;
                found = true;
                break;
            }
        }
        if (found == false) { return ""; }
        if (curOverview) { return ""; }

        // picks is the final ordered card list; used dedups by URL (a page never links
        // to itself or lists the same neighbor twice).
        var picks: [{str: any}] = mut [<{str: any}>];
        var used: {str: bool} = mut {};
        used[curUrl] = true;

        // Stage 1: lead with the nearest-ancestor overview - the overview page whose
        // URL is the longest prefix of this page's URL.
        var leadUrl = "";
        var leadTitle = "";
        var leadDesc = "";
        foreach (p in this.docPages) {
            if (p.overview and p.url != curUrl and curUrl.startsWith(p.url)) {
                if (p.url.len() > leadUrl.len()) {
                    leadUrl = p.url;
                    leadTitle = p.title;
                    leadDesc = p.desc;
                }
            }
        }
        if (leadUrl != "") {
            picks.append(mut {"url": leadUrl, "title": leadTitle, "desc": leadDesc, "hasDesc": leadDesc != ""});
            used[leadUrl] = true;
        }

        // Stage 2: score every remaining page and fill up to four cards.
        var scored: [{str: str}] = mut [<{str: str}>];
        foreach (p in this.docPages) {
            if (used[p.url] == null) {
                var score = 3 * sharedTagCount(curTags, p.tags);
                if (curSection != "" and p.section == curSection) { score = score + 4; }
                if (p.overview) { score = score + 3; }
                if (p.srcRel == this.docs + "/documentation.md") { score = score + 1; }
                if (score > 0) {
                    scored.append(mut {
                        "key": pad4(score), "url": p.url, "title": p.title, "desc": p.desc
                    });
                }
            }
        }
        // Highest score first; ties by URL ascending. Padded keys compare lexically
        // the same as numerically, so strLess on the key is a numeric compare.
        final sorted = scored.sort(fun (a: {str: str}, b: {str: str}) > bool {
            if (a["key"] != b["key"]) { return strLess(b["key"], a["key"]); }
            return strLess(a["url"], b["url"]);
        });
        foreach (r in sorted) {
            if (picks.len() < 4) {
                picks.append(mut {"url": r["url"], "title": r["title"], "desc": r["desc"], "hasDesc": r["desc"] != ""});
            }
        }

        if (picks.len() == 0) { return ""; }

        return template.render(`  <section class="related container" aria-labelledby="related-heading">
    <h2 id="related-heading" class="related-heading">Related</h2>
    <div class="related-grid">
{{#picks}}
        <a class="related-card" href="{{root}}{{url}}"><span class="related-card-title">{{title}}</span>{{#hasDesc}}<span class="related-card-desc">{{desc}}</span>{{/hasDesc}}</a>
{{/picks}}
    </div>
  </section>
`, {"root": root, "picks": picks});
    }

    // loadMeta populates the commit-metadata fields once, shelling out to git. Pinned
    // to the default branch so deployed links stay stable across feature-branch renders.
    fun loadMeta() > void {
        if (this.metaLoaded) { return; }
        this.metaPrefix = capture("git -C " + this.root + " rev-parse --show-prefix");
        this.metaBranch = "main";
        this.metaFull = capture("git -C " + this.root + " rev-parse HEAD");
        this.metaShort = capture("git -C " + this.root + " rev-parse --short HEAD");
        this.metaStamp = capture("TZ=UTC git -C " + this.root + " show -s --date=format-local:'%Y-%m-%dT%H:%M:%SZ' --format=%cd HEAD");
        this.metaCommits = buildCommits(this);
        this.metaLoaded = true;
    }

    // assetIntegrityCheck throws on any dangling href/src in the written output, so a
    // renamed bundle or forgotten alias fails the build instead of shipping a 404.
    fun assetIntegrityCheck() > void {
        var files: [str] = mut [<str>];
        walkGen("", files, this);
        foreach (f in files) {
            if (f.endsWith(".html") == false and f.endsWith(".xml") == false and f.endsWith(".txt") == false) {
                // Non-textual asset: nothing to scan for refs.
            } else {
                final fh = io.File.open(this.outDir + "/" + f, io.FileMode.read);
                final html = fh.readAll();
                fh.close();
                final parts = f.split("/");
                var pageDir = "";
                if (parts.len() > 1) { pageDir = parts.sub(0, parts.len() - 1).join("/"); }
                foreach (target in scanReferencesInHTML(html, pageDir)) {
                    if (checkPathExists(target, this) == false) {
                        throw "asset integrity: " + f + " references missing " + target;
                    }
                }
            }
        }
    }

    // orphanCheck proves every docs page is reachable by BFS from the nav roots, so a
    // page with no inbound link fails the build instead of shipping unreachable.
    fun orphanCheck() > void {
        // Every written page, keyed the way pageKey() yields, so BFS can tell a page
        // link from an asset link.
        var files: [str] = mut [<str>];
        walkGen("", files, this);
        var isPage: {str: bool} = mut {};
        foreach (f in files) {
            if (f == "index.html") { isPage[""] = true; }
            else { if (f.endsWith("/index.html")) { isPage[f.sub(0, f.len() - 11)] = true; } }
        }

        var visited: {str: bool} = mut {};
        var queue: [str] = mut [<str>];
        foreach (r in ["", "documentation", "blog", "download", "tour", "playground", "search", "public", "development"]) {
            if (isPage[r] != null and visited[r] == null) { visited[r] = true; queue.append(r); }
        }
        var head = 0;
        while (head < queue.len()) {
            final key = queue[head];
            head = head + 1;
            var path = this.outDir + "/index.html";
            if (key != "") { path = this.outDir + "/" + key + "/index.html"; }
            final fh = io.File.open(path, io.FileMode.read);
            final html = fh.readAll();
            fh.close();
            foreach (ref in scanReferencesInHTML(html, key)) {
                final k = pageKey(ref);
                if (isPage[k] != null and visited[k] == null) {
                    visited[k] = true;
                    queue.append(k);
                }
            }
        }

        var orphans: [str] = mut [<str>];
        foreach (p in this.docPages) {
            var dk = p.url;
            if (dk.endsWith("/")) { dk = dk.sub(0, dk.len() - 1); }
            if (visited[dk] == null) { orphans.append(p.url); }
        }
        if (orphans.len() > 0) {
            throw "orphaned pages: {orphans.len()} docs renderPage(s) unreachable from site navigation (add a link from an overview page): " + orphans.join(", ");
        }
    }
}

// (The per-page reading-time and tags are no longer module globals: they are passed
// straight into renderPage() as the `reading` / `tags` arguments, so there is no
// set-before-call / clear-after temporal coupling to get wrong.)

fun capture(cmd: str) > str {
    final tmp = os.tmpFilename("sitegen");
    final code = os.execute(["sh", "-c", cmd + " > " + tmp + " 2>/dev/null"]);
    if (code != 0) {
        fs.delete(tmp);
        return "";
    }
    final f = io.File.open(tmp, io.FileMode.read);
    final result = f.readAll();
    f.close();
    fs.delete(tmp);
    return result.trim();
}

// Map of repo-root-relative source path -> "full|short|date" of the most recent
// commit that touched it, built from ONE git log (newest-first, so a file's first
// sighting wins) instead of a git call per page. ">>>" can't begin a repo path,
// so it cleanly marks each commit header; the file names follow until the next.
// Run with `git -C ..` so the pathspecs (README.md, docs) and written paths are
// magus/-relative, matching site.metaPrefix.
// HISTORY_MAX caps the per-file history depth in the "History" disclosure. The
// full log is one git spawn, so pushing this higher is cheap; a low cap keeps
// the rendered <details> panel from bloating on hot-edit files.
final HISTORY_MAX = 8;

// buildCommits parses one git-log pass:
//   - metaCommits: path -> "full|short|stamp" of the FIRST (newest) sighting.
//     Drives the always-visible "Last updated" footer line.
//   - metaHistory: path -> list of up to HISTORY_MAX "full|short|stamp|subject"
//     entries in newest-first order. Drives the collapsed WS R history panel.
// The log prints "SUBJ:<one-line subject>" after each ">>>" header so the two
// fields ride together without a second git spawn.
fun buildCommits(site: Site) > {str: str} {
    var m: {str: str} = mut {};
    site.metaHistory = mut {};
    final log = capture("TZ=UTC git -C " + site.root + " log --first-parent --diff-merges=first-parent --name-only "
        + "--date=format-local:'%Y-%m-%dT%H:%M:%SZ' "
        + "--format='>>>%H|%h|%cd%nSUBJ:%s' -- README.md docs blog CHANGELOG.md");
    var curHeader = "";
    var curSubject = "";
    foreach (line in log.split("\n")) {
        if (line.startsWith(">>>")) {
            curHeader = line.sub(3);
            curSubject = "";
        } else if (line.startsWith("SUBJ:")) {
            curSubject = line.sub(5);
        } else if (line != "" and curHeader != "") {
            // Newest sighting wins for the "last updated" line.
            if (m[line] == null) { m[line] = curHeader; }
            // Append to per-file history (newest-first) until HISTORY_MAX.
            var hist = site.metaHistory[line];
            if (hist == null) { hist = mut [<str>]; }
            if (hist.len() < HISTORY_MAX) {
                hist.append(curHeader + "|" + curSubject);
            }
            site.metaHistory[line] = hist;
        }
    }
    return m;
}


// deriveTitle reads a page title from the first H1, stripping the code backticks a
// markdown heading like `# `fs`` carries so the title reads cleanly as plain text
// in <title>, the breadcrumb, the pager, and the search index. (Frontmatter
// titles bypass this and are used verbatim.)
fun deriveTitle(md: str, rel: str) > str {
    foreach (line in md.split("\n")) {
        if (line.startsWith("# ")) { return $"`".replaceAll(line.sub(2).trim(), ""); }
    }
    return rel;
}


// parseTags reads the frontmatter `tags:` list from raw markdown as [str], empty when
// the field is absent. The one place tags are extracted so the rendered chips and
// the search index draw from the same source (markdown.frontmatter returns the
// YAML as JSON; serialize navigates it).
fun parseTags(md: str) > [str] {
    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    final tags: [str] = mut [];
    foreach (t in fm.q("tags").listValue()) {
        final tag = t.stringValue();
        // A "magus" tag narrows nothing - it is the whole project. Drop it site-wide so it
        // never renders as a chip or clutters the search index (a few docs, plus the magus
        // module/command pages, carry it in frontmatter).
        if (tag.lower() != "magus") { tags.append(tag); }
    }
    return tags;
}

// pageType reads the frontmatter `page_type:` marker (empty when absent). The one
// value that matters today is "overview": a landing/index page whose job is to
// orient and route to others (the documentation index, a section index like spells.md or
// modules/, a diagnostics-family README). Overview pages are the hubs the Related
// ranking favors and the roots the reachability gate trusts, so declaring the type
// in frontmatter beats guessing it from a URL shape.
fun pageType(md: str) > str {
    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    return fm.q("page_type").stringValue();
}

// isGenerated reports whether a page is mechanically generated rather than hand-
// written. Generated references live under three fixed docs/ subtrees that the doc
// generators overwrite wholesale: modules/ (cmd/magus-docs), spells/*.md
// (cmd/magus-spelldocs; the spells.md landing itself is hand-written), and
// manpage/ (cmd/magus-manpage). srcRel is the docs/-prefixed source path. Kept as
// a path convention because the generated .md carries no frontmatter marker.
fun isGenerated(srcRel: str, site: Site) > bool {
    return srcRel.startsWith(site.docs + "/buzz/modules/")
        or srcRel.startsWith(site.docs + "/spells/")
        or srcRel.startsWith(site.docs + "/manpage/")
        or srcRel == site.docs + "/config.md";
}


fun outputName(base: str) > str {
    if (base == "README.md") { return "index.html"; }
    return base.sub(0, base.len() - 3) + ".html";
}


// climb builds n repetitions of "../".
fun climb(n: int) > str {
    var s = "";
    var i = 0;
    while (i < n) { s = s + "../"; i = i + 1; }
    return s;
}

// climbFromDir returns the "../" prefix that climbs from a gen-relative directory back to
// gen's root - one "../" per path segment. So "playground" -> "../" and "console/dashboard"
// -> "../../". The standalone/app pages derive their nav prefix from their output location
// with this instead of a hand-maintained literal, which silently went wrong in the
// /console/ move (the prefix and the write path drifted apart).
fun climbFromDir(dir: str) > str {
    return climb(dir.split("/").len());
}

// sitePathPrefix returns the root-absolute URL path prefix for this deployment - the path
// component of SITE_URL, e.g. "https://eli.gladman.cc/magus/" -> "/magus/" - or "/" when
// SITE_URL is unset (an empty string splits to length 1, so the branch is skipped). Only the
// pages that can be served at an unpredictable depth (the 404 and the SW offline fallback)
// and the PWA manifest/service worker use this absolute scheme; every other page uses the
// depth-relative rootPrefix. One definition so the derivation isn't copy-pasted four ways.
fun sitePathPrefix() > str {
    var basePath = "/";
    final parts = SITE_URL.split("://");
    if (parts.len() > 1) {
        final rest = parts[1];
        final firstSlash = rest.indexOf("/");
        if (firstSlash != null) { basePath = rest.sub(firstSlash); }
    }
    if (basePath.endsWith("/") == false) { basePath = basePath + "/"; }
    return basePath;
}

// rewriteLinks applies rewriteHref to every href="..." in a rendered content
// fragment. It runs on the markdown-rendered body only (before the page template
// wraps it), so the nav/breadcrumb/pager hrefs — built separately with clean URLs —
// are never double-processed. oldDir/newDir are the page's old flat directory and
// new clean directory (both gen-root-relative, "" for the home page).
// newCleanDirectory gives a docs page's directory after the directory-index move -
// its clean URL without the trailing slash - for rewriteLinks. It reads site state
// (the blog dir, via cleanURL), so it stays here; the pure old-directory counterpart
// (oldFlatDirectory) lives in scribe_html.
fun newCleanDirectory(rel: str, site: Site) > str {
    final u = cleanURL(rel, site.blog);
    if (u == "") { return ""; }
    return u.sub(0, u.len() - 1);
}


// writeSEOFiles writes sitemap.xml + robots.txt from the real page URLs (sorted, so
// byte-stable), each as an absolute SITE_URL loc — the home page's "index.html" URL
// maps to the bare site root. Aliases are deliberately absent (only canonical pages
// belong in a sitemap). Gated on SITE_URL so the site can ship dark until the host
// is confirmed. robots points crawlers at the sitemap.
fun writeSEOFiles(site: Site) > void {
    if (SITE_URL == "") { return; }
    var urls: [str] = mut [<str>];
    foreach (u in site.pageUrls.keys()) { urls.append(u); }
    final sorted = urls.sort(fun (a: str, b: str) > bool { return strLess(a, b); });
    var body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
        + "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n";
    foreach (u in sorted) {
        var loc = u;
        if (loc == "index.html") { loc = ""; }
        body = body + "  <url>" + xmlElement("loc", SITE_URL + loc) + "</url>\n";
    }
    body = body + "</urlset>\n";
    fs.writeFile(site.outDir + "/sitemap.xml", body);
    fs.writeFile(site.outDir + "/robots.txt", "User-agent: *\nAllow: /\nSitemap: " + SITE_URL + "sitemap.xml\n");
}


// renderBlogAtom writes gen/public/atom/blog.atom.xml: an Atom 1.0 feed of
// site.blogPosts, newest first. Per <entry>: title, link (absolute), id (same URL),
// updated (post date), summary (description), author. Feed-level updated = newest
// post's date. Gated on SITE_URL so it can ship dark until the host is confirmed.
fun renderBlogAtom(site: Site) > void {
    if (SITE_URL == "") { return; }
    if (site.blogPosts.len() == 0) { return; }
    final sorted = site.blogPosts.sort(fun (a: BlogPost, b: BlogPost) > bool {
        if (a.date != b.date) { return strLess(b.date, a.date); }
        return strLess(a.base, b.base);
    });
    final feedUpdated = atomDate(sorted[0].date);
    var body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
        + "<feed xmlns=\"http://www.w3.org/2005/Atom\">\n"
        + "  " + xmlElement("title", "magus blog") + "\n"
        + "  " + xmlSelfClose("link", xmlAttribute("href", SITE_URL + "blog/") + xmlAttribute("rel", "alternate")) + "\n"
        + "  " + xmlSelfClose("link", xmlAttribute("href", SITE_URL + "public/atom/blog.atom.xml") + xmlAttribute("rel", "self")) + "\n"
        + "  " + xmlElement("id", SITE_URL + "blog/") + "\n"
        + "  " + xmlElement("updated", feedUpdated) + "\n";
    foreach (p in sorted) {
        final entryUrl = SITE_URL + p.url;
        body = body + "  <entry>\n"
            + "    " + xmlElement("title", p.title) + "\n"
            + "    " + xmlSelfClose("link", xmlAttribute("href", entryUrl)) + "\n"
            + "    " + xmlElement("id", entryUrl) + "\n"
            + "    " + xmlElement("updated", atomDate(p.date)) + "\n"
            + "    " + xmlElement("summary", p.description) + "\n"
            + "  </entry>\n";
    }
    body = body + "</feed>\n";
    fs.makeDirectory(site.outDir + "/public/atom");
    fs.writeFile(site.outDir + "/public/atom/blog.atom.xml", body);
}


// strToNat converts a decimal digit string to a non-negative int.
// Non-digit characters are ignored. Used for numeric semver segment parsing.
fun strToNat(s: str) > int {
    var n = 0;
    var i = 0;
    while (i < s.len()) {
        final b = s.byte(i);
        if (b >= 48 and b <= 57) { // '0'..'9' are codepoints 48-57
            n = n * 10 + (b - 48);
        }
        i = i + 1;
    }
    return n;
}

// semverSortKey returns a zero-padded sort key for a release filename.
// "v0.10.0.yaml" -> "0000.0010.0000", so lexicographic order matches numeric semver.
// Unknown filename formats fall through to the original name (safe: only used for sort).
fun semverSortKey(name: str) > str {
    var v = name;
    if (v.startsWith("v")) { v = v.sub(1); }
    if (v.endsWith(".yaml")) { v = v.sub(0, v.len() - 5); }
    final parts = v.split(".");
    var key = "";
    foreach (p in parts) {
        if (key.len() > 0) { key = key + "."; }
        key = key + pad4(strToNat(p));
    }
    return key;
}

// sortNamesSemverDesc sorts a list of release filenames descending by semver
// (newest-first). Uses selection sort; O(n^2) fine for the expected ~10-20 releases.
// Mirrors Go's compareSemver in cmd/magus-utils/release.go.
fun sortNamesSemverDesc(names: [str]) > [str] {
    var remaining: [str] = mut [<str>];
    foreach (n in names) { remaining.append(n); }
    var sorted: [str] = mut [<str>];
    while (remaining.len() > 0) {
        var maxIdx = 0;
        var maxKey = semverSortKey(remaining[0]);
        var k = 1;
        while (k < remaining.len()) {
            final key = semverSortKey(remaining[k]);
            if (key > maxKey) {
                maxKey = key;
                maxIdx = k;
            }
            k = k + 1;
        }
        sorted.append(remaining[maxIdx]);
        var next: [str] = mut [<str>];
        var m = 0;
        while (m < remaining.len()) {
            if (m != maxIdx) { next.append(remaining[m]); }
            m = m + 1;
        }
        remaining = next;
    }
    return sorted;
}

// loadReleases reads releases/v*.yaml (newest-first by numeric semver) and populates
// site.releases. Each yaml file is authoritative for one version: version, date, body
// (trimmed markdown for the Atom feed), notes sections (added/changed/fixed/removed),
// yanked flag, and artifacts (list of {name, platform, size, sha256}).
// This replaces parseChangelog: changelog-parsing now runs ONLY at cut time, never
// at site-build time.
fun loadReleases(site: Site) > void {
    site.releases = mut [<Release>];
    final relDir = site.root + "/releases";
    if (os.execute(["test", "-d", relDir]) != 0) { return; }
    // Collect yaml filenames, then sort newest-first by numeric semver so
    // v0.10.0 correctly precedes v0.2.0 (lexicographic reversal fails there).
    var names: [str] = mut [<str>];
    foreach (name in fs.list(relDir)) {
        if (name.endsWith(".yaml")) { names.append(name); }
    }
    final sorted = sortNamesSemverDesc(names);
    foreach (name in sorted) {
        final path = relDir + "/" + name;
        final f = io.File.open(path, io.FileMode.read);
        final src = f.readAll();
        f.close();
        final doc = serialize.Boxed.init(yaml.parse(src));
        final ver = doc.q("version").stringValue();
        final date = doc.q("date").stringValue();
        final body = doc.q("body").stringValue();
        if (ver == "") { continue; } // skip malformed files
        // Load structured notes sections (added/changed/fixed/removed).
        // .list() returns null when the YAML field is absent; guard before iterating.
        var notesAdded: [str] = mut [<str>];
        var notesChanged: [str] = mut [<str>];
        var notesFixed: [str] = mut [<str>];
        var notesRemoved: [str] = mut [<str>];
        final _addedList = doc.q("notes").q("added").list();
        if (_addedList != null) {
            foreach (item in _addedList) { notesAdded.append(item.stringValue()); }
        }
        final _changedList = doc.q("notes").q("changed").list();
        if (_changedList != null) {
            foreach (item in _changedList) { notesChanged.append(item.stringValue()); }
        }
        final _fixedList = doc.q("notes").q("fixed").list();
        if (_fixedList != null) {
            foreach (item in _fixedList) { notesFixed.append(item.stringValue()); }
        }
        final _removedList = doc.q("notes").q("removed").list();
        if (_removedList != null) {
            foreach (item in _removedList) { notesRemoved.append(item.stringValue()); }
        }
        final yanked = doc.q("yanked").booleanValue();
        // Load artifacts: each entry has name/platform/size/sha256.
        // .list() returns null when artifacts is absent; guard before iterating.
        var arts: [{str: str}] = mut [<{str: str}>];
        final artList = doc.q("artifacts").list();
        foreach (a in artList) {
            final artName = a.q("name").stringValue();
            final artPlatform = a.q("platform").stringValue();
            final artSize = a.q("size").stringValue();
            final artSHA256 = a.q("sha256").stringValue();
            arts.append(mut {
                "name": artName,
                "platform": artPlatform,
                "size": artSize,
                "sha256": artSHA256,
            });
        }
        site.releases.append(Release{
            version = ver,
            date = date,
            body = body,
            notesAdded = notesAdded,
            notesChanged = notesChanged,
            notesFixed = notesFixed,
            notesRemoved = notesRemoved,
            yanked = yanked,
            artifacts = arts,
        });
    }
}

// renderReleasesAtom writes gen/public/atom/releases.atom.xml from parsed
// releases (newest first as authored). Per <entry>: title = version, link =
// GH/releases/tag/<ver>, id = same, updated = release date, summary = the section
// body. Feed-level updated = newest release's date. Gated on SITE_URL and on
// having at least one released version.
fun renderReleasesAtom(site: Site) > void {
    if (SITE_URL == "") { return; }
    if (site.releases.len() == 0) { return; }
    final feedUpdated = atomDate(site.releases[0].date);
    var body = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
        + "<feed xmlns=\"http://www.w3.org/2005/Atom\">\n"
        + "  " + xmlElement("title", "magus releases") + "\n"
        + "  " + xmlSelfClose("link", xmlAttribute("href", GH + "/releases") + xmlAttribute("rel", "alternate")) + "\n"
        + "  " + xmlSelfClose("link", xmlAttribute("href", SITE_URL + "public/atom/releases.atom.xml") + xmlAttribute("rel", "self")) + "\n"
        + "  " + xmlElement("id", GH + "/releases") + "\n"
        + "  " + xmlElement("updated", feedUpdated) + "\n";
    foreach (r in site.releases) {
        final ver = r.version;
        final link = GH + "/releases/tag/" + ver;
        body = body + "  <entry>\n"
            + "    " + xmlElement("title", ver) + "\n"
            + "    " + xmlSelfClose("link", xmlAttribute("href", link)) + "\n"
            + "    " + xmlElement("id", link) + "\n"
            + "    " + xmlElement("updated", atomDate(r.date)) + "\n"
            + "    " + xmlElementAttribute("summary", xmlAttribute("type", "text"), r.body.trim()) + "\n"
            + "  </entry>\n";
    }
    body = body + "</feed>\n";
    fs.makeDirectory(site.outDir + "/public/atom");
    fs.writeFile(site.outDir + "/public/atom/releases.atom.xml", body);
}

// artifactDesc returns a human-readable description for a release artifact given
// its filename and platform string. Covers the standard release asset set.
fun artifactDesc(name: str, platform: str) > str {
    if (name == "SHA256SUMS")        { return "SHA-256 manifest"; }
    if (name == "SHA256SUMS.sig")    { return "Ed25519 signature of SHA256SUMS"; }
    if (name == "magus-release.pem") { return "Release signing key (SPKI PEM)"; }
    // Tarballs: derive from platform string (e.g. "linux/amd64", "darwin/arm64").
    if (platform == "linux/amd64")   { return "Linux amd64 binary"; }
    if (platform == "linux/arm64")   { return "Linux arm64 binary"; }
    if (platform == "darwin/amd64")  { return "macOS Intel binary"; }
    if (platform == "darwin/arm64")  { return "macOS Apple Silicon binary"; }
    if (platform == "windows/amd64") { return "Windows amd64 binary"; }
    return name;
}

// autoindex renders one Apache-`mod_autoindex`-styled listing at path (a gen-
// root-relative dir, without trailing slash; "" for the root of the /public/
// tree, "atom" or "release" for a subdir). entries is a list of records with
// {name, href, size?, modified?, desc}. Every level brackets the listing with a
// leading and trailing rule, like a real mirror index. Themed with Pico via the shared renderPage() template
// (no bespoke color palette), so light/dark follow the site theme. rootDepth is
// how many "../" the caller needs to reach gen/'s root, used only to preload the
// hat asset in the shared head.
fun renderAutoindex(path: str, entries: [{str: str}], parentHref: str, site: Site) > void {
    // Displayed path: /public or /public/atom, always absolute with leading + trailing slash.
    var displayPath = "/public";
    if (path != "public") { displayPath = "/" + path; }
    displayPath = displayPath + "/";

    // The parent link and the entry rows are fixed-width text (padded columns), so
    // buzz assembles them; the template only wraps the <pre> block. The padding must
    // stay here - Mustache can't align columns.
    // Sort entries by name so listings are byte-stable.
    final sorted = entries.sort(fun (a: {str: str}, b: {str: str}) > bool { return strLess(a["name"], b["name"]); });

    // Column widths grow to the widest cell (floors: the header labels, and 30 for
    // names to keep the classic look), so cells of any length stay aligned - a
    // release artifact name runs past 30 chars and a full RFC3339 stamp past a bare
    // date, either of which a fixed width would shove out of column. Two spaces
    // separate every column; Name/Last modified are left-aligned, Size right-aligned.
    var nameW = 30;
    if (parentHref != "") { if (16 > nameW) { nameW = 16; } }   // len("Parent Directory")
    var modW = 13;                                               // len("Last modified")
    var sizeW = 4;                                               // len("Size")
    foreach (e in sorted) {
        if (e["name"].len() > nameW) { nameW = e["name"].len(); }
        if (e["modified"].len() > modW) { modW = e["modified"].len(); }
        if (e["size"].len() > sizeW) { sizeW = e["size"].len(); }
    }

    // Header, padded to the same widths as the rows below.
    var head = "Name";
    var hi = 4; while (hi < nameW) { head = head + " "; hi = hi + 1; }
    head = head + "  Last modified";
    var hj = 13; while (hj < modW) { head = head + " "; hj = hj + 1; }
    var sizeHead = "Size";
    var hk = 4; while (hk < sizeW) { sizeHead = " " + sizeHead; hk = hk + 1; }
    head = head + "  " + sizeHead + "  Description";

    var parent = "";
    if (parentHref != "") {
        var pName = "<a href=\"" + parentHref + "\">Parent Directory</a>";
        var pi = 16; while (pi < nameW) { pName = pName + " "; pi = pi + 1; }
        var pMod = "-"; var pj = 1; while (pj < modW) { pMod = pMod + " "; pj = pj + 1; }
        var pSize = "-"; var pk = 1; while (pk < sizeW) { pSize = " " + pSize; pk = pk + 1; }
        parent = pName + "  " + pMod + "  " + pSize + "  \n";
    }

    var rows = "";
    foreach (e in sorted) {
        final name = e["name"];
        // The name cell pads by its visible length; the <a> tags occupy no columns.
        var nameCell = "<a href=\"" + e["href"] + "\">" + name + "</a>";
        var ni = name.len(); while (ni < nameW) { nameCell = nameCell + " "; ni = ni + 1; }
        var padMod = e["modified"];
        var mj = e["modified"].len(); while (mj < modW) { padMod = padMod + " "; mj = mj + 1; }
        var padSize = e["size"];
        var sk = e["size"].len(); while (sk < sizeW) { padSize = " " + padSize; sk = sk + 1; }
        rows = rows + nameCell + "  " + padMod + "  " + padSize + "  " + e["desc"] + "\n";
    }
    final body = template.render(`<h1>Index of {{displayPath}}</h1>
<pre class="autoindex"><span class="autoindex-head">{{{head}}}</span>
<hr>
{{{parent}}}{{{rows}}}<hr>
</pre>
`, {"displayPath": displayPath, "head": head, "parent": parent, "rows": rows});

    fs.makeDirectory(site.outDir + "/" + path);
    // srcMarker matches the written directory depth so rootPrefix computes the
    // right "../" climb (public/x.md -> "../", public/atom/x.md -> "../../").
    final srcMarker = path + "/_index.md";
    // Alias the marker's commit footer to a real content source so it stays stable
    // (not HEAD, which advances every commit and would break the drift gate). Use
    // CHANGELOG.md, which the /public/ tree derives from. If not yet committed,
    // fall back to HEAD - not a drift-gate failure, just a stale footer once, then
    // stable.
    final chLog = site.metaCommits[site.metaPrefix + "CHANGELOG.md"];
    if (chLog != null) {
        site.metaCommits[site.metaPrefix + srcMarker] = chLog;
    } else {
        site.metaCommits[site.metaPrefix + srcMarker] = site.metaFull + "|" + site.metaShort + "|" + site.metaStamp;
    }
    final doc = renderPage("Index of " + displayPath, "Index of " + displayPath, body, srcMarker, "", path + "/", "", mut [], site);
    final of = io.File.open(site.outDir + "/" + path + "/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    // Register the URL for sitemap purposes, and mark it written so
    // pruneStaleOutputs knows a since-removed release/feed's old autoindex page
    // should be cleaned up rather than left behind.
    site.pageUrls[path + "/"] = true;
    site.writtenPaths[path + "/index.html"] = true;
}

// jsonStr encodes a string value as a JSON string literal, escaping only the
// characters JSON requires: backslash, double-quote, and ASCII control characters
// 0x00-0x1F. Unicode pass-through is fine for JSON (and for this use case: release
// notes may contain em-dashes or other non-ASCII). Tabs/newlines are escaped
// explicitly since they appear in release note bodies.
fun jsonStr(s: str) > str {
    // str.replace is first-match only; split+join replaces every occurrence without
    // regex escaping concerns. Order matters: escape backslashes first so new ones
    // added for later escapes are not re-escaped.
    var escaped = s.split("\\").join("\\\\");
    escaped = escaped.split("\"").join("\\\"");
    escaped = escaped.split("\n").join("\\n");
    escaped = escaped.split("\r").join("\\r");
    escaped = escaped.split("\t").join("\\t");
    return "\"" + escaped + "\"";
}

// jsonStrList encodes a [str] as a JSON array of string literals.
fun jsonStrList(items: [str]) > str {
    var parts: [str] = mut [<str>];
    foreach (s in items) { parts.append(jsonStr(s)); }
    return "[" + parts.join(",") + "]";
}

// releaseIndexJSON builds the JSON body for gen/public/release/index.json.
// Schema version 1 (frozen): schema_version, releases[]{version, date, notes{added?,
// changed?, fixed?, removed?}, body, artifacts[]{name, platform, size, sha256}, yanked?}.
// Field order and names match the Go ReleaseManifest struct in cmd/magus-utils/release.go
// so the schema is one canonical frozen v1 regardless of emitter.
// Emits compact JSON; git-stable across runs; one release per line.
fun releaseIndexJSON(site: Site) > str {
    // \{ and \} are the Buzz escape sequences for literal braces in a double-quoted
    // string (the unescaped { would start a string-interpolation expression).
    var relJson: [str] = mut [<str>];
    foreach (rel in site.releases) {
        // Build the notes sub-object, omitting empty sections (matching Go omitempty).
        var notesParts: [str] = mut [<str>];
        if (rel.notesAdded.len() > 0) {
            notesParts.append("\"added\":" + jsonStrList(rel.notesAdded));
        }
        if (rel.notesChanged.len() > 0) {
            notesParts.append("\"changed\":" + jsonStrList(rel.notesChanged));
        }
        if (rel.notesFixed.len() > 0) {
            notesParts.append("\"fixed\":" + jsonStrList(rel.notesFixed));
        }
        if (rel.notesRemoved.len() > 0) {
            notesParts.append("\"removed\":" + jsonStrList(rel.notesRemoved));
        }
        final notesJson = "\{" + notesParts.join(",") + "\}";
        var artJson: [str] = mut [<str>];
        foreach (a in rel.artifacts) {
            artJson.append("\{\"name\":" + jsonStr(a["name"]) + ",\"platform\":" + jsonStr(a["platform"]) + ",\"size\":" + jsonStr(a["size"]) + ",\"sha256\":" + jsonStr(a["sha256"]) + "\}");
        }
        var entry = "\{\"version\":" + jsonStr(rel.version)
            + ",\"date\":" + jsonStr(rel.date)
            + ",\"notes\":" + notesJson
            + ",\"body\":" + jsonStr(rel.body)
            + ",\"artifacts\":[" + artJson.join(",") + "]";
        if (rel.yanked) { entry = entry + ",\"yanked\":true"; }
        entry = entry + "\}";
        relJson.append(entry);
    }
    return "\{\"schema_version\":1,\"releases\":[" + relJson.join(",") + "]\}\n";
}

// renderPublic writes the nested /public/ autoindex tree: the root at /public/
// lists atom/ + release/ subdirs plus the machine files that live at their
// canonical spec locations (/sitemap.xml, /robots.txt); /public/atom/ lists the
// two Atom feeds; /public/release/ is a data-driven listing of release artifacts.
// Deterministic (no network at build).
fun renderPublic(site: Site) > void {
    if (SITE_URL == "") { return; }

    // /public/atom/ - the two feeds (if they were written).
    var atomEntries: [{str: str}] = mut [<{str: str}>];
    if (site.blogPosts.len() > 0) {
        atomEntries.append(mut {
            "name": "blog.atom.xml", "href": "blog.atom.xml",
            "size": "-", "modified": atomDate(site.blogPosts[0].date),
            "desc": "Blog posts (Atom 1.0)"
        });
    }
    if (site.releases.len() > 0) {
        atomEntries.append(mut {
            "name": "releases.atom.xml", "href": "releases.atom.xml",
            "size": "-", "modified": atomDate(site.releases[0].date),
            "desc": "Releases (Atom 1.0)"
        });
    }
    if (atomEntries.len() > 0) { renderAutoindex("public/atom", atomEntries, "../", site); }

    // /public/release/  - per-version tree. Each released version (loaded from
    // releases/v*.yaml by loadReleases) gets its own subdirectory listing its
    // artifacts. Deep-links to individual assets use GH/releases/download/<ver>/<name>
    // directly; magus-release.pem links to the local /assets/ copy (three levels up).
    // size comes from the manifest (populated by the release-cut tool); "-" for
    // historical releases migrated without artifact data.
    foreach (rel in site.releases) {
        final ver = rel.version;
        final date = rel.date;
        final assetBase = GH + "/releases/download/" + ver;
        var verEntries: [{str: str}] = mut [<{str: str}>];
        foreach (art in rel.artifacts) {
            final artName = art["name"];
            var artSize = art["size"];
            if (artSize == "") { artSize = "-"; }
            var artDate = date;
            if (artName == "magus-release.pem") { artDate = "-"; }
            var artHref = assetBase + "/" + artName;
            if (artName == "magus-release.pem") { artHref = "../../../assets/magus-release.pem"; }
            final artDesc = artifactDesc(artName, art["platform"]);
            verEntries.append(mut {
                "name": artName, "href": artHref,
                "size": artSize, "modified": artDate, "desc": artDesc,
            });
        }
        renderAutoindex("public/release/" + ver, verEntries, "../", site);
    }

    // /public/release/  - parent index listing every version as a subdirectory.
    // Empty when no releases have shipped yet; just the bracketing rules remain.
    var releaseParent: [{str: str}] = mut [<{str: str}>];
    foreach (rel in site.releases) {
        final ver = rel.version;
        releaseParent.append(mut {"name": ver + "/", "href": ver + "/", "size": "-", "modified": rel.date, "desc": "Release " + ver});
    }
    renderAutoindex("public/release", releaseParent, "../", site);

    // gen/public/release/index.json - machine-readable release index, newest-first.
    // Schema: schema_version (1) + releases array. URL and schema are frozen at birth;
    // additive changes only. index.json.sig (Ed25519) is written by magus-utils
    // release-index at release time (not here; signing key is not available at
    // site-build time). Track in writtenPaths so pruneStaleOutputs knows it is current.
    if (site.releases.len() > 0) {
        final idxJson = releaseIndexJSON(site);
        fs.writeFile(site.outDir + "/public/release/index.json", idxJson);
        site.writtenPaths["public/release/index.json"] = true;
    }

    // /public/ root.
    var rootEntries: [{str: str}] = mut [<{str: str}>];
    // Modified timestamps: content-derived where possible (a feed's newest entry
    // stamp), "-" otherwise (release matrix is deferred; robots/sitemap are
    // deterministic outputs whose only "mod time" would be build time, which would
    // drift on every commit and break the drift gate).
    if (atomEntries.len() > 0) {
        rootEntries.append(mut {"name": "atom/", "href": "atom/", "size": "-", "modified": atomDate(site.blogPosts[0].date), "desc": "Atom feeds"});
    }
    rootEntries.append(mut {"name": "release/", "href": "release/", "size": "-", "modified": "-", "desc": "Release artifacts"});
    rootEntries.append(mut {"name": "sitemap.xml", "href": "../sitemap.xml", "size": "-", "modified": "-", "desc": "XML sitemap"});
    rootEntries.append(mut {"name": "robots.txt", "href": "../robots.txt", "size": "-", "modified": "-", "desc": "Robots policy"});
    renderAutoindex("public", rootEntries, "../", site);
}

// render404 writes gen/404.html - the themed "warped off the map" page GitHub
// Pages serves for any unmatched path. GitHub Pages keeps the deep 404 URL in
// the address bar, so the site's ordinary relative paths would break here; this
// page therefore uses root-absolute paths (/<basePath>/site.css, /<basePath>/
// main.js, etc.) - the ONE deliberate exception to the relative-link scheme in
// WS0b. basePath is derived from SITE_URL (e.g. https://eli.gladman.cc/magus/
// -> "/magus/"); when SITE_URL is empty, fall back to "/" so the page still
// renders locally with absolute paths from the server root.
fun render404(site: Site) > void {
    final basePath = sitePathPrefix();
    final title = "Page not found - magus";
    final desc = "You have warped off the map. That page is not here; head back to the documentation, install page, or playground.";
    // Its own template (rather than renderPage()) because every asset/link here must be
    // root-absolute, not relative - GitHub Pages keeps the deep 404 URL in the bar.
    final tmpl = `<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="generator" content="magus">
  <meta http-equiv="Content-Security-Policy" content="{{{csp}}}">
  <title>{{title}}</title>
  <meta name="description" content="{{desc}}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{basePath}}assets/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="{{basePath}}assets/apple-touch-icon.png">
  <link rel="stylesheet" href="{{basePath}}assets/pico.min.css">
  <link rel="stylesheet" href="{{basePath}}theme.css">
  <link rel="stylesheet" href="{{basePath}}site.css">
  <!-- ui-panels.css: the shared settings-gear dropdown + reference drawer (split out of console.css). -->
  <link rel="stylesheet" href="{{basePath}}ui-panels.css">
  <script src="{{basePath}}theme.js"></script>
</head>
<body>
{{{nav}}}  <main class="container">
    <article>
      <h1>You have warped off the map.</h1>
      <p><em>No such target.</em> Let us get you back:</p>
      <ul>
        <li><a href="{{basePath}}">Home</a></li>
        <li><a href="{{basePath}}documentation/">Documentation</a></li>
        <li><a href="{{basePath}}download/">Download</a></li>
        <li><a href="{{basePath}}tour/">Tour</a></li>
        <li><a href="{{basePath}}playground/">Playground</a></li>
      </ul>
    </article>
  </main>
{{{footer}}}  <script type="module" src="{{basePath}}main.js"></script>
</body>
</html>
`;
    final doc = template.render(tmpl, {
        "title": title, "desc": desc, "basePath": basePath, "csp": site.csp,
        "nav": renderSiteNav(basePath, "", false), "footer": renderSiteFooter(basePath, site),
    });
    fs.writeFile(site.outDir + "/404.html", doc);
}

// writeOffline writes gen/offline/index.html - the themed page shown by the service
// worker when a navigation request fails (network unreachable and no cached copy).
// Like render404, it must use root-absolute asset paths because its URL depth differs
// from the rest of the site; basePath is derived the same way render404 derives it.
// Graph and playground are called out explicitly because they are precached and fully
// functional offline - they are the honest answer to "what CAN I do right now?".
fun writeOffline(site: Site) > void {
    final basePath = sitePathPrefix();
    final title = "You are offline - magus";
    final desc = "No network connection. The graph explorer and playground are fully functional offline.";
    final tmpl = `<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="generator" content="magus">
  <meta http-equiv="Content-Security-Policy" content="{{{csp}}}">
  <title>{{title}}</title>
  <meta name="description" content="{{desc}}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{basePath}}assets/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="{{basePath}}assets/apple-touch-icon.png">
  <link rel="stylesheet" href="{{basePath}}assets/pico.min.css">
  <link rel="stylesheet" href="{{basePath}}theme.css">
  <link rel="stylesheet" href="{{basePath}}site.css">
  <!-- ui-panels.css: the shared settings-gear dropdown + reference drawer (split out of console.css). -->
  <link rel="stylesheet" href="{{basePath}}ui-panels.css">
  <script src="{{basePath}}theme.js"></script>
</head>
<body>
{{{nav}}}  <main class="container">
    <article>
      <h1>You are offline.</h1>
      <p>This page requires a network connection and is not available offline.</p>
      <p>This works fully offline (it is cached on your device):</p>
      <ul>
        <li><a href="{{basePath}}playground/">Playground</a> - run Buzz code in the browser</li>
      </ul>
      <p>The <a href="{{basePath}}console/">console</a> is a separate installable app with its own offline cache.</p>
    </article>
  </main>
{{{footer}}}  <script type="module" src="{{basePath}}main.js"></script>
</body>
</html>
`;
    final doc = template.render(tmpl, {
        "title": title, "desc": desc, "basePath": basePath, "csp": site.csp,
        "nav": renderSiteNav(basePath, "", false), "footer": renderSiteFooter(basePath, site),
    });
    fs.makeDirectory(site.outDir + "/offline");
    fs.writeFile(site.outDir + "/offline/index.html", doc);
    // Register so pruneStaleOutputs does not treat it as a stale leftover; it
    // is always produced (the SW precaches it) so it never becomes stale.
    site.writtenPaths["offline/index.html"] = true;
}

// llmsIndexBody builds the gen/llms.txt document (the llms.txt convention): an H1,
// a one-line summary, then every docs page as "- [title](base+url): description",
// sorted by URL for a byte-stable artifact like search-index.json. base is the link
// prefix (SITE_URL for absolute links, else "/"). Each linked page has its Markdown
// source at <url>index.md (emitted next to the HTML by renderFile), so an agent can
// fetch clean Markdown per page. Kept pure so a unit test can pin the exact output.
fun llmsIndexBody(pages: [DocPage], base: str) > str {
    final sorted = pages.sort(fun (a: DocPage, b: DocPage) > bool {
        return strLess(a.url, b.url);
    });
    var body = "# magus\n\n"
        + "> Workspace-aware build orchestrator and content-addressed cache. "
        + "Every link below is the page's raw Markdown (its index.md sibling), "
        + "so an agent fetches clean content directly.\n\n"
        + "## Documentation\n\n";
    foreach (p in sorted) {
        // Link straight to the page's Markdown (directory-style url + index.md, the
        // sibling of index.html), not the HTML page, so no URL guessing is needed.
        var line = "- [" + p.title + "](" + base + p.url + "index.md)";
        if (p.desc != "") { line = line + ": " + p.desc; }
        body = body + line + "\n";
    }
    return body;
}

// writeLLMsIndex writes gen/llms.txt from the collected docs corpus, mirroring the
// post-walk search-index.json write. Links are absolute under SITE_URL when set so
// an external agent can follow them; otherwise root-relative.
fun writeLLMsIndex(site: Site) > void {
    var base = "/";
    if (SITE_URL != "") {
        base = SITE_URL;
        if (base.endsWith("/") == false) { base = base + "/"; }
    }
    fs.writeFile(site.outDir + "/llms.txt", llmsIndexBody(site.docPages, base));
}

// fileSha256 reads path and returns its lowercase-hex SHA-256 digest. The one
// place file bytes get hashed for both writeServiceWorker's cache-version
// stamp and writeSiteManifest's per-asset integrity list, so the two never
// drift into computing "the same hash" two different ways.
fun fileSha256(path: str) > str {
    return crypto.hash(crypto.HashAlgorithm.Sha256, fs.readFile(path));
}

// scriptHash returns a CSP `sha256-<base64>` source for js's exact text (the
// same bytes a browser hashes when it evaluates a `<script>` element's
// content against a hash-source script-src). crypto.hash returns lowercase
// hex; CSP hash-sources are base64, so hex_decode back to raw digest bytes
// before base64-encoding - encoding.base64Encode/hexDecode exist for exactly
// this "reformat a digest" case, not just URL-safe payload transport.
fun scriptHash(js: str) > str {
    return "sha256-" + encoding.base64Encode(encoding.hexDecode(crypto.hash(crypto.HashAlgorithm.Sha256, js)));
}

// extractInlineScripts pulls the exact text content of every attribute-less
// `<script>...</script>` block out of html, in order. Deliberately matches
// only the literal "<script>" open tag (no attributes) - a `<script src=...>`
// or `<script type="module" src=...>` is an external load already covered by
// script-src 'self', not a hash-source candidate.
fun extractInlineScripts(html: str) > [str] {
    var scripts: [str] = mut [<str>];
    var rest = html;
    while (true) {
        final start = rest.indexOf("<script>");
        if (start == null) { return scripts; }
        rest = rest.sub(start + 8);   // len("<script>") == 8
        final end = rest.indexOf("</script>");
        if (end == null) { return scripts; }
        scripts.append(rest.sub(0, end));
        rest = rest.sub(end + 9);   // len("</script>") == 9
    }
    return scripts;
}

// CSP_INLINE_SCRIPT_SOURCES lists the source HTML files scanned for inline
// <script> blocks whose hashes the site-wide CSP must allow. Every
// renderPage()-based page (docs, home, search, tour, blog, /public/) carries
// no inline script at all; only the hand-authored playground.html does today
// (its WASM bootstrap, the syntax-overlay resize sync, draft persistence, and
// the fullscreen toggle - 4 blocks). Adding an inline <script> to a listed
// file, or to a new file not listed here, is a build-time correctness bug
// that surfaces immediately as a browser CSP violation on that page instead
// of silently working - see computeCSP's doc comment for why that is the
// intended failure mode, not a bug to route around.
final CSP_INLINE_SCRIPT_SOURCES = ["playground.html"];

// CSP_IMG_SRC_DEFAULT is the img-src every page gets except the home page:
// same-origin images plus data: URIs (inline SVG/icon data), nothing else.
// img-src is a GET-only channel that connect-src cannot restrict (an
// `<img src="https://host/?leaked=...">` still fires even though
// connect-src's loopback lock would refuse the same host as a fetch target),
// so the graph and playground pages - which hold the reader's own dependency
// graph or source code - carry no external image allowance at all.
final CSP_IMG_SRC_DEFAULT = "'self' data:";

// CSP_IMG_SRC_HOME extends CSP_IMG_SRC_DEFAULT with the two hosts the
// README's status badges load from (github.com's Actions badge, pkg.go.dev's
// reference badge) - see computeCSP's doc comment. Only the home page embeds
// those badges, so only the home page's CSP (Site.cspHome) passes this value;
// every other page passes CSP_IMG_SRC_DEFAULT.
final CSP_IMG_SRC_HOME = CSP_IMG_SRC_DEFAULT + " https://github.com https://pkg.go.dev";

// computeCSP builds one page's Content-Security-Policy meta content (see the
// doc comment on Site.csp/Site.cspHome for which pages get which img-src).
// Deny-by-default (default-src 'self' - not 'none': manifest-src and the
// same-origin-only <link rel=prefetch> hover-warm in src/site/prefetch.ts both fall
// back to default-src per the CSP3 fetch-directive spec, and the service
// worker registration (`navigator.serviceWorker.register('sw.js')`, main.js)
// falls back through worker-src -> child-src -> default-src since neither is
// named explicitly here - 'self' is the minimal fallback that keeps all three
// working without opening a single directive wider than same-origin; 'none'
// would break the service worker registration outright), then every
// directive the site actually needs is named explicitly and nothing else is
// permitted:
//   - script-src: 'self' for the external bundles, 'wasm-unsafe-eval' because
//     the Go/TinyGo WebAssembly runtime (the playground, and run-example.js's
//     lazy "Run" buttons on docs pages) requires it to instantiate a wasm
//     module - there is no narrower CSP source for that capability - plus one
//     sha256- hash per inline script found in CSP_INLINE_SCRIPT_SOURCES.
//     Hashing the ACTUAL script bytes (not a hand-copied constant) is what
//     makes "add a script, forget to regenerate" fail loudly in the browser
//     instead of silently shipping a hole.
//   - style-src: 'unsafe-inline' because a few pages carry a <style> block or
//     a style="" attribute (playground.html's layout CSS, a couple of
//     noscript fallbacks) rather than an external sheet; CSP has no
//     hash-source for style ATTRIBUTES (only style-src-attr's newer
//     'unsafe-hashes', not yet universal), so a per-block hash scheme would
//     leave the attribute case uncovered anyway.
//   - img-src: imgSrc, verbatim (CSP_IMG_SRC_DEFAULT everywhere except the
//     home page, which passes CSP_IMG_SRC_HOME for its two status badges -
//     live status indicators, CI result and doc coverage, that vendoring
//     would make permanently stale, unlike Pico/mermaid/hljs (pure
//     libraries, vendored in Phase 0 with zero loss of freshness)). Scoping
//     the widened allowance to the one page that actually embeds the badges
//     keeps every other page - notably graph/playground - at same-origin-only.
//   - connect-src: 'self' plus the loopback wildcards - the browser-enforced
//     form of the loopback-only rule (plan 0.3), kept in sync with the
//     literal 127.0.0.1/[::1] host check the graph explorer's live mode makes
//     client-side. This is intentionally NOT loosened for graph.html's/
//     playground.html's `#src=<url>` loader, which can point at an arbitrary
//     CORS-enabled address (e.g. a raw GitHub link): a third-party #src= now
//     fails at the browser CSP layer rather than being fetched. Both loaders
//     already handle a fetch failure gracefully (a status message, not a
//     crash) - see docs/reference/console.md's "Verify our claims" section.
//   - form-action/object-src/frame-src 'none': no <form>, <object>/<embed>, or
//     <iframe> anywhere on the site.
//   - base-uri 'self': nothing sets <base>; pins it against injection anyway.
fun computeCSP(imgSrc: str) > str {
    var scriptSrc = "'self' 'wasm-unsafe-eval'";
    foreach (path in CSP_INLINE_SCRIPT_SOURCES) {
        final f = io.File.open(path, io.FileMode.read);
        final html = f.readAll();
        f.close();
        foreach (js in extractInlineScripts(html)) {
            scriptSrc = scriptSrc + " '" + scriptHash(js) + "'";
        }
    }
    return "default-src 'self'; script-src " + scriptSrc
        + "; style-src 'self' 'unsafe-inline'"
        + "; img-src " + imgSrc
        + "; connect-src 'self' http://127.0.0.1:* http://[::1]:*"
        + "; form-action 'none'; base-uri 'self'; object-src 'none'; frame-src 'none'";
}

// cspForRedirectStub builds the CSP a plain alias redirect page needs -
// distinct from computeCSP's site-wide policy because a redirect stub
// (aliasStub) loads no stylesheet, image, or external script; its only
// content is one inline <script> whose text embeds the redirect target, so
// it differs per stub and cannot share the single site-wide hash list. script
// is the exact text redirectScript(rel) (scribe_html.buzz) produces - the
// same string aliasStub embeds, so the hash always matches what ships.
fun cspForRedirectStub(script: str) > str {
    return "default-src 'none'; script-src '" + scriptHash(script) + "'"
        + "; base-uri 'self'; form-action 'none'; object-src 'none'; frame-src 'none'";
}

// writeManifest writes gen/manifest.webmanifest - the PWA metadata browsers
// (mostly on Android and Windows) read to allow "install this site". Icons
// reuse the hat mark (WS A/V); scope/start_url match the deploy base so a
// nested install stays inside /magus/. Gated on SITE_URL so a same-origin
// scope is well-defined; without it we'd default to "/" and mis-scope.
fun writeManifest(site: Site) > void {
    if (SITE_URL == "") { return; }
    final basePath = sitePathPrefix();
    // Buzz interpolates { ... } in strings, so JSON braces are escaped as \{ \}
    // (see gopherbuzz/testdata/54_raw_string.buzz).
    // Icons: favicon-32 and apple-touch-icon are the legacy set; icon-192/512 target
    // Android/Windows install prompts; icon-512-maskable carries a solid #13171f
    // background so the hat mark stays centered in the safe zone for circular crops.
    final body = "\{\n"
        + "  \"name\": \"magus\",\n"
        + "  \"short_name\": \"magus\",\n"
        + "  \"id\": \"" + basePath + "\",\n"
        + "  \"lang\": \"en\",\n"
        + "  \"description\": \"" + escapeAttr(SITE_DESC) + "\",\n"
        + "  \"start_url\": \"" + basePath + "\",\n"
        + "  \"scope\": \"" + basePath + "\",\n"
        + "  \"display\": \"standalone\",\n"
        + "  \"categories\": [\"developer\", \"utilities\"],\n"
        + "  \"background_color\": \"#ffffff\",\n"
        + "  \"theme_color\": \"#3178c6\",\n"
        + "  \"icons\": [\n"
        + "    \{ \"src\": \"" + basePath + "assets/favicon-32.png\", \"sizes\": \"32x32\", \"type\": \"image/png\", \"purpose\": \"any\" \},\n"
        + "    \{ \"src\": \"" + basePath + "assets/apple-touch-icon.png\", \"sizes\": \"180x180\", \"type\": \"image/png\", \"purpose\": \"any\" \},\n"
        + "    \{ \"src\": \"" + basePath + "assets/icon-192.png\", \"sizes\": \"192x192\", \"type\": \"image/png\", \"purpose\": \"any\" \},\n"
        + "    \{ \"src\": \"" + basePath + "assets/icon-512.png\", \"sizes\": \"512x512\", \"type\": \"image/png\", \"purpose\": \"any\" \},\n"
        + "    \{ \"src\": \"" + basePath + "assets/icon-512-maskable.png\", \"sizes\": \"512x512\", \"type\": \"image/png\", \"purpose\": \"maskable\" \}\n"
        + "  ],\n"
        + "  \"shortcuts\": [\n"
        + "    \{ \"name\": \"Console\", \"url\": \"" + basePath + "console/\" \},\n"
        + "    \{ \"name\": \"Playground\", \"url\": \"" + basePath + "playground/\" \},\n"
        + "    \{ \"name\": \"Getting started\", \"url\": \"" + basePath + "getting-started/\" \}\n"
        + "  ],\n"
        + "  \"launch_handler\": \{ \"client_mode\": \"focus-existing\" \}\n"
        + "\}\n";
    fs.writeFile(site.outDir + "/manifest.webmanifest", body);
}

// writeServiceWorker writes gen/sw.js - a conservative worker that keeps HTML
// network-first (never stale docs) and static hashed assets cache-first, and
// precaches the search index + playground WASM so those two heavy features
// survive an offline reload. The source lives in website/sw.js.tmpl (Buzz
// interpolates { ... } inside strings, so embedding JS with arrow functions
// as inline strings would collide). We swap __VERSION__ (keyed off HEAD's
// short commit hash so a new build purges old caches on activate) and
// __BASE__ (SITE_URL's path prefix).
fun writeServiceWorker(site: Site) > void {
    if (SITE_URL == "") { return; }
    final basePath = sitePathPrefix();
    final tmplFile = io.File.open("sw.js.tmpl", io.FileMode.read);
    var body = tmplFile.readAll();
    tmplFile.close();
    // The cache version is a digest of the precached assets' own digests, so it changes
    // exactly when a cached asset changes and is otherwise byte-identical across
    // re-renders. This deliberately replaces the old "magus-<HEAD short hash>" form, which
    // changed on every commit, could never contain its own commit's hash, and so
    // perpetually drifted the gen gate.
    //
    // The list is parsed from the template's OWN PRECACHE array (the single source of
    // truth) rather than duplicated here - a second hand-maintained copy silently drifted
    // once (the /console/ move left this list pointing at logs/ and dashboard/ instead of
    // console/logs/ and console/dashboard/, so the test -f guard below skipped them and
    // editing those apps never bumped the version -> stale service worker). Only the
    // PRECACHE block is scanned, so the fetch handler's own BASE + "offline/" is ignored.
    final pcRest = body.sub(body.indexOf("const PRECACHE = ["));
    final pcBlock = pcRest.sub(0, pcRest.indexOf("];"));
    var precached = mut [<str>];
    foreach (line in pcBlock.split("\n")) {
        final q = line.indexOf("BASE + \"");
        if (q != null) {
            final tail = line.sub(q + 8); // past `BASE + "`
            var rel = tail.sub(0, tail.indexOf("\""));
            // A directory URL (e.g. offline/) caches its index.html; hash that real file.
            if (rel.endsWith("/")) { rel = rel + "index.html"; }
            precached.append(rel);
        }
    }
    var manifest = "";
    foreach (rel in precached) {
        final p = site.outDir + "/" + rel;
        if (os.execute(["test", "-f", p]) == 0) {
            manifest = manifest + rel + ":" + fileSha256(p) + "\n";
        }
    }
    final version = "magus-" + crypto.hash(crypto.HashAlgorithm.Sha256, manifest).sub(0, 12);
    // .replace only touches the first match; the markers appear both in the file
    // header comment and in the code, so replaceAll it is.
    body = $"__VERSION__".replaceAll(body, version);
    body = $"__BASE__".replaceAll(body, basePath);
    fs.writeFile(site.outDir + "/sw.js", body);
}

// Footer crediting the last commit that touched a page's source (a magus/-relative
// path), falling back to HEAD for a not-yet-committed file. Keying off the file's
// own history means a page changes when its source does, not when any commit lands.
fun renderCommitFooter(path: str, site: Site) > str {
    var cFull = site.metaFull;
    var cShort = site.metaShort;
    var cStamp = site.metaStamp;
    final rec = site.metaCommits[site.metaPrefix + path];
    if (rec != null) {
        final parts = rec.split("|");
        cFull = parts[0];
        cShort = parts[1];
        cStamp = parts[2];
    }
    // "Last updated" line: the always-visible provenance. A <small> paragraph so
    // Pico's typography sets the muted look; no custom classes. It stays one inline
    // line (no newlines) so the templates below carry none either.
    var line = template.render(`<small>Last updated <time datetime="{{stampAttr}}">{{stampDisplay}}</time> (<a href="{{gh}}/commit/{{full}}" data-tooltip="{{full}}" title="{{full}}">{{short}}</a>)</small>`,
        {"stampAttr": cStamp, "stampDisplay": formatISO(cStamp), "gh": GH, "full": cFull, "short": cShort});

    // <details> disclosure of the EARLIER commits that touched this page (the latest
    // is already named above, so it is skipped to avoid a double reference). Semantic
    // markup only - Pico styles <details>/<summary>/<ul>/<code>/<small>/<a> natively.
    // Gated on the file having a real history entry; synthesized pages fall back to
    // the "Last updated" line alone, and a single-commit page shows nothing extra.
    final histKey = site.metaPrefix + path;
    final hist = site.metaHistory[histKey];
    if (hist != null and hist.len() > 0) {
        var earlier: [{str: any}] = mut [<{str: any}>];
        foreach (row in hist) {
            final parts = row.split("|");
            if (parts.len() >= 3 and parts[0] != cFull) {
                final rec = mut {<str: any>};
                rec["full"] = parts[0];
                rec["short"] = parts[1];
                rec["stampAttr"] = parts[2];
                rec["stampDisplay"] = formatISOShort(parts[2]);
                var rowSubj = "";
                if (parts.len() >= 4) { rowSubj = parts[3]; }
                rec["subj"] = rowSubj;
                earlier.append(rec);
            }
        }
        if (earlier.len() > 0) {
            line = line + template.render(`<details class="recent-changes"><summary>Earlier changes on this page ({{count}})</summary><ul>{{#earlier}}<li><a href="{{gh}}/commit/{{full}}"><code>{{short}}</code></a> <small><time datetime="{{stampAttr}}">{{stampDisplay}}</time></small> - {{subj}}</li>{{/earlier}}</ul><p><small><a href="{{gh}}/commits/{{branch}}/{{histKey}}" data-tooltip="All commits that touched this page" title="All commits that touched this page">Full history &#x2197;</a> &middot; <a href="{{gh}}/blame/{{branch}}/{{histKey}}" data-tooltip="Line-by-line commit attribution on GitHub" title="Line-by-line commit attribution on GitHub">Blame source &#x2197;</a></small></p></details>`,
                {"count": earlier.len(), "earlier": earlier, "gh": GH, "branch": site.metaBranch, "histKey": histKey});
        }
    }
    return line;
}

// rootPrefix returns the relative path from a generated page back up to gen/'s
// root ("" for spells.html, "../" for modules/fs.html, "../../" for
// codes/sandbox/X.html), so the shared nav links and theme.js resolve at any
// page depth and the site still works when served under a project subpath.
fun rootPrefix(srcRel: str, site: Site) > str {
    var rel = srcRel;
    if (rel.startsWith(site.docs + "/")) { rel = rel.sub((site.docs + "/").len()); }
    return climb(cleanDepth(rel, site.blog));
}

// stripTags removes HTML tags from a fragment, leaving its text. The text keeps
// the HTML-encoded entities goldmark produced, so it drops straight into a
// double-quoted attribute (TOC link tooltips) without re-escaping.
fun stripTags(s: str) > str {
    var r = s;
    var lt = r.indexOf("<");
    while (lt != null) {
        final gt = r.indexOf(">");
        if (gt == null) { return r; }
        r = r.sub(0, lt) + r.sub(gt + 1);
        lt = r.indexOf("<");
    }
    return r;
}

// collapseWs turns any run of whitespace (newlines/tabs/spaces goldmark left in the
// markup) into single spaces, so a derived description reads as one clean line.
fun collapseWs(s: str) > str {
    var r = s.replace("\n", " ").replace("\t", " ").replace("\r", " ");
    while (r.indexOf("  ") != null) { r = r.replace("  ", " "); }
    return r.trim();
}

// decodeEntities turns the HTML entities goldmark produces back into their characters
// for a plain-text description. &amp; is decoded LAST so an entity like "&amp;lt;"
// does not get double-decoded into "<".
fun decodeEntities(s: str) > str {
    return s.replace("&lt;", "<").replace("&gt;", ">").replace("&quot;", "\"")
        .replace("&#39;", "'").replace("&#34;", "\"").replace("&amp;", "&");
}

// truncateWords caps s at about n characters, cutting on a word boundary so the
// description never ends mid-word. Short paragraphs (the common case) pass through.
fun truncateWords(s: str, n: int) > str {
    if (s.len() <= n) { return s; }
    final head = s.sub(0, n);
    var i = head.len() - 1;
    while (i > 0) {
        if (head.sub(i, 1) == " ") { return head.sub(0, i); }
        i = i - 1;
    }
    return head;
}

// readingTime estimates minutes-to-read by weighting content by type rather than
// blindly counting words: prose reads at 220 wpm, but a fenced code block is
// parsed line by line (not skimmed like prose) and an image or diagram costs a
// few seconds of looking. So a page that is mostly code or figures gets a truer
// estimate than a raw word count, which would badly under- or over-shoot it.
// Frontmatter is stripped so YAML doesn't skew the count. Returns "" for pages too
// short to be worth labeling. Deterministic: a pure function of the committed source.
fun readingTime(md: str) > str {
    final text = markdown.stripFrontmatter(md);
    final WPM = 220;               // prose words per minute
    final CODE_SEC_PER_LINE = 2;   // a code line is read deliberately, not skimmed
    final IMG_SEC = 10;            // time to take in one image or diagram

    // Walk line by line so fenced code (``` or ~~~) is measured by line count while
    // prose is measured by word count. A fence marker line itself is chrome, not
    // content; blank lines inside a fence are skipped so whitespace doesn't inflate.
    var proseWords = 0;
    var codeLines = 0;
    var inFence = false;
    var fence = "";                // the marker (``` or ~~~) that opened the fence
    foreach (line in text.split("\n")) {
        final t = line.trim();
        if (inFence) {
            if (t.startsWith(fence)) { inFence = false; fence = ""; }
            else { if (t != "") { codeLines = codeLines + 1; } }
        } else {
            if (t.startsWith("```")) { inFence = true; fence = "```"; }
            else { if (t.startsWith("~~~")) { inFence = true; fence = "~~~"; }
            else {
                // Prose line: count runs of non-whitespace as words.
                var inWord = false;
                var i = 0;
                while (i < line.len()) {
                    final b = line.byte(i);
                    final isSpace = (b == 32 or b == 9 or b == 10 or b == 13);
                    if (isSpace) { inWord = false; }
                    else { if (inWord == false) { proseWords = proseWords + 1; } inWord = true; }
                    i = i + 1;
                }
            } }
        }
    }

    // Images/diagrams: markdown "![alt](src)" plus raw <img>. A split-count is cheap
    // and order-independent; a stray "![" in prose is rare enough to ignore.
    final images = (text.split("![").len() - 1) + (text.split("<img").len() - 1);

    final seconds = (proseWords * 60) / WPM + codeLines * CODE_SEC_PER_LINE + images * IMG_SEC;
    if (seconds < 45) { return ""; }   // too short to be worth a chip (~under a minute)
    var mins = (seconds + 30) / 60;    // round to the nearest minute
    if (mins < 1) { mins = 1; }
    return "{mins} min read";
}

// deriveDescription is the belt-and-suspenders page description: the first
// substantive paragraph of the rendered HTML, tags stripped, whitespace collapsed,
// entities decoded, truncated on a word boundary. A leading image-only paragraph
// (the hero) yields empty text and is skipped. "" when no paragraph has text, so
// the caller can fall back to SITE_DESC. Runs before escapeAttr re-encodes, so the
// decode here avoids the double-encoding the plan's risk register flags.
fun deriveDescription(html: str) > str {
    var rest = html;
    var open = rest.indexOf("<p>");
    while (open != null) {
        final close = rest.indexOf("</p>");
        if (close == null) { return ""; }
        // sub(start, length): the inner-paragraph text runs from just past "<p>"
        // to just before "</p>", so its length is (close - (open + 3)).
        final inner = rest.sub(open + 3, close - (open + 3));
        final text = decodeEntities(collapseWs(stripTags(inner)));
        if (text != "") { return truncateWords(text, 155); }
        rest = rest.sub(close + 4);
        open = rest.indexOf("<p>");
    }
    return "";
}

// strLess is lexicographic string ordering by byte; buzz has no `<` on str, so
// the sibling pager spells it out to sort filenames deterministically.
fun strLess(a: str, b: str) > bool {
    final n = a.len();
    final m = b.len();
    var i = 0;
    while (i < n and i < m) {
        if (a.byte(i) != b.byte(i)) { return a.byte(i) < b.byte(i); }
        i = i + 1;
    }
    return n < m;
}

// renderToc builds the "On this page" sidebar from a rendered page's h2/h3 headings
// (goldmark produces each on its own line with a slug id); h3s nest under their h2.
// Returns "" with fewer than three headings — too little to warrant a sidebar (a
// module page with one "Methods" h2 over many h3 methods still qualifies) — so
// renderPage() falls back to a full-width article. toc.js layers scroll-spy + the
// collapse toggle onto this markup, so the list must already exist for it to find.
fun renderToc(content: str) > str {
    final lines = content.split("\n");
    var nHead = 0;
    foreach (line in lines) {
        if (line.startsWith("<h2 id=\"") or line.startsWith("<h3 id=\"")) { nHead = nHead + 1; }
    }
    if (nHead < 3) { return ""; }

    var ul = "<ul>";
    var haveLi = false;   // an h2 <li> is open, awaiting its </li>
    var inSub = false;    // an h3 sublist <ul> is open
    foreach (line in lines) {
        var lvl = 0;
        if (line.startsWith("<h2 id=\"")) { lvl = 2; }
        if (line.startsWith("<h3 id=\"")) { lvl = 3; }
        if (lvl != 0) {
            final after = line.sub(8);                 // past `<hN id="`
            final q = after.indexOf("\"");
            final gt = line.indexOf(">");
            if (q != null) {
                if (gt != null) {
                    final id = after.sub(0, q);
                    final inner = line.sub(gt + 1);
                    final end = inner.indexOf("</h");
                    var label = inner;
                    if (end != null) { label = inner.sub(0, end); }
                    // TOC entries render as plain text - drop inline <code>,
                    // <strong>, <em> etc from the heading so nothing in the
                    // sidebar looks bold, italic, or code-styled.
                    final plain = stripTags(label);
                    final link = "<a href=\"#" + id + "\" title=\"" + plain + "\">" + plain + "</a>";
                    if (lvl == 2) {
                        if (inSub) { ul = ul + "</ul>"; inSub = false; }
                        if (haveLi) { ul = ul + "</li>"; }
                        ul = ul + "<li>" + link;
                        haveLi = true;
                    } else {
                        if (haveLi == false) {
                            ul = ul + "<li>" + link + "</li>";
                        } else {
                            if (inSub == false) { ul = ul + "<ul>"; inSub = true; }
                            ul = ul + "<li>" + link + "</li>";
                        }
                    }
                }
            }
        }
    }
    if (inSub) { ul = ul + "</ul>"; }
    if (haveLi) { ul = ul + "</li>"; }
    ul = ul + "</ul>";
    // A muted closing hint at the foot of the list, mirroring the nav dropdown's
    // .nav-menu-hint: it only shows when the TOC is a mobile bottom sheet (dismissed
    // by tapping the backdrop or pressing Esc), and is hidden on the desktop sidebar.
    return template.render(`    <aside class="toc">
      <nav>
        <p class="toc-title">On this page</p>
        {{{ul}}}
        <p class="toc-hint" aria-hidden="true">Tap outside or press Esc to close</p>
      </nav>
    </aside>
`, {"ul": ul});
}

// dirLabel maps a docs subdirectory name to its breadcrumb label.
// cap upper-cases the first character of a slug for a breadcrumb label.
fun capitalizeFirst(s: str) > str {
    if (s == "") { return s; }
    return s.sub(0, 1).upper() + s.sub(1);
}

// navLink renders one top-nav item, marking it aria-current when it is the page
// the visitor is currently on (key == active).

// renderSettingsPanel renders the gear button and its dropdown - the rightmost control
// in every top bar. The theme (auto/light/dark) select lives here on EVERY page: it
// replaced the standalone toggle button so the bar carries two trailing controls
// (reference + gear), not three. showConsole adds the daemon-app operator prefs (refresh
// rate, daemon host) that only the console apps read and persist; the docs, playground,
// 404, and offline pages get the theme row alone. console-settings.js opens/closes the
// panel (and persists poll/host); theme.js seeds and drives the #theme-cycle button
// (click cycles auto/light/dark), since it owns the pre-paint theme set(). Both scripts
// no-op when their controls are absent.
fun renderSettingsPanel(showConsole: bool) > str {
    var rows = "";
    if (showConsole) {
        rows = `          <label class="settings-row"><span>Refresh rate</span><select id="settings-poll"><option value="5000">5s</option><option value="10000">10s</option><option value="20000">20s</option><option value="60000">60s</option></select></label>
          <label class="settings-row"><span>Daemon host</span><input id="settings-host" type="text" placeholder="127.0.0.1:7391" spellcheck="false" autocomplete="off"></label>
`;
    }
    // "Saved locally" rather than "in this browser": these apps install as a PWA, so the
    // browser framing reads wrong. The reload behavior is no longer stated here - changing a
    // console pref now raises a "reload to apply" toast (console-settings.js), so the note
    // stays short and the same on every surface.
    final note = "Saved locally.";
    final tmpl = `        <button id="settings-btn" class="outline" type="button" aria-controls="settings-panel" aria-expanded="false" aria-haspopup="true" aria-label="Settings" title="Settings"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
        <div class="settings-panel" id="settings-panel" hidden aria-label="Settings">
          <h2 class="settings-title">Settings</h2>
          <p class="settings-note">{{note}}</p>
{{{rows}}}          <div class="settings-row"><span>Theme</span><button type="button" id="theme-cycle" class="theme-cycle outline" aria-label="Color theme"><span class="theme-cycle-icon" aria-hidden="true"></span><span class="theme-cycle-label">Auto</span></button></div>
        </div>`;
    return template.render(tmpl, {"note": note, "rows": rows});
}

// renderSiteNav renders the shared top bar (brand + section links + settings gear). One
// definition for every page - docs pages via renderPage(), the 404, and the playground
// (build-time injected via renderPlayground) - so adding a nav item lands everywhere
// at once. root is the relative prefix back to gen/'s root; active is the current
// section's key (or "" for none). withRef controls the Reference (drawer trigger)
// button: it is shown only where the page actually ships a #ref-drawer + ref-drawer.js
// and loads console.css (which sizes the icon button) - the docs pages and the
// playground (whose drawer holds its "not everything runs here" module note). The 404
// and offline pages have no reference content, so they pass false to omit the trigger
// and its divider rather than render an oversized, dead button.
fun renderSiteNav(root: str, active: str, withRef: bool) > str {
    // On mobile the five section links collapse behind a menu button. That button is a
    // plain Pico .outline <button> (like the theme toggle) - NOT a <details>, whose Pico
    // accordion styling we kept having to fight - so it inherits the button look for free
    // and nav.js toggles the dropdown. Brand + theme toggle stay outside it, always shown.
    // The toggle icon swaps hamburger -> X when the menu is open (CSS keys off
    // .nav-right.nav-open); both glyphs ship in the button, one shows at a time. The
    // "Menu" caption and the closing hint are mobile-popup only (aria-hidden on
    // desktop). Home is an explicit link because the brand mark's accessible name is
    // just "magus". The {{#links}} section marks the active item with aria-current;
    // a backtick raw string holds the Mustache verbatim.
    final tmpl = `  <header class="site-header">
    <nav class="container">
      <ul><li><a href="{{root}}index.html" class="contrast"><picture><source srcset="{{root}}assets/hat.webp" type="image/webp"><img class="brand-mark" src="{{root}}assets/hat.png" width="65" height="48" alt=""></picture> <strong>magus</strong></a></li></ul>
      <div class="nav-right">
{{#withRef}}        <button class="ref-trigger outline" type="button" aria-controls="ref-drawer" aria-expanded="false" aria-label="Reference" title="Reference"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="16" y2="11"/></svg></button>
        <span class="nav-divider" aria-hidden="true"></span>
{{/withRef}}        <button class="nav-toggle outline" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav-links"><svg class="icon-menu" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg><svg class="icon-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg></button>
        <ul class="nav-links" id="site-nav-links">
          <li class="nav-menu-label" aria-hidden="true">Menu</li>
{{#links}}        <li><a href="{{href}}"{{#current}} aria-current="page"{{/current}}>{{label}}</a></li>
{{/links}}          <li class="nav-menu-hint" aria-hidden="true">Tap outside or press Esc to close</li>
        </ul>
{{{settings}}}
      </div>
    </nav>
  </header>
`;
    final links = mut [<{str: any}>];
    links.append({"href": root + "index.html", "label": "Home", "current": active == "home"});
    links.append({"href": root + "documentation/", "label": "Documentation", "current": active == "documentation"});
    links.append({"href": root + "blog/", "label": "Blog", "current": active == "blog"});
    links.append({"href": root + "download/", "label": "Download", "current": active == "download"});
    links.append({"href": root + "tour/", "label": "Tour", "current": active == "tour"});
    links.append({"href": root + "playground/", "label": "Playground", "current": active == "playground"});
    links.append({"href": root + "console/", "label": "Console", "current": active == "console"});
    // The console SPA (a separate top-level project, copied to /console/ at deploy) is the single
    // public entry point to magus's browser apps: it hosts the dashboard, graph explorer, log viewer,
    // and activity trail as tabs, so none of them get their own top-nav item. The docs site no longer
    // renders anything at /console/ - the app owns it. The loopback-API reference doc lives under
    // /reference/console/. Playground stays a distinct link above because it is a standalone in-browser
    // Buzz runner (no daemon) that the tour deep-links into, not a daemon app.
    return template.render(tmpl, {"root": root, "links": links, "withRef": withRef, "settings": renderSettingsPanel(false)});
}

// renderReferenceDrawer returns the docs-site reference panel: the same slide-out drawer the console
// apps use (styled by console.css, driven by ref-drawer.js), but WITHOUT data-relocate-search so the
// docs keep their prominent top search bar in place. Its one .ref-section links the key reference
// pages; ref-drawer.js relocates it into the drawer and the inline-browse feature opens each one in
// the panel (no navigating away). root is the relative prefix back to gen/'s root.
// Cached, root-templated reference content. Each doc is rendered to HTML ONCE, then its root-relative
// links ("../X", from a depth-1 page) get a %%ROOT%% marker so renderReferenceDrawer can substitute
// the embedding page's own root prefix per page - the same content works from any depth.
var _refGlossary = "";
var _refConventions = "";
var _refLoaded = false;

// refDocHtml renders one docs/*.md to content HTML and templatizes its root-relative links.
fun refDocHtml(rel: str, site: Site) > str {
    final f = io.File.open(site.root + "/" + site.docs + "/" + rel, io.FileMode.read);
    final md = f.readAll();
    f.close();
    var html = renderContentHTML(markdown.toHtml(md), oldFlatDirectory(rel), newCleanDirectory(rel, site));
    while (html.indexOf("=\"../") != null) { html = html.replace("=\"../", "=\"%%ROOT%%"); }
    return html;
}

fun loadReferenceContent(site: Site) > void {
    if (_refLoaded) { return; }
    _refLoaded = true;
    _refGlossary = refDocHtml("glossary.md", site);
    _refConventions = refDocHtml("conventions.md", site);
}

fun renderReferenceDrawer(root: str, site: Site) > str {
    loadReferenceContent(site);
    var glossary = _refGlossary;
    while (glossary.indexOf("%%ROOT%%") != null) { glossary = glossary.replace("%%ROOT%%", root); }
    var conventions = _refConventions;
    while (conventions.indexOf("%%ROOT%%") != null) { conventions = conventions.replace("%%ROOT%%", root); }
    final tmpl = `  <details class="ref-section" open>
    <summary>Glossary</summary>
    <div class="disclosure-body ref-embed">{{{glossary}}}</div>
  </details>
  <details class="ref-section" open>
    <summary>Conventions</summary>
    <div class="disclosure-body ref-embed">{{{conventions}}}</div>
  </details>
  <div class="ref-backdrop" id="ref-backdrop"></div>
  <aside class="ref-drawer" id="ref-drawer" aria-hidden="true" aria-label="Reference">
    <div class="ref-drawer-head">
      <div class="ref-drawer-head-l">
        <button type="button" class="ref-pin" aria-pressed="false" aria-label="Pin the reference panel open" title="Pin the reference panel open"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 4h6l-1 5 3 3v2H7v-2l3-3-1-5z"/><line x1="12" y1="14" x2="12" y2="21"/></svg></button>
        <h2 class="ref-drawer-title">Reference</h2>
      </div>
      <button type="button" class="ref-drawer-close" aria-label="Close reference">&times;</button>
    </div>
  </aside>
`;
    return template.render(tmpl, {"root": root, "glossary": glossary, "conventions": conventions});
}

// renderSiteFooter renders the shared one-line attribution footer. It leads with two
// root-relative site links (the Search tool and the /public/ file tree) so those
// surfaces are reachable from every page, then the absolute GitHub/Buzz links; the
// License link points at the pinned site.metaBranch (main) like the other GitHub links.
// root is the relative prefix back to gen/'s root (so the site links resolve at any
// page depth), matching renderSiteNav's root argument.
fun renderSiteFooter(root: str, site: Site) > str {
    // Two clusters spread across the footer's width: this site's own surfaces on
    // the left, the project/external links on the right. Dots separate items within
    // a cluster; the clusters divide the row without adding a second line on desktop.
    // The middle cluster's app entry is the Console (the single entry point to the browser
    // apps, matching the header) - the dashboard, graph, logs, and activity are its tabs.
    // Backtick raw string holds the Mustache verbatim (a double-quoted "{{x}}" would
    // collide with Buzz's own {expr} interpolation).
    final tmpl = `  <footer class="site-footer container">
    <small class="footer-group"><a href="{{root}}search/">Search</a> &middot; <a href="{{root}}public/">Files</a></small>
    <small class="footer-group"><a href="{{root}}console/">Console</a> &middot; <a href="{{root}}playground/">Playground</a> &middot; <a href="{{root}}tour/">Tour</a></small>
    <small class="footer-group"><a href="{{gh}}">Source Code</a> &middot; <a href="{{gh}}/blob/{{branch}}/LICENSE">License</a> &middot; <a href="https://buzz-lang.dev/">Built with Buzz</a></small>
  </footer>
`;
    return template.render(tmpl, {"root": root, "gh": GH, "branch": site.metaBranch});
}

// lookupTitle returns the title of the docs page at a clean gen-root URL (e.g.
// "modules/" -> "magus stdlib"), or "" when no docs page owns that URL. Used by
// renderBreadcrumb so an intermediate crumb reads as its destination page's real title.
fun lookupTitle(url: str, site: Site) > str {
    foreach (p in site.docPages) {
        if (p.url == url) { return p.title; }
    }
    return "";
}

// renderAnnouncementBar renders a dismissible top strip announcing the newest shipped
// release, or "" when none has shipped yet (so it stays dormant until then). The
// version comes from loadReleases (releases/*.yaml), so it is drift-stable;
// announcement.js hides it once the reader dismisses that version and re-shows it on
// the next release. The GitHub tag link mirrors the releases Atom feed's convention.
fun renderAnnouncementBar(site: Site) > str {
    if (site.releases.len() == 0) { return ""; }
    final ver = site.releases[0].version;
    final tmpl = `  <div id="announcement-bar" data-version="{{ver}}">
    <div class="container">
      <span>magus <strong>{{ver}}</strong> is out. <a href="{{gh}}/releases/tag/{{ver}}">See what's new</a></span>
      <button class="announcement-close" type="button" aria-label="Dismiss announcement">&times;</button>
    </div>
  </div>
`;
    return template.render(tmpl, {"ver": ver, "gh": GH});
}

// renderPlayground writes gen/playground/index.html from the hand-authored source, injecting
// the shared nav + footer at its <!-- site-nav --> / <!-- site-footer --> placeholders.
// The playground is a standalone page (custom head, wasm, its own scripts) so it does
// not go through renderPage(); templating only the top nav keeps it in lockstep with every
// other page (its bottom chrome is the console status bar, authored in playground.html, not
// the docs footer). It sits at gen/'s root, so its nav prefix is "".
fun renderPlayground(site: Site) > void {
    final f = io.File.open("playground.html", io.FileMode.read);
    var html = f.readAll();
    f.close();
    // The page ships at /playground/ (a directory index like every other page), so
    // its injected nav climbs one level to reach the site root.
    final outDir = "playground";
    final root = climbFromDir(outDir);
    html = html.replace("<!-- site-nav -->", renderSiteNav(root, "playground", true));
    // No site-footer injection: the playground wears the console apps' bottom status bar
    // (authored directly in playground.html) instead of the docs footer, so the parse
    // result reads in the console design language. renderSiteFooter still serves the docs
    // pages (renderPage) and the reference drawer.
    // The default (non-home) CSP meta - site.csp, not site.cspHome - since the
    // playground has no reason to load an external image and holds the reader's
    // own source, so it gets the tighter img-src, not the badge hosts. Also:
    // playground.html's own <!-- csp --> placeholder is what
    // CSP_INLINE_SCRIPT_SOURCES reads to compute it in the first place, so this
    // file is both the hash's source and its sink.
    html = html.replace("<!-- csp -->", "<meta http-equiv=\"Content-Security-Policy\" content=\"" + site.csp + "\">");
    fs.makeDirectory(site.outDir + "/" + outDir);
    fs.writeFile(site.outDir + "/" + outDir + "/index.html", html);
}


// renderPagerLink renders one prev/next card, reading the sibling's source so it credits
// the same title (frontmatter title, else first H1) the sibling page renders with.
fun renderPagerLink(srcDir: str, name: str, dir: str, cls: str, climbPrefix: str) > str {
    final f = io.File.open(srcDir + "/" + name, io.FileMode.read);
    final md = f.readAll();
    f.close();
    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    var title = fm.q("title").stringValue();
    if (title == "") { title = deriveTitle(md, name); }
    // Siblings are directory-index pages under the same parent dir. A regular page
    // lives in its own <slug>/ subdir, so it climbs one level to reach a sibling
    // (../<slug>/); an index.md landing sits directly in the parent, so it does not.
    final slug = name.sub(0, name.len() - 3);   // drop ".md"
    return template.render(`      <a class="{{cls}}" href="{{climbPrefix}}{{slug}}/"><span class="page-nav-dir">{{dir}}</span><span class="page-nav-title">{{title}}</span></a>
`, {"cls": cls, "climbPrefix": climbPrefix, "slug": slug, "dir": dir, "title": title});
}

// renderPager renders the previous/next links among a page's siblings — the other
// rendered docs in the same source directory, ordered by filename (README/index
// and underscore-prefixed fixtures excluded). Links are bare basenames, since a
// sibling lives in the same output directory. "" when there is no sibling on
// either side. rel is docs-relative (e.g. "modules/fs.md").
fun renderPager(rel: str, site: Site) > str {
    final parts = rel.split("/");
    final base = parts[parts.len() - 1];
    var srcDir = site.root + "/" + site.docs;
    if (parts.len() > 1) { srcDir = srcDir + "/" + parts.sub(0, parts.len() - 1).join("/"); }

    var sibs: [str] = mut [<str>];
    foreach (name in fs.list(srcDir)) {
        // README.md/index.md are the directory's landing page, reached via the
        // breadcrumb and nav — not a prev/next peer — so they stay out of the pager
        // (and their clean URL is the parent dir, which a sibling link can't express).
        if (name.endsWith(".md") and name != "README.md" and name != "index.md"
            and name.startsWith("_") == false) {
            sibs.append(name);
        }
    }
    if (sibs.len() < 2) { return ""; }
    final ordered = sibs.sort(fun (a: str, b: str) > bool { return strLess(a, b); });

    var pos = -1;
    var i = 0;
    while (i < ordered.len()) {
        if (ordered[i] == base) { pos = i; }
        i = i + 1;
    }
    if (pos < 0) { return ""; }

    // Every pageable sibling now lives in its own <slug>/ subdir, so a page climbs
    // one level to reach a peer (../<slug>/). Landings are excluded above.
    final climbPrefix = "../";

    var body = "";
    if (pos > 0) { body = body + renderPagerLink(srcDir, ordered[pos - 1], "Previous", "page-nav-prev", climbPrefix); }
    if (pos < ordered.len() - 1) { body = body + renderPagerLink(srcDir, ordered[pos + 1], "Next", "page-nav-next", climbPrefix); }
    if (body == "") { return ""; }
    return template.render(`    <nav class="page-nav" aria-label="Pagination">
{{{body}}}    </nav>
`, {"body": body});
}
// srcRel is the page's source path relative to magus/ (e.g. "docs/spells.md");
// it drives both the per-page commit footer and the "Suggest an edit" link.
// description is the resolved page description (frontmatter, else derived, else the
// site default) — always non-empty, so the meta tag always fires. canonUrl is the
// page's clean gen-root URL ("" for home) for the canonical link. pager is the
// prev/next nav (may be ""); the home page and lone pages pass "".
fun renderPage(title: str, description: str, content: str, srcRel: str, pager: str, canonUrl: str, reading: str, tags: [str], site: Site) > str {
    final root = rootPrefix(srcRel, site);
    // Which top-nav item to mark current. Every rendered docs page hangs off the
    // documentation index, except the dedicated install page; the home page (README)
    // highlights nothing (its wordmark is the home link).
    var active = "documentation";
    if (srcRel == "README.md") { active = "home"; }
    if (srcRel == site.docs + "/download.md" or srcRel.startsWith(site.docs + "/download/")) { active = "download"; }
    // Blog posts and the blog index live under the "Blog" nav item.
    if (srcRel.startsWith(site.blog + "/") or srcRel == site.blog + "/index.md") { active = "blog"; }
    // /public/ autoindex pages are meta surfaces; no nav item is current.
    if (srcRel.startsWith("public/")) { active = ""; }
    // The search page is a tool surface with no nav home of its own.
    if (srcRel == "search/index.md") { active = ""; }
    // The tour page is its own top-nav item.
    if (srcRel == "tour/index.md") { active = "tour"; }
    // /development/ is a contributor surface reached from the footer, not the top nav.
    if (srcRel.startsWith("development/")) { active = "development"; }
    // View-model flags for the head's optional blocks; the markup itself lives in
    // the template's sections below. hasDescription gates the description meta and
    // og:description. hasSiteUrl gates the canonical + og:* block (og:url/og:image
    // must be absolute), so the site can ship dark until the host is confirmed;
    // SITE_URL carries the trailing slash, canonUrl is the slashed clean path.
    final hasDescription = description != "";
    final hasSiteUrl = SITE_URL != "";
    // Atom feed discovery advertises each feed only when it was actually written:
    // releases once a version has shipped, blog on the home + blog pages once a post
    // exists. Advertising a missing file would trip the asset-integrity check.
    final hasReleasesFeed = hasSiteUrl and site.releases.len() > 0;
    final hasBlogFeed = hasSiteUrl and site.hasBlogPosts and (srcRel == "README.md" or srcRel.startsWith(site.blog + "/"));
    // Preload the LCP hero image on the home page only (README's gopher), so the
    // browser fetches it in parallel with the CSS.
    final isHome = srcRel == "README.md";
    // The home page is the only one whose CSP img-src needs to reach past
    // same-origin (its two status badges); every other page keeps site.csp's
    // tighter default. See Site.csp/Site.cspHome's doc comments.
    var pageCsp = site.csp;
    if (isHome) { pageCsp = site.cspHome; }
    // Reading-time chip (module var, set by the renderX() caller). Rendered as
    // a sibling ABOVE the <article> card but INSIDE its column - a chip that
    // hovers above the card, aligned with the card's left edge, not floating
    // far-left above the TOC sidebar. Passed in per call (reading), so a page that
    // wants none passes "".
    var readingHtml = "";
    if (reading != "") {
        readingHtml = "    <small class=\"reading-time\" title=\"Estimated reading time\">" + reading + "</small>\n";
    }
    // Frontmatter tags (passed in per call) render as outlined, non-interactive chips
    // in the provenance footer (there are no tag-archive pages to link to yet).
    // Generated pages (module/spell/man-page references) lead with a filled
    // "Generated" status chip so readers know the source of truth is code, not the
    // page - and that its "Suggest an edit" link points at generated output.
    final gen = isGenerated(srcRel, site);
    var tagsHtml = "";
    if (gen or tags.len() > 0) {
        var chips = "";
        if (gen) {
            chips = chips + "<span class=\"tag generated\" data-tooltip=\"Auto-generated from source; edit the generator, not this page\" title=\"Auto-generated from source; edit the generator, not this page\">auto-generated</span>";
        }
        foreach (t in tags) {
            // Topical tags are links into the search page, scoped to that exact tag
            // (tag:"<name>"), so a click lists every page carrying it. The value is
            // quoted so multi-word tags survive as one token; url_encode makes the
            // whole thing querystring-safe. The generated status chip stays a span.
            final tagQuery = encoding.urlEncode("tag:\"" + t + "\"");
            chips = chips + "<a class=\"tag\" href=\"" + root + "search/?q=" + tagQuery + "\">" + escapeAttr(t) + "</a>";
        }
        tagsHtml = "    <div class=\"post-tags\" aria-label=\"Tags\">" + chips + "</div>\n";
    }
    // Headings drive the TOC sidebar; without enough of them the article goes
    // full-width (no .with-toc grid) and toc.js simply finds nothing to enhance.
    // With TOC: wrap reading-time + article in a div so both share the article
    // grid cell (TOC in col 1, [chip + article] in col 2).
    final toc = renderToc(content);
    var contentBlock = "" + readingHtml + "    <article>\n" + content + "    </article>\n";
    if (toc != "") {
        contentBlock = "    <div class=\"with-toc\">\n" + toc
            + "    <div>\n" + readingHtml + "    <article>\n" + content + "    </article>\n    </div>\n"
            + "    </div>\n";
    }
    // Page tools: two plain links on the right of the secondary row, separated
    // by a middle-dot. "View source" only appears for pages backed by a real
    // .md on disk (synthesized pages like the blog index and /public/* have no
    // source). "Report an issue" was dropped - GitHub's edit flow is one click
    // from Issues, and readers who just want to file a bug rarely start from
    // a docs page.
    final hasSource = srcRel.endsWith(".md") and srcRel.startsWith("public/") == false
        and srcRel != site.blog + "/index.md" and srcRel != "search/index.md" and srcRel != "tour/index.md";
    var edit = "<small class=\"page-tools-edit\">";
    if (hasSource) {
        edit = edit + "<a href=\"index.md\" data-tooltip=\"View this page's Markdown source\" title=\"View this page's Markdown source\">&#182; View source</a> &middot; ";
    }
    edit = edit + "<a href=\"" + GH + "/edit/" + site.metaBranch + "/" + site.metaPrefix + srcRel + "\" data-tooltip=\"Edit this page on GitHub\" title=\"Edit this page on GitHub\">&#x270E; Suggest an edit</a></small>";
    // Second row under the search box: "Suggest an edit" hugging the right edge
    // via margin-left:auto (reading-time now lives inside the article, above). The
    // search page is a generated tool surface with no editable source, so it skips
    // the row entirely (a "Suggest an edit" link there would 404 on GitHub).
    var secondaryRow = "    <div class=\"page-tools-secondary\">" + edit + "</div>\n";
    if (srcRel == "search/index.md" or srcRel == "tour/index.md" or srcRel.startsWith("development/")) { secondaryRow = ""; }
    // Consistent "<page title> - magus" suffix everywhere. Home just says
    // "magus" (its H1-derived title is the wordmark, no need to duplicate).
    var fullTitle = title + " — magus";
    if (srcRel == "README.md") { fullTitle = "magus"; }
    // OpenGraph + Twitter Card meta so a shared link renders a title/description/
    // image card instead of a bare URL. The og:* block lives in the template, gated
    // on hasSiteUrl; here we only pick og:type ("website" for home, else "article").
    var ogType = "article";
    if (isHome) { ogType = "website"; }
    // Body class marks the meta surfaces that keep the full chrome but drop or widen
    // parts of it: /public/ file-tree pages (site.css keys .site-public to hide the
    // doc-only controls) and the search page (site-search widens the container for
    // the results listing). "" for an ordinary page.
    var bodyClass = "";
    if (srcRel.startsWith("public/")) { bodyClass = "site-public"; }
    if (srcRel == "search/index.md") { bodyClass = "site-search"; }
    // Per-page provenance strip (footer tags + "Last updated" commit line). The
    // search page is a generated tool surface with no source commit; writing it
    // would make renderCommitFooter fall back to HEAD, drifting the output every commit
    // and tripping the generate drift gate. So omit the whole strip there.
    var provenance = "  <div class=\"page-provenance container\">\n"
        + tagsHtml
        + "    " + renderCommitFooter(srcRel, site) + "\n"
        + "  </div>\n";
    if (srcRel == "search/index.md" or srcRel == "tour/index.md" or srcRel.startsWith("development/")) { provenance = ""; }
    // The page skeleton as one Mustache template. The head's optional blocks are
    // logic-less sections keyed off the view-model flags computed above
    // (hasDescription/hasSiteUrl/hasReleasesFeed/hasBlogFeed/isHome); {{value}}
    // interpolation HTML-escapes. The body's composed components (announcement, nav,
    // breadcrumb, contentBlock, related, provenance, footer) are whole rendered
    // fragments, injected raw via {{{...}}}. Inline notes that used to live here:
    //   - favicon set reuses the optimized hat mark; PNG + apple-touch cover clients.
    //   - the <noscript> explains the missing search box (no JS, no injected input).
    //   - one deferred main.js bundle; head-critical theme.js stays separate above.
    final pageTmpl = `<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="generator" content="magus">
  <meta http-equiv="Content-Security-Policy" content="{{{csp}}}">
  <title>{{fullTitle}}</title>
{{#hasDescription}}
  <meta name="description" content="{{description}}">
{{/hasDescription}}
{{#hasSiteUrl}}
  <link rel="canonical" href="{{siteUrl}}{{canonUrl}}">
  <meta property="og:type" content="{{ogType}}">
  <meta property="og:site_name" content="magus">
  <meta property="og:title" content="{{fullTitle}}">
{{#hasDescription}}
  <meta property="og:description" content="{{description}}">
{{/hasDescription}}
  <meta property="og:url" content="{{siteUrl}}{{canonUrl}}">
  <meta property="og:image" content="{{siteUrl}}assets/gopher.png">
  <meta name="twitter:card" content="summary_large_image">
{{/hasSiteUrl}}
{{#hasReleasesFeed}}
  <link rel="alternate" type="application/atom+xml" title="magus releases" href="{{root}}public/atom/releases.atom.xml">
{{/hasReleasesFeed}}
{{#hasBlogFeed}}
  <link rel="alternate" type="application/atom+xml" title="magus blog" href="{{root}}public/atom/blog.atom.xml">
{{/hasBlogFeed}}
{{#isHome}}
  <link rel="preload" as="image" href="{{root}}assets/gopher.webp" type="image/webp" fetchpriority="high">
{{/isHome}}
  <link rel="icon" type="image/png" sizes="32x32" href="{{root}}assets/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="{{root}}assets/apple-touch-icon.png">
  <link rel="manifest" href="{{root}}manifest.webmanifest">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#13171f">
  <link rel="stylesheet" href="{{root}}assets/pico.min.css">
  <link rel="stylesheet" href="{{root}}theme.css">
  <link rel="stylesheet" href="{{root}}site.css">
  <!-- ui-panels.css: the shared settings gear + reference drawer. The docs corpus loads this and
       NOT console.css (that is the console-app-only shell). -->
  <link rel="stylesheet" href="{{root}}ui-panels.css">
  <script src="{{root}}theme.js"></script>
</head>
<body{{#bodyClass}} class="{{bodyClass}}"{{/bodyClass}}>
  <a class="skip-link" href="#main-content">Skip to content</a>
{{{announcement}}}{{{nav}}}  <main id="main-content" class="container" tabindex="-1">
{{{breadcrumb}}}    <div class="page-tools"></div>
    <noscript><p class="noscript-notice">Search needs JavaScript. Browse the <a href="{{root}}documentation/">documentation</a>, or use GitHub's code search on the <a href="{{gh}}">source repo</a>.</p></noscript>
{{{secondaryRow}}}{{{contentBlock}}}{{{pager}}}  </main>
{{{related}}}{{{provenance}}}{{{refdrawer}}}{{{footer}}}  <script type="module" src="{{root}}main.js"></script>
</body>
</html>
`;
    return template.render(pageTmpl, {
        "fullTitle": fullTitle,
        "csp": pageCsp,
        "description": description,
        "hasDescription": hasDescription,
        "hasSiteUrl": hasSiteUrl,
        "siteUrl": SITE_URL,
        "canonUrl": canonUrl,
        "ogType": ogType,
        "hasReleasesFeed": hasReleasesFeed,
        "hasBlogFeed": hasBlogFeed,
        "isHome": isHome,
        "bodyClass": bodyClass,
        "root": root,
        "gh": GH,
        "announcement": renderAnnouncementBar(site),
        "nav": renderSiteNav(root, active, true),
        "breadcrumb": site.renderBreadcrumb(srcRel, title, root),
        "secondaryRow": secondaryRow,
        "contentBlock": contentBlock,
        "pager": pager,
        "related": site.renderRelated(srcRel, root),
        "provenance": provenance,
        "refdrawer": renderReferenceDrawer(root, site),
        "footer": renderSiteFooter(root, site),
    });
}

// Render the repo's top-level README.md as the site landing page (index.html).
// Links of the form href="docs/X" (relative from the repo root) resolve from
// gen/index.html as href="X" — strip the docs/ prefix.
fun renderRoot(site: Site) > void {
    final f = io.File.open(site.root + "/README.md", io.FileMode.read);
    final rawMd = f.readAll();
    f.close();

    // The committed README carries no frontmatter (GitHub renders a leading YAML
    // block as an ugly metadata table on the repo landing page), so a minimal
    // frontmatter is synthesized here, in memory, before the README is used for
    // anything else. Title and description are deliberately left out: they
    // already derive correctly from the content below (the H1, then the first
    // real paragraph), so only the search/tag classification - which has no
    // content to derive from - needs a value. Kept to one basic tag by design.
    final md = "---\ntags: [readme]\n---\n\n" + rawMd;

    var html = markdown.toHtml(md);
    while (html.indexOf("href=\"./docs/") != null) {
        html = html.replace("href=\"./docs/", "href=\"");
    }
    while (html.indexOf("href=\"docs/") != null) {
        html = html.replace("href=\"docs/", "href=\"");
    }
    // The home page stays at gen/index.html (gen root), so its in-content links are
    // rewritten from the root directory to the root directory.
    html = renderContentHTML(html, "", "");

    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    var title = fm.q("title").stringValue();
    if (title == "") { title = deriveTitle(md, "README.md"); }
    // Resolve the description: authored frontmatter, else the first real paragraph,
    // else the site default — always non-empty so the meta tag always fires.
    var desc = fm.q("description").stringValue();
    if (desc == "") { desc = deriveDescription(html); }
    if (desc == "") { desc = SITE_DESC; }

    final doc = renderPage(title, desc, html, "README.md", "", "", readingTime(md), parseTags(md), site);
    final of = io.File.open(site.outDir + "/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    // The "View source" link targets this file directly - write the original,
    // unamended README so it matches the committed source byte for byte (the
    // synthesized tags frontmatter above is a build-time-only detail).
    fs.writeFile(site.outDir + "/index.md", rawMd);
    site.addRecord("index.html", title, desc, md);
    foreach (a in fm.q("aliases").listValue()) { site.collectAlias(a.stringValue(), "index.html"); }
    std.print("  README.md -> " + site.outDir + "/index.html");
}

// Render one docs/*.md file to a sibling *.html under gen. rel is relative to the
// docs/ subtree; srcRel (site.docs/rel) is magus/-relative for the footer/edit link.
fun renderFile(rel: str, site: Site) > void {
    final f = io.File.open(site.root + "/" + site.docs + "/" + rel, io.FileMode.read);
    final md = f.readAll();
    f.close();

    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    var title = fm.q("title").stringValue();
    if (title == "") { title = deriveTitle(md, rel); }

    final html = renderContentHTML(markdown.toHtml(md), oldFlatDirectory(rel), newCleanDirectory(rel, site));

    // Resolve the description: authored frontmatter, else the first real paragraph,
    // else the site default — always non-empty so the meta tag always fires.
    var desc = fm.q("description").stringValue();
    if (desc == "") { desc = deriveDescription(html); }
    if (desc == "") { desc = SITE_DESC; }

    final url = cleanURL(rel, site.blog);
    final doc = renderPage(title, desc, html, site.docs + "/" + rel, renderPager(rel, site), url, readingTime(md), parseTags(md), site);

    // Directory-index output: every page is <cleanURL>index.html (extensionless,
    // with the build-artifact "gen" segment flattened out). url is gen/-root-
    // relative and ends in a slash, matching what search.js/sitemap/canonical use.
    final dir = site.outDir + "/" + url.sub(0, url.len() - 1);   // drop trailing slash for mkdir
    fs.makeDirectory(dir);

    final of = io.File.open(dir + "/index.html", io.FileMode.write);
    of.write(doc);
    of.close();

    // Emit the page's source Markdown next to its HTML so a reader can "View
    // source" (or copy-as-markdown) directly. Powers llms-full.txt too - a
    // committed .md-per-page is the single input that later WS T slices reuse.
    fs.writeFile(dir + "/index.md", md);

    site.addRecord(url, title, desc, md);
    // Redirect stubs for any old paths this page declares (frontmatter aliases:).
    foreach (a in fm.q("aliases").listValue()) { site.collectAlias(a.stringValue(), url); }

    std.print("  " + rel + " -> " + dir + "/index.html");
}


// renderBlogPost renders one blog/<file>.md as its own directory-index page. base
// is the file's basename (e.g. "2026-07-01-hello-blog.md"); the written URL is date-
// scoped, blog/<YYYY>/<MM>/<DD>/<slug>/ (via blogURLPath, from the filename's date
// prefix), so permalinks sort by date and never collide across years. Post metadata
// (title/date/description) is captured into site.blogPosts for the index page (and,
// later, the Atom feed).
fun renderBlogPost(base: str, site: Site) > void {
    final rel = site.blog + "/" + base;
    final f = io.File.open(site.root + "/" + rel, io.FileMode.read);
    final md = f.readAll();
    f.close();

    final fm = serialize.jsonDecode(markdown.frontmatter(md));
    var title = fm.q("title").stringValue();
    if (title == "") { title = deriveTitle(md, base); }
    final date = fm.q("date").stringValue();

    // Frontmatter `date` is the human-facing byline; the filename's YYYY-MM-DD-
    // prefix is the canonical URL scope. Require them to agree so the permalink and
    // the printed date can never drift. A post with a date but no filename prefix
    // (or a mismatched one) is a hard error, not a silent divergence.
    final dateDir = blogDateDirectory(base);
    if (date != "") {
        // Frontmatter dates decode as full RFC3339 ("2026-07-01T00:00:00Z"); take
        // the calendar day and re-slash it to compare against the filename's
        // "YYYY/MM/DD" scope. (str.replace is first-match only, so build by split.)
        final fp = date.split("T")[0].split("-");   // ["2026","07","01"]
        var fmDir = "";
        if (fp.len() >= 3) { fmDir = fp[0] + "/" + fp[1] + "/" + fp[2]; }
        if (dateDir == null) {
            throw "blog: " + rel + " has frontmatter date " + date
                + " but the filename lacks a matching YYYY-MM-DD- prefix";
        }
        if (dateDir != fmDir) {
            throw "blog: " + rel + " frontmatter date " + date
                + " disagrees with the filename date prefix";
        }
    }

    final slug = blogSlug(base);
    final urlPath = blogURLPath(base);        // "2026/07/01/hello-blog"
    final url = site.blog + "/" + urlPath + "/";
    // Blog posts sit at gen/blog/<urlPath>/index.html. Their old flat directory was
    // "blog"; their new clean directory is "blog/<urlPath>" (date-scoped). The link
    // rewriter needs both so cross-references (../../documentation/) resolve at the
    // post's real depth.
    final html = renderContentHTML(markdown.toHtml(md), site.blog, site.blog + "/" + urlPath);

    var desc = fm.q("description").stringValue();
    if (desc == "") { desc = deriveDescription(html); }
    if (desc == "") { desc = SITE_DESC; }

    // Dateline: a scoped byline injected directly under the post's H1 - publish
    // date (calendar day; see blogDate), author, and a permalink to the post's
    // own canonical URL. Sitting inside the <article> right after the title, it
    // reads as the post's metadata rather than free-floating page chrome. Guarded
    // on there being an H1 and a date; a title-less or undated post just skips it.
    var article = html;
    final h1End = html.indexOf("</h1>");
    if (h1End != null and date != "") {
        final author = fm.q("author").stringValue();
        var meta = "<p class=\"blog-post-meta\"><time datetime=\"" + blogDateAttr(date)
            + "\">" + blogDate(date) + "</time>";
        if (author != "") { meta = meta + " &middot; " + author; }
        meta = meta + " &middot; <a href=\"" + SITE_URL + url + "\" rel=\"bookmark\">Permalink</a></p>\n";
        final cut = h1End + 5;   // length of "</h1>"
        article = html.sub(0, cut) + "\n" + meta + html.sub(cut);
    }

    // Reverse-chronological pager: blog posts pair prev/next by date, not filename.
    final pager = renderBlogPager(base, site);

    final doc = renderPage(title, desc, article, rel, pager, url, readingTime(md), parseTags(md), site);
    fs.makeDirectory(site.outDir + "/" + site.blog + "/" + urlPath);
    final of = io.File.open(site.outDir + "/" + site.blog + "/" + urlPath + "/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    fs.writeFile(site.outDir + "/" + site.blog + "/" + urlPath + "/index.md", md);

    site.addRecord(url, title, desc, md);
    foreach (a in fm.q("aliases").listValue()) { site.collectAlias(a.stringValue(), url); }

    site.blogPosts.append(BlogPost{
        base = base, slug = slug, urlPath = urlPath, title = title,
        date = date, description = desc, url = url,
    });

    std.print("  " + rel + " -> " + site.outDir + "/" + site.blog + "/" + urlPath + "/index.html");
}

// renderBlogPager renders the previous/next links between posts, ordered by date
// (newest to oldest so "next" is older and "prev" is newer, matching timeline
// intuition). Falls back to filename order when a post lacks a date. Reuses
// renderPagerLink's climb-relative sibling link form.
fun renderBlogPager(base: str, site: Site) > str {
    // Rebuild the ordering deterministically from disk (site.blogPosts may be partial
    // during the walk). Newest first.
    var posts: [BlogPost] = mut [<BlogPost>];
    foreach (name in fs.list(site.root + "/" + site.blog)) {
        if (name.endsWith(".md") and name != "index.md" and name.startsWith("_") == false) {
            final f = io.File.open(site.root + "/" + site.blog + "/" + name, io.FileMode.read);
            final md = f.readAll();
            f.close();
            final fm = serialize.jsonDecode(markdown.frontmatter(md));
            var t = fm.q("title").stringValue();
            if (t == "") { t = deriveTitle(md, name); }
            posts.append(BlogPost{ base = name, date = fm.q("date").stringValue(), title = t });
        }
    }
    if (posts.len() < 2) { return ""; }
    // Sort by date DESC, tiebreak by filename ASC so ordering is stable when two
    // posts share a date.
    final ordered = posts.sort(fun (a: BlogPost, b: BlogPost) > bool {
        if (a.date != b.date) { return strLess(b.date, a.date); }
        return strLess(a.base, b.base);
    });

    var pos = -1;
    var i = 0;
    while (i < ordered.len()) {
        if (ordered[i].base == base) { pos = i; }
        i = i + 1;
    }
    if (pos < 0) { return ""; }

    // Posts are date-scoped (blog/YYYY/MM/DD/slug/), so a sibling link is no longer
    // a flat "../<slug>/"; relativePath walks from this post's dir to the target's URL
    // and writes the minimal climb, correct across any shared date prefix.
    final fromDir = site.blog + "/" + blogURLPath(base);
    var body = "";
    // Previous = newer post (earlier in ordered), Next = older post (later).
    if (pos > 0) {
        final prev = ordered[pos - 1];
        final href = relativePath(fromDir, site.blog + "/" + blogURLPath(prev.base) + "/");
        body = body + "      <a class=\"page-nav-prev\" href=\"" + href + "\">"
            + "<span class=\"page-nav-dir\">Newer</span>"
            + "<span class=\"page-nav-title\">" + prev.title + "</span></a>\n";
    }
    if (pos < ordered.len() - 1) {
        final nxt = ordered[pos + 1];
        final href = relativePath(fromDir, site.blog + "/" + blogURLPath(nxt.base) + "/");
        body = body + "      <a class=\"page-nav-next\" href=\"" + href + "\">"
            + "<span class=\"page-nav-dir\">Older</span>"
            + "<span class=\"page-nav-title\">" + nxt.title + "</span></a>\n";
    }
    if (body == "") { return ""; }
    return "    <nav class=\"page-nav\" aria-label=\"Pagination\">\n" + body + "    </nav>\n";
}

// renderBlogIndex writes gen/blog/index.html, a reverse-chronological list of the
// collected blog posts. It runs AFTER renderBlogPost has populated site.blogPosts for
// every post in the walk. The listing is a plain <ul> under the shared renderPage()
// template, so it inherits nav/breadcrumb/footer for free.
fun renderBlogIndex(site: Site) > void {
    // Newest first, tiebreak by base for determinism.
    final sorted = site.blogPosts.sort(fun (a: BlogPost, b: BlogPost) > bool {
        if (a.date != b.date) { return strLess(b.date, a.date); }
        return strLess(a.base, b.base);
    });

    // View-model per post; date/description are optional (gated by hasDate/hasDesc).
    var posts: [{str: any}] = mut [<{str: any}>];
    foreach (p in sorted) {
        final rec = mut {<str: any>};
        rec["urlPath"] = p.urlPath;
        rec["title"] = p.title;
        rec["hasDate"] = p.date != "";
        if (p.date != "") {
            rec["dateAttr"] = blogDateAttr(p.date);
            rec["dateDisplay"] = blogDate(p.date);
        }
        rec["hasDesc"] = p.description != "";
        rec["description"] = p.description;
        posts.append(rec);
    }
    final body = template.render(`<h1>Blog</h1>
{{#hasPosts}}
<ul class="blog-index">
{{#posts}}
  <li><a href="{{urlPath}}/"><span class="blog-index-title">{{title}}</span></a>{{#hasDate}} <time class="blog-index-date" datetime="{{dateAttr}}">{{dateDisplay}}</time>{{/hasDate}}{{#hasDesc}}<p class="blog-index-desc">{{description}}</p>{{/hasDesc}}</li>
{{/posts}}
</ul>
{{/hasPosts}}
{{^hasPosts}}
<p>No posts yet.</p>
{{/hasPosts}}
`, {"hasPosts": sorted.len() > 0, "posts": posts});

    final title = "Blog";
    final desc = "The magus blog. Release notes, deep dives, and behind-the-scenes writeups.";
    final url = site.blog + "/";
    // srcRel for the index page: a blog/index.md marker so renderPage() picks the "blog"
    // active-nav key and the breadcrumb roots correctly, even though there is no
    // source file. Alias the marker's commit-footer key to the newest post's own
    // commit so the "Last updated" line is a stable snapshot instead of tracking
    // HEAD (which would drift every commit and break the drift gate).
    if (sorted.len() > 0) {
        final rec = site.metaCommits[site.metaPrefix + site.blog + "/" + sorted[0].base];
        if (rec != null) { site.metaCommits[site.metaPrefix + site.blog + "/index.md"] = rec; }
    }
    final doc = renderPage(title, desc, body, site.blog + "/index.md", "", url, "", mut [], site);
    fs.makeDirectory(site.outDir + "/" + site.blog);
    final of = io.File.open(site.outDir + "/" + site.blog + "/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    // The index is a real page, so it belongs in the search index and sitemap.
    // No frontmatter tags/description — the resolved desc above rides through.
    site.pageUrls[url] = true;
    // Build a fake mini record so addRecord's shape stays consistent.
    final recStub = "---\ntitle: " + title + "\ndescription: " + desc + "\ntags: []\n---\nBlog listing.\n";
    site.addRecord(url, title, desc, recStub);
    std.print("  blog index -> " + site.outDir + "/" + site.blog + "/index.html");
}

// renderSearchPage writes gen/search/index.html: the dedicated, deep-linkable search
// surface. It is a tool page (no markdown source; kept out of the search index and
// sitemap, and out of the provenance/edit chrome via the srcRel guards in renderPage()).
// The #search-page container is the signal search.js keys off to switch from the
// header dropdown to full-page, URL-synced (?q=) results. Emitted after the walk so
// it is a peer of renderPublic()/render404().
// renderSyntaxRow renders one Search Syntax entry: a clickable example that runs itself
// (search.js intercepts the ?q= link) beside a plain-language description. The query
// is url-encoded for the href and entity-escaped for its <code> display.
fun renderSyntaxRow(q: str, desc: str) > str {
    return template.render(`        <dt><a class="syntax-example" href="?q={{qEnc}}"><code>{{q}}</code></a></dt><dd>{{desc}}</dd>
`, {"qEnc": encoding.urlEncode(q), "q": q, "desc": desc});
}

fun renderSearchPage(site: Site) > void {
    final root = rootPrefix("search/index.md", site);
    // Always-open, forefront syntax reference: on the dedicated page the query
    // language is a first-class part of the surface, not a disclosure to hunt for
    // (the header dropdown carries only a compact hint). Each example is a real ?q=
    // link, so it works without JS and doubles as teach-by-doing once search.js runs
    // it in place.
    // The query examples as a view-model of pre-rendered <dt>/<dd> rows (renderSyntaxRow
    // does the urlEncode); the template arranges the two-column layout. Results come
    // first in the DOM so a narrow-screen collapse stacks them above the reference.
    final rows = renderSyntaxRow("tag:build", "Pages carrying the exact tag \"build\".")
        + renderSyntaxRow("-tag:spell", "Exclude pages with a tag.")
        + renderSyntaxRow("tag:\"remote cache\"", "Quote values that contain spaces.")
        + renderSyntaxRow("title:install", "Scope a term to one field: title, description, or text.")
        + renderSyntaxRow("\"exact phrase\"", "Match words that appear together, in order.")
        + renderSyntaxRow("cache -go", "Require a word; drop another with a leading minus.")
        + renderSyntaxRow("tag:cache OR tag:build", "OR matches either; terms are ANDed by default.")
        + renderSyntaxRow("tag:(cache OR build)", "Group several values for one field.")
        + renderSyntaxRow("title:mag*", "Wildcards: * stands for any run of characters.")
        + renderSyntaxRow("(tag:a OR tag:b) -tag:c", "Parenthesize to group; combine with exclusion.");
    final body = template.render(`<h1>Search</h1>
<div id="search-page">
  <div class="search-page-inputwrap">
    <input id="search-page-input" class="search-input" type="text" placeholder="Search docs... (try tag:cache)" autocomplete="off" spellcheck="false" aria-label="Search the documentation" aria-controls="search-page-results">
    <ul id="search-facets" class="search-facets" role="listbox" aria-label="Tag suggestions" hidden></ul>
  </div>
  <div id="search-chips" class="search-chips" aria-hidden="true" hidden></div>
  <div class="search-layout">
    <div class="search-main">
      <p id="search-page-status" class="search-page-status" role="status" aria-live="polite"></p>
      <ul id="search-page-results" class="search-page-results"></ul>
    </div>
    <aside class="search-side">
  <section class="search-syntax" aria-label="Search syntax">
    <p class="search-syntax-title">Search Syntax</p>
    <p class="search-syntax-lead">Terms are combined with AND and matched case-insensitively. Click an example to run it.</p>
    <dl>
{{{rows}}}    </dl>
  </section>
    </aside>
  </div>
  <noscript><p class="noscript-notice">Search needs JavaScript. Browse the <a href="{{root}}documentation/">documentation</a>, or use GitHub's code search on the <a href="{{gh}}">source repo</a>.</p></noscript>
</div>
`, {"root": root, "gh": GH, "rows": rows});
    final title = "Search";
    final desc = "Search the magus documentation. Filter by tag with tag:name, exclude terms with -term, and match exact phrases with quotes.";
    final doc = renderPage(title, desc, body, "search/index.md", "", "search/", "", mut [], site);
    fs.makeDirectory(site.outDir + "/search");
    final of = io.File.open(site.outDir + "/search/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    std.print("  search page -> " + site.outDir + "/search/index.html");
}

// codeTeaser pulls a short code preview from a tour example: skip the leading comment
// block and blank lines, then take the first several real lines. Gives each card a
// code snippet at a glance instead of the descriptive header comment.
fun codeTeaser(src: str) > str {
    var started = false;
    final kept: [str] = mut [<str>];
    foreach (line in src.split("\n")) {
        if (started == false) {
            final t = line.trim();
            if (t == "" or t.startsWith("//")) { continue; }
            started = true;
        }
        if (kept.len() >= 7) { break; }
        kept.append(line);
    }
    return kept.join("\n");
}

// tourSrc reads one curated example from the tour/ dir (cwd-relative; build-time only,
// the files are not written - their content rides into the page as teaser + deep-link).
fun tourSrc(file: str) > str {
    final f = io.File.open("tour/" + file, io.FileMode.read);
    final s = f.readAll();
    f.close();
    return s;
}

// playgroundLink deep-links src into the playground editor. The raw source is url-safe
// base64 (unpadded, matching src/site/run-example.ts and the wasm's applyHashSource decoder)
// in the #source= fragment, so the code stays client-side (never hits the server/CDN).
fun playgroundLink(root: str, src: str) > str {
    var enc = encoding.base64urlEncode(src);
    while (enc.endsWith("=")) { enc = enc.sub(0, enc.len() - 1); }
    return root + "playground/#source=" + enc;
}

// TourStep is one tour card: the .buzz example file, its copy, and a cross-link to
// the concept doc a newcomer should read next (docSlug is the clean-URL directory,
// e.g. "targets"). It renders its own numbered card - the first of scribe's typed
// value objects, putting presentation on the data it presents instead of a
// stringly-typed {str: str} map juggled by the caller.
object TourStep {
    file: str = "",
    title: str = "",
    desc: str = "",
    docLabel: str = "",
    docSlug: str = "",

    // card renders this step's numbered <li>: the code teaser, an Open-in-Playground
    // deep link, and the concept cross-link, all resolved against root.
    fun renderCard(root: str, num: int) > str {
        final src = tourSrc(this.file);
        // The concept cross-link rides at the end of the description as an inline
        // link, not a separate "Read up:" line under the footer.
        return template.render(`      <li class="tour-card">
        <div class="tour-head"><span class="tour-num">{{num}}</span><h3>{{title}}</h3></div>
        <p class="tour-desc">{{desc}} <a class="tour-learn" href="{{root}}{{docSlug}}/">{{docLabel}} <span class="xref-arrow" aria-hidden="true">&rarr;</span></a></p>
        <pre class="tour-teaser"><code class="language-buzz">{{teaser}}</code></pre>
        <div class="tour-foot">
          <a class="open-in-playground" href="{{playLink}}" target="_blank" rel="noopener" title="Open this snippet in the playground (new tab)" data-tooltip="Open in playground">Open in Playground <span class="oip-arrow" aria-hidden="true">&#x2197;</span></a>
        </div>
      </li>
`, {"num": num, "title": this.title, "desc": this.desc, "root": root, "docSlug": this.docSlug, "docLabel": this.docLabel, "teaser": codeTeaser(src), "playLink": playgroundLink(root, src)});
    }
}

// renderTourPage writes gen/tour/index.html: a numbered card grid that walks a newcomer
// through magusfiles and Buzz. Each card carries a step number, title, one-liner, a code
// teaser, and an Open-in-Playground deep-link. A synthesized page like the search page -
// no .md source - so renderPage()'s srcRel guards drop its provenance/edit chrome.
fun renderTourPage(site: Site) > void {
    final root = rootPrefix("tour/index.md", site);
    final steps: [TourStep] = mut [<TourStep>];
    steps.append(TourStep{ file = "01-hello.buzz", title = "Magusfiles: write your first target",
        desc = "A magusfile is a build definition; each exported function is a runnable target.",
        docLabel = "Targets", docSlug = "targets" });
    steps.append(TourStep{ file = "02-targets.buzz", title = "Targets: wire the dependencies",
        desc = "Wire a pipeline with magus.needs; ci is the conventional anchor it all keys off.",
        docLabel = "Targets", docSlug = "targets" });
    steps.append(TourStep{ file = "03-spells.buzz", title = "Spells: bind a real toolchain",
        desc = "Bind a real toolchain (Go, TypeScript, Docker) as cached, kebab-case ops.",
        docLabel = "Spells", docSlug = "spells" });
    steps.append(TourStep{ file = "04-buzz.buzz", title = "Buzz: branch, loop, recurse",
        desc = "Variables, functions, recursion, closures - evaluated live in your browser.",
        docLabel = "Engines", docSlug = "engines" });
    steps.append(TourStep{ file = "05-slots.buzz", title = "Slots: taming a greedy target",
        desc = "A target starts with one slot; reserve more so a parallel tool cannot starve the rest.",
        docLabel = "Operations", docSlug = "operations" });
    steps.append(TourStep{ file = "06-cache.buzz", title = "Cache: replay, and catch drift",
        desc = "Targets replay from cache and run once per plan; skip_cache opts a check out.",
        docLabel = "Caching", docSlug = "remote-cache" });
    steps.append(TourStep{ file = "07-globs.buzz", title = "Globs: gather a target family",
        desc = "Name targets by a shared suffix and gather them with one glob; regex for the rest.",
        docLabel = "Targets", docSlug = "targets" });
    steps.append(TourStep{ file = "08-charms.buzz", title = "Charms: check, then apply",
        desc = "A charm rides down the plan; the built-in rw flips read-only checks to rewrites.",
        docLabel = "Charms", docSlug = "charms" });
    steps.append(TourStep{ file = "09-services.buzz", title = "Services: share one across runs",
        desc = "Author a spell whose op returns a Service; magus supervises one, shared across runs.",
        docLabel = "Services", docSlug = "services" });
    steps.append(TourStep{ file = "10-wards.buzz", title = "Wards: catch the contradiction",
        desc = "A detached service trips MGS5002 at resolution, before anything forks.",
        docLabel = "Wards", docSlug = "wards" });
    steps.append(TourStep{ file = "11-workspace.buzz", title = "Workspaces: run only what changed",
        desc = "Projects wire cross-project order with depends_on; affected runs only what changed.",
        docLabel = "CI and affected", docSlug = "targets/ci" });
    steps.append(TourStep{ file = "12-magusfile.buzz", title = "Pipelines: assemble the whole build",
        desc = "The full multi-toolchain pipeline: generate, format, lint, build, test, release.",
        docLabel = "CI", docSlug = "targets/ci" });
    steps.append(TourStep{ file = "13-custom-targets.buzz", title = "Custom targets: name your own phases",
        desc = "The canonical names are conventions, not a closed set; export a release or deploy target and drive one from another.",
        docLabel = "Targets", docSlug = "targets" });
    steps.append(TourStep{ file = "14-stdlib.buzz", title = "Standard library: batteries included",
        desc = "Buzz ships host modules - string casing, semver math, JSON, hashing - you import and call straight from a target.",
        docLabel = "Buzz modules", docSlug = "buzz/modules" });
    steps.append(TourStep{ file = "15-charms-custom.buzz", title = "Custom charms: patch the argv",
        desc = "Declare your own charm as a JSON Patch over a spell op's argv; run op:charm to watch the flag splice in.",
        docLabel = "Charms", docSlug = "charms" });

    var cards = "";
    var n = 1;
    foreach (step in steps) {
        cards = cards + step.renderCard(root, n);
        n = n + 1;
    }

    final body = template.render(`<h1>Tour</h1>
<p class="lede">A guided walk through magusfiles and Buzz, step by step. Open any example in the Playground to run and edit it.</p>
    <ol class="tour-grid">
{{{cards}}}    </ol>
`, {"cards": cards});
    final title = "Tour";
    final desc = "A guided tour of magus: curated, runnable examples from a hello-world magusfile through a full multi-toolchain pipeline, custom targets, and the Buzz standard library.";
    final doc = renderPage(title, desc, body, "tour/index.md", "", "tour/", "", mut [], site);
    fs.makeDirectory(site.outDir + "/tour");
    final of = io.File.open(site.outDir + "/tour/index.html", io.FileMode.write);
    of.write(doc);
    of.close();
    // addRecord uses the desc arg directly and only parses this stub for tags, so the
    // stub carries just a valid tags list (a description: line with colons would break
    // the YAML). The body text seeds a few search terms for the page.
    site.addRecord("tour/", title, desc,
        "---\ntags: [tour, getting started, examples, playground, hello world]\n---\nGuided tour of magus. Hello world, targets, spells, the Buzz language, and a full magusfile.\n");
    std.print("  tour page -> " + site.outDir + "/tour/index.html");
}

// walkBlog visits every blog/*.md post file (excluding index.md and _underscored
// fixtures), in fs.list's sorted order — so the walk is deterministic. Posts are
// flat: no nested subdirectories under blog/.
fun walkBlog(site: Site) > void {
    if (isDirectory(site.root + "/" + site.blog) == false) { return; }
    foreach (name in fs.list(site.root + "/" + site.blog)) {
        if (name.endsWith(".md") and name != "index.md" and name.startsWith("_") == false) {
            renderBlogPost(name, site);
        }
    }
    renderBlogIndex(site);
}

// True if path is a directory.
fun isDirectory(path: str) > bool {
    return os.execute(["test", "-d", path]) == 0;
}

// Recursively walk ../docs (the output lives outside it, under gen).
fun walk(rel: str, site: Site) > void {
    var dir = site.root + "/" + site.docs;
    if (rel != "") { dir = site.root + "/" + site.docs + "/" + rel; }

    foreach (name in fs.list(dir)) {
        var childRel = name;
        if (rel != "") { childRel = rel + "/" + name; }

        if (isDirectory(site.root + "/" + site.docs + "/" + childRel)) {
            walk(childRel, site);
        } else {
            if (name.endsWith(".md")) { renderFile(childRel, site); }
        }
    }
}

// renderDevelopmentPage renders one /development/ page from markdown through the shared
// renderPage() pipeline (nav, TOC, theme, search index), skipping the doc-only chrome
// renderPage() already strips for this srcRel prefix (provenance, edit link, nav
// highlight). url ends in "/"; srcRel uses the "<dir>/_index.md" marker convention
// so rootPrefix/renderBreadcrumb derive the right depth and trail.
fun renderDevelopmentPage(title: str, desc: str, md: str, url: str, srcRel: str, site: Site) > void {
    final html = renderContentHTML(markdown.toHtml(md), "", "");
    final doc = renderPage(title, desc, html, srcRel, "", url, "", mut [], site);
    final dir = site.outDir + "/" + url.sub(0, url.len() - 1);
    fs.makeDirectory(dir);
    fs.writeFile(dir + "/index.html", doc);
    site.addRecord(url, title, desc, md);
    site.pageUrls[url] = true;
}

// renderDevelopmentPageRaw is renderDevelopmentPage for pages whose body is already final HTML
// (the /development/ landing and projects index, built by hand). It skips
// renderContentHTML - the markdown/link-rewrite pipeline that strips the trailing
// slash off relative links - so card hrefs like "magus/" stay slash-terminated and
// resolve without a directory redirect. searchText is the plain text indexed for
// search (the HTML carries no useful prose otherwise).
fun renderDevelopmentPageRaw(title: str, desc: str, html: str, searchText: str, url: str, srcRel: str, site: Site) > void {
    final doc = renderPage(title, desc, html, srcRel, "", url, "", mut [], site);
    final dir = site.outDir + "/" + url.sub(0, url.len() - 1);
    fs.makeDirectory(dir);
    fs.writeFile(dir + "/index.html", doc);
    site.addRecord(url, title, desc, searchText);
    site.pageUrls[url] = true;
}

// renderDevelopment writes the /development/ contributor section: one themed page per
// project rendering that project's committed MAGUS.md (the target catalog + run-order
// graph md_generate produces), plus a /development/ landing that links straight to
// them. There is no separate projects index; the retired /development/projects/ URLs
// redirect to their flattened locations. Projects are discovered as site.root plus any immediate subdir
// carrying a MAGUS.md; fs.list is sorted, so the set and its ordering are byte-stable
// for the drift gate. The MAGUS.md files stay committed (they serve the offline and
// agent read paths); this renders the same source for the online reader, where the
// Mermaid graphs and theming beat a raw file view.
fun renderDevelopment(site: Site) > void {
    var projects: [{str: str}] = mut [<{str: str}>];
    if (os.execute(["test", "-f", site.root + "/MAGUS.md"]) == 0) {
        projects.append(mut {"name": "magus", "path": site.root + "/MAGUS.md"});
    }
    foreach (name in fs.list(site.root)) {
        if (name.startsWith(".") == false and isDirectory(site.root + "/" + name)) {
            if (os.execute(["test", "-f", site.root + "/" + name + "/MAGUS.md"]) == 0) {
                projects.append(mut {"name": name, "path": site.root + "/" + name + "/MAGUS.md"});
            }
        }
    }
    if (projects.len() == 0) { return; }

    foreach (proj in projects) {
        final f = io.File.open(proj["path"], io.FileMode.read);
        final md = f.readAll();
        f.close();
        final name = proj["name"];
        renderDevelopmentPage(name + " targets",
            "Target catalog and run-order graph for the " + name + " project, generated from its magusfile.",
            md, "development/" + name + "/", "development/" + name + "/_index.md", site);
        // The old nested URL redirects to the flattened one so inbound links survive.
        site.collectAlias("development/projects/" + name, "development/" + name + "/");
    }

    // Project cards (reusing the Related card look), one per magus project. Built as
    // raw HTML with slash-terminated hrefs so each card links straight to the project
    // page. They sit directly on the /development/ landing now; the old projects index
    // is gone and its URL redirects here.
    var projectCards = "";
    foreach (proj in projects) {
        final name = proj["name"];
        projectCards = projectCards
            + "        <a class=\"related-card\" href=\"" + name + "/\">"
            + "<span class=\"related-card-title\">" + escapeAttr(name) + "</span>"
            + "<span class=\"related-card-desc\">target catalog and dependency graph</span></a>\n";
    }
    site.collectAlias("development/projects", "development/");

    // CONTRIBUTING.md (repo root) rendered as its own page under /development/.
    var haveContributing = false;
    if (os.execute(["test", "-f", site.root + "/CONTRIBUTING.md"]) == 0) {
        final cf = io.File.open(site.root + "/CONTRIBUTING.md", io.FileMode.read);
        final contributingMd = cf.readAll();
        cf.close();
        renderDevelopmentPage("Contributing",
            "How to build, test, and contribute to magus: the performance-evidence rule, the docs-site flow, and one-person-project etiquette.",
            contributingMd, "development/contributing/", "development/contributing/_index.md", site);
        haveContributing = true;
    }

    // Contributing is a plain prose section (a heading and a sentence linking to its
    // page), not a card - only the per-project graphs keep the card grid below.
    var contributingSection = "";
    if (haveContributing) {
        contributingSection = "<h2 id=\"contributing\">Contributing</h2>\n"
            + "<p>The <a href=\"contributing/\">Contributing guide</a> covers the conventions worth knowing before you open a pull request: run the suite with <code>magus run ci</code>, back any performance change with benchmark evidence, and regenerate the docs site (<code>magus run generate:rw website</code>) so the committed <code>gen/</code> tree never drifts from its source.</p>\n";
    }
    // Development is the contributor landing page the root README points at as the "full
    // contributor reference", so it carries the orientation a newcomer to the codebase
    // needs: the dogfooding framing, a build/test quickstart, the contributing rules, the
    // per-project graphs, and a jumping-off list to the deeper reference docs. Built as
    // raw HTML (renderDevelopmentPageRaw skips the markdown pipeline) so the card hrefs keep their
    // trailing slash; the language-sh code block is picked up by the client highlighter.
    final devHtml = template.render(`<h1 id="development">Development</h1>
<p>Reference for people working <em>on</em> magus rather than building with it. magus is built and tested by magus: this repository is itself a magus workspace, so the targets, spells, caching, and wards documented for your projects run this one too.</p>
<h2 id="getting-started">Getting started</h2>
<p>Building the <code>magus</code> binary needs only Go. The docs site and WebAssembly playground also need the Node, esbuild, and TinyGo toolchain pinned in <code>mise.toml</code>, which <a href="https://mise.jdx.dev/">mise</a> installs in one step. From a fresh clone:</p>
<pre><code class="language-sh">git clone https://github.com/egladman/magus
cd magus
mise install
go build -o magus ./cmd/magus
magus run ci</code></pre>
<p><code>magus run ci</code> builds, formats, lints, and tests every affected project - the same pipeline continuous integration runs. Only need the binary? Go alone is enough; skip <code>mise install</code> and drop the docs and playground targets.</p>
{{{contributingSection}}}<h2 id="project-graphs">Project graphs</h2>
<p>One card per magus project in this repository, each linking to that project's runnable targets and run-order graph - the same content as its committed <code>MAGUS.md</code>, rendered here with the site's theming, search, and live Mermaid diagrams.</p>
    <div class="related-grid">
{{{projectCards}}}    </div>
<h2 id="reference">Reference</h2>
<p>The deeper references a contributor reaches for once the build is running:</p>
<ul>
  <li><a href="../conventions/">Conventions</a> - the naming and layout rules magus expects of a workspace, and that this repository follows.</li>
  <li><a href="../operations/">Operations</a> - the work hierarchy underneath a target: ops, plans, and the slots that bound concurrency.</li>
  <li><a href="../config/">Configuration</a> - the <code>magus.yaml</code> keys and the <code>MAGUS_*</code> environment inventory.</li>
  <li><a href="../wards/">Diagnostic codes</a> - the <code>MGSxxxx</code> wards, what each one catches, and how to author your own.</li>
  <li><a href="../debugging/">Debugging</a> - dry runs, verbose output, and pry breakpoints for when a target misbehaves.</li>
</ul>
`, {"contributingSection": contributingSection, "projectCards": projectCards});
    renderDevelopmentPageRaw("Development", "Contributor reference for the magus repository: build and test quickstart, how to contribute, the per-project target catalogs, and the deeper reference docs.",
        devHtml, "Development contributing getting started build test project target catalogs conventions operations configuration diagnostic codes debugging reference", "development/", "development/_index.md", site);
}

// site_render rebuilds gen/ from ../docs and the root README. Pure function of
// git history (footers) and the source tree — reproducible and gate-stable.
export fun site_render(root: str, docs: str, blog: str, outDir: str) > Site {
    // The generator state for one render pass, created here and threaded explicitly
    // into every renderer as a `site` argument - no module-global singleton, so two
    // renders (or parallel sessions) never share state.
    // (outDir, not out: `out` is a reserved word in buzz.)
    var site: Site = mut Site{};
    site.root = root;
    site.docs = docs;
    site.blog = blog;
    site.outDir = outDir;
    site.loadMeta();
    site.searchRecords = mut [];
    site.aliasTarget = mut {};
    site.pageUrls = mut {};
    site.writtenPaths = mut {};
    site.docPages = mut [<DocPage>];
    site.blogPosts = mut [<BlogPost>];
    site.hasBlogPosts = false;
    if (isDirectory(site.root + "/" + site.blog)) {
        foreach (name in fs.list(site.root + "/" + site.blog)) {
            if (name.endsWith(".md") and name != "index.md" and name.startsWith("_") == false) {
                site.hasBlogPosts = true;
            }
        }
    }
    // Computed once, before any page renders, so every page (renderPage()'s shared
    // head AND the hand-authored playground.html/graph.html) threads a stable
    // string instead of recomputing per page. See Site.csp/Site.cspHome and
    // computeCSP's doc comments for which pages get which of the two.
    site.csp = computeCSP(CSP_IMG_SRC_DEFAULT);
    site.cspHome = computeCSP(CSP_IMG_SRC_HOME);
    // gen/ is NOT wiped and rebuilt from scratch: outDir is created if missing, then
    // every render below writes/overwrites its current output in place, and
    // pruneStaleOutputs() (called near the end of this function, once every write is
    // known) deletes exactly the leftovers whose source has since been renamed or
    // removed - a renamed docs page, a deleted blog post, a dropped alias, a release
    // that fell out of CHANGELOG.md. Committed-but-not-rendered artifacts (the
    // playground's WASM/editor bundle, rebuilt out of band by build-playground /
    // build-playground-editor) simply persist untouched, since nothing here writes
    // or deletes them.
    fs.makeDirectory(site.outDir);
    std.print("generating site from " + site.root + "/" + site.docs + "/ -> " + site.outDir + "/");

    // Copy static assets referenced by the root README (images, badges). Scoped
    // delete-then-recopy (not a tracked/pruned path like everything else): cp -r
    // alone wouldn't remove a since-deleted source image, so source-copied files
    // are cleared first to keep this one directory-copy free of leftovers too.
    // Preserve the committed esbuild build outputs (mermaid.js, hljs.js from
    // build-mermaid / build-hljs) - they live in gen/assets, not site.root/assets,
    // so a blind wipe would delete them on `serve` (which re-renders without
    // rebuilding bundles); generate rebuilds them afterward regardless.
    os.execute(["sh", "-c", "mkdir -p " + site.outDir + "/assets && find " + site.outDir + "/assets -mindepth 1 -maxdepth 1 ! -name mermaid.js ! -name hljs.js -exec rm -rf \{\} +"]);
    os.execute(["sh", "-c", "[ -d " + site.root + "/assets ] && cp -r " + site.root + "/assets/. " + site.outDir + "/assets/ || true"]);

    // Bundle + minify the client-side assets with esbuild (pinned in mise.toml).
    // The nine flat scripts became a src/ ES-module tree (feature modules + lib/);
    // esbuild writes two outputs: theme.js (head, critical, minified — no bundle
    // needed, it has no imports) and main.js (the deferred bundle of every feature
    // module). mermaid is a lazy dynamic import() pointing to the same-origin
    // gen/assets/mermaid.js bundle (built by build-mermaid); esbuild leaves dynamic
    // imports as external runtime imports. CSS is minified per-file (not
    // bundled). Pinned esbuild -> byte-stable output, so the drift gate holds.
    os.execute(["sh", "-c", "esbuild src/styles/site.css --minify --outfile=" + site.outDir + "/site.css"]);
    // console.css: the console-app-only shell (app bar, launcher, status bar, full-height
    // layout) loaded by /dashboard/, /logs/, /graph/ (and the playground, for the status bar)
    // but NOT the docs corpus. Site-wide-ish, so minified to gen root and enumerated in the
    // precache/allowlist next to site.css.
    os.execute(["sh", "-c", "esbuild src/styles/console.css --minify --outfile=" + site.outDir + "/console.css"]);
    // ui-panels.css: the shared nav-triggered UI panels (settings gear dropdown + reference
    // drawer) that BOTH the docs pages and the console apps use. Split out of console.css so the
    // docs corpus can load only this and drop console.css. Gen-root, precached like the others.
    os.execute(["sh", "-c", "esbuild src/styles/ui-panels.css --minify --outfile=" + site.outDir + "/ui-panels.css"]);
    os.execute(["sh", "-c", "esbuild src/styles/theme.css --minify --outfile=" + site.outDir + "/theme.css"]);
    // The console surfaces (graph/logs/dashboard/activity) and their page-scoped CSS moved to the
    // standalone top-level console/ project (its own build, deployed to /console/). The docs site no
    // longer renders or bundles any of them.
    os.execute(["sh", "-c", "esbuild src/theme.ts --minify --outfile=" + site.outDir + "/theme.js"]);
    os.execute(["sh", "-c", "esbuild src/site/main.ts --bundle --minify --format=esm --outfile=" + site.outDir + "/main.js"]);

    // Emit the WebAssembly playground page at gen/playground/index.html (injecting the
    // shared nav/footer into the hand-authored playground.html). buzz.wasm,
    // wasm_exec.js, and editor.js are committed directly in gen/playground/ - rebuilt
    // in place by build-playground / build-playground-editor, never by this render -
    // so renderPlayground only needs to add index.html alongside them. gen/ no longer
    // gets wiped on every generate (see the comment above fs.makeDirectory(site.outDir)),
    // so there is no external source copy to merge in; pruneStaleOutputs() also knows
    // to leave these three paths alone (see its alwaysKeep set).
    // Gather every docs page's relatedness metadata BEFORE any page renders, so each docs page's
    // "Related" cards (renderRelated) can resolve titles/URLs against the full corpus. collectDocPages
    // only reads frontmatter, so it is free of the render state below.
    site.collectDocPages("");

    renderPlayground(site);

    // Load release manifests from releases/*.yaml BEFORE the walk so renderPage()
    // knows whether the releases Atom feed will be written and can gate its
    // <link rel=alternate> discovery tag accordingly (advertising a missing feed
    // file would trip the asset check). Changelog-parsing no longer runs at site-build
    // time; it runs only at release-cut time (cmd/magus-utils cut).
    loadReleases(site);

    renderRoot(site);
    walk("", site);
    walkBlog(site);

    // Build the /development/ section before writeAliases so its pages are in site.pageUrls
    // for the collision guard and its collectAlias redirects (the retired
    // /development/projects/ URLs) get stubs written in the same pass.
    renderDevelopment(site);

    // Emit a redirect stub per declared frontmatter alias (after the walk, so every
    // real page URL is known for the collision guard). Aliases stay out of the
    // search index/sitemap/feeds — only the real page they point to appears there.
    // The console API-reference page (docs/reference/console.md) aliases the old /console/ URL, so a
    // redirect stub lands at gen/console/index.html here - that keeps the docs site's internal links
    // to /console/ resolving for the asset-integrity gate. The console SPA is a SEPARATE project,
    // copied over gen/console/ at deploy (see .github/workflows/pages.yaml), so the app wins there.
    site.writeAliases();

    writeSEOFiles(site);
    renderBlogAtom(site);
    renderReleasesAtom(site);
    renderPublic(site);
    render404(site);
    writeOffline(site);
    renderSearchPage(site);
    renderTourPage(site);
    writeManifest(site);

    // llms.txt: the docs index an AI agent reads to discover pages and fetch each
    // one's Markdown at <url>index.md. A post-walk aggregate over the docs corpus,
    // like search-index.json below.
    writeLLMsIndex(site);

    // Flat {url, title, text, tags, description?} record per page; search.js
    // fetches this lazily on first focus. Keys are sorted by serialize, and the
    // walk order is fs.list's (sorted), so the file is byte-stable across runs.
    fs.writeFile(site.outDir + "/search-index.json", "[" + site.searchRecords.join(",") + "]");

    // Written last: its cache version is a digest of the precached assets (incl.
    // search-index.json just above), so every one of them must already exist.
    writeServiceWorker(site);

    // Clean up anything left on disk from a previous render whose source is gone
    // (see pruneStaleOutputs' doc comment). Runs before the two gates below so
    // neither can trip on a stale page's dangling reference to content removed
    // along with it.
    pruneStaleOutputs(site);

    // writeSiteManifest is NOT called here: generateJsBundles() (magusfile.buzz's
    // generate(), which calls this function) still has to run and writes
    // gen/assets/mermaid.js and gen/assets/hljs.js - both served assets - AFTER
    // site_render returns. Computing the manifest here would silently miss them.
    // See generate()'s call to scribe.writeSiteManifest(site) for the real call
    // site, which runs once every write to gen/ - by any step - is done.

    // Reproducibility guard: throw on any dangling href/src reference. Runs after
    // every asset + page has been written, so a missing file (renamed bundle,
    // deleted image, forgotten alias fix) fails the build here rather than
    // shipping a silent 404. See docs/engines.md.
    site.assetIntegrityCheck();

    // Orphan gate: after every page exists, prove each docs page is reachable by
    // clicking from the site's front door. Runs after assetIntegrityCheck so link
    // targets are already known-good.
    site.orphanCheck();

    // Parity gate: no previously-shipped URL may silently start 404-ing.
    abandonedLinkCheck(site);

    std.print("done");
    // Hand the populated state back to the caller, which threads it into
    // updateUrlLock (no module-global carries it between the two calls).
    return site;
}

// checkPathExists returns true when target (gen-root-relative, no leading slash)
// resolves to a real file under gen/. Directory refs (URL ending in "/" or a plain
// slugged path) resolve to their index.html; assets pass through verbatim.
fun checkPathExists(target: str, site: Site) > bool {
    // Empty target = gen/'s root, always the index.html landing. This shows up
    // when a page links to "../" (Parent Directory in an autoindex root) and the
    // resolver pops back to the root.
    if (target == "") { return os.execute(["test", "-f", site.outDir + "/index.html"]) == 0; }
    if (os.execute(["test", "-f", site.outDir + "/" + target]) == 0) { return true; }
    if (os.execute(["test", "-d", site.outDir + "/" + target]) == 0) {
        return os.execute(["test", "-f", site.outDir + "/" + target + "/index.html"]) == 0;
    }
    if (target.endsWith("/")) {
        return os.execute(["test", "-f", site.outDir + "/" + target + "index.html"]) == 0;
    }
    return false;
}

// scanReferencesInHTML pulls every href="..." and src="..." out of html, skipping
// external URLs, mailto:, javascript:, data:, and pure fragments. Each reference
// is returned as a gen-root-relative path (resolved against pageDir).
fun scanReferencesInHTML(html: str, pageDir: str) > [str] {
    var refs: [str] = mut [<str>];
    var seen: {str: bool} = mut {};
    var rest = html;
    while (true) {
        final iHref = rest.indexOf("href=\"");
        final iSrc = rest.indexOf("src=\"");
        var i: int = -1;
        var advance = 0;
        if (iHref != null and iSrc != null) {
            if (iHref < iSrc) { i = iHref; advance = 6; } else { i = iSrc; advance = 5; }
        } else if (iHref != null) { i = iHref; advance = 6; }
        else if (iSrc != null) { i = iSrc; advance = 5; }
        else { i = -1; }
        if (i < 0) { return refs; }
        rest = rest.sub(i + advance);
        final end = rest.indexOf("\"");
        if (end == null) { return refs; }
        final raw = rest.sub(0, end);
        rest = rest.sub(end + 1);
        if (raw == "") { continue; }
        if (raw.startsWith("http://") or raw.startsWith("https://") or raw.startsWith("//")
            or raw.startsWith("#") or raw.startsWith("mailto:") or raw.startsWith("javascript:")
            or raw.startsWith("data:") or raw.startsWith("tel:")) { continue; }
        // Root-absolute paths (leading /) are the deploy-time reference form
        // (WS0b's ONE deliberate exception on 404.html, WS S's manifest, etc.);
        // they resolve at the deploy base, not against gen/'s root, so we can't
        // check them locally without threading SITE_URL's basePath in. Skip.
        if (raw.startsWith("/")) { continue; }
        // References to repo source files (.go/.buzz) point at their GitHub
        // location relative to the repo root, not to a generated site asset.
        // magus's `markdown` module rewrites .md links but leaves .go/.buzz
        // untouched, matching author intent. Skip so the check stays focused on
        // real page/asset breakage.
        if (raw.endsWith(".go") or raw.endsWith(".buzz")) { continue; }
        // Strip a URL #fragment; the file only needs to exist, the fragment is
        // client-side.
        var path = raw;
        final hash = path.indexOf("#");
        if (hash != null) { path = path.sub(0, hash); }
        if (path == "") { continue; }
        // Also drop a query string.
        final q = path.indexOf("?");
        if (q != null) { path = path.sub(0, q); }
        if (path == "") { continue; }
        final resolved = resolvePath(pageDir, path);
        if (seen[resolved] == null) {
            seen[resolved] = true;
            refs.append(resolved);
        }
    }
    return refs;
}

// walkGen recursively enumerates every written file under gen/ so the integrity
// check reads each once. Skips buzz.wasm (binary; slow file test suffices).
fun walkGen(rel: str, acc: [str], site: Site) > void {
    var dir = site.outDir;
    if (rel != "") { dir = site.outDir + "/" + rel; }
    foreach (name in fs.list(dir)) {
        var childRel = name;
        if (rel != "") { childRel = rel + "/" + name; }
        if (os.execute(["test", "-d", site.outDir + "/" + childRel]) == 0) {
            walkGen(childRel, acc, site);
        } else {
            acc.append(childRel);
        }
    }
}

// pruneStaleOutputs deletes gen/ output left behind by a source that no longer
// produces it - a renamed/removed docs page, a deleted blog post, a dropped
// frontmatter alias, a release that fell out of CHANGELOG.md. gen/ is no longer
// wiped before each render (see the comment in site_render), so this is what keeps
// it from silently accumulating orphans instead: walk what is really on disk,
// and for every "<dir>/index.html" NOT in writtenPaths (this render's actual
// output) and not in alwaysKeep, delete the whole directory - taking any sibling
// file (an index.md, say) with it. Run before assetIntegrityCheck/orphanCheck so
// neither gate can trip on a stale page's dangling reference to content that was
// removed along with it.
fun pruneStaleOutputs(site: Site) > void {
    // Fixed, unconditional-or-deliberately-persistent outputs that are never
    // candidates for pruning: paths a normal render always (re)writes regardless of
    // docs/blog content (so they're never actually stale), plus the playground's
    // committed WASM/editor bundle, which this render never writes or deletes at all
    // (it is refreshed out of band by build-playground / build-playground-editor).
    final alwaysKeep: {str: bool} = mut {
        "index.html": true, "index.md": true, "404.html": true,
        "sitemap.xml": true, "robots.txt": true, "manifest.webmanifest": true,
        "sw.js": true, "search-index.json": true, "site-manifest.sha256": true,
        "site.css": true, "console.css": true, "ui-panels.css": true, "theme.css": true, "theme.js": true, "main.js": true,
        "search/index.html": true,
        "playground/index.html": true, "playground/buzz.wasm": true,
        "playground/wasm_exec.js": true, "playground/editor.js": true,
        // /console/ is owned by the standalone console/ project (copied in at deploy). The docs render
        // only emits a redirect stub there via the reference/console alias, which writeAliases already
        // registers in writtenPaths, so it needs no alwaysKeep entry.
    };
    final acc: [str] = mut [<str>];
    walkGen("", acc, site);
    final staleDirs: {str: bool} = mut {};
    foreach (path in acc) {
        if (alwaysKeep[path] != null) { continue; }
        if (path.startsWith("assets/")) { continue; }   // scoped delete+recopy above already keeps this clean
        if (path.endsWith("/index.html") == false) { continue; }   // only page-shaped files drive pruning
        if (site.writtenPaths[path] != null) { continue; }
        staleDirs[path.sub(0, path.len() - 11)] = true;   // len("/index.html") == 11
    }
    foreach (dir in staleDirs.keys()) {
        std.print("  pruning stale " + dir + "/ (no longer produced)");
        fs.delete(site.outDir + "/" + dir);
    }
}

// writeSiteManifest emits gen/site-manifest.sha256: one "<sha256>  <path>\n"
// line (standard sha256sum(1) format, so `sha256sum -c` or a spot-check
// `curl -s <asset-url> | sha256sum` verifies it directly - see
// docs/reference/console.md's "Verify our claims" section) per file actually
// shipped under gen/, repo-relative, sorted. Reuses fileSha256 - the same
// per-file digest writeServiceWorker already computes for its cache-version
// stamp, just surfaced for every asset instead of folded into one internal
// checksum. Exported and called from magusfile.buzz's generate(), AFTER
// generateJsBundles() - not from inside site_render() - because
// generateJsBundles() writes gen/assets/mermaid.js and gen/assets/hljs.js
// (both served assets) only after site_render() has already returned;
// computing the manifest inside site_render would silently omit them. The
// manifest excludes its own output path (a file cannot hash itself).
export fun writeSiteManifest(site: Site) > void {
    final acc: [str] = mut [<str>];
    walkGen("", acc, site);
    final sorted = acc.sort(fun (a: str, b: str) > bool { return strLess(a, b); });
    var body = "";
    foreach (rel in sorted) {
        if (rel == "site-manifest.sha256") { continue; }
        body = body + fileSha256(site.outDir + "/" + rel) + "  " + rel + "\n";
    }
    fs.writeFile(site.outDir + "/site-manifest.sha256", body);
}

// pageKey normalizes a scanReferencesInHTML result (a gen-root-relative path with no
// trailing slash - "spells/go", "index.html", "assets/x.png") to a page key: "" for
// the home page, else the directory that holds the page's index.html. Asset paths
// pass through unchanged and simply never match a real page key.
fun pageKey(resolved: str) > str {
    var r = resolved;
    if (r.endsWith("/index.html")) { r = r.sub(0, r.len() - 11); }  // len("/index.html") == 11
    if (r == "index.html") { return ""; }
    if (r.endsWith("/")) { r = r.sub(0, r.len() - 1); }
    return r;
}


// URL_LOCK is the committed, append-only ledger of every URL the site has ever
// shipped (one per line, sorted). RETIRED_URLS lists URLs intentionally removed,
// exempting them from the abandoned-link gate.
final URL_LOCK = "urls.lock";
final RETIRED_URLS = "retired-urls.txt";

// readURLSet reads a newline-delimited URL file into a set, skipping blanks and
// "#" comments. Missing file -> empty set (the bootstrap case for URL_LOCK).
fun readURLSet(path: str) > {str: bool} {
    var set: {str: bool} = mut {};
    if (os.execute(["test", "-f", path]) != 0) { return set; }
    final f = io.File.open(path, io.FileMode.read);
    final content = f.readAll();
    f.close();
    foreach (line in content.split("\n")) {
        final t = line.trim();
        if (t != "" and t.startsWith("#") == false) { set[t] = true; }
    }
    return set;
}

// abandonedLinkCheck is the parity gate: every URL the site has shipped before
// (recorded in URL_LOCK) must still resolve, so a renamed or deleted page can't
// silently start 404-ing on inbound links and bookmarks. To retire a URL on
// purpose, either add a redirect (frontmatter `aliases:`, whose stub keeps the old
// URL resolving) or list it in retired-urls.txt. Runs every render; the lock only
// grows (updateUrlLock, under the rw charm).
fun abandonedLinkCheck(site: Site) > void {
    final locked = readURLSet(URL_LOCK);
    final retired = readURLSet(RETIRED_URLS);
    var abandoned: [str] = mut [<str>];
    foreach (url in locked.keys()) {
        if (retired[url] == null and checkPathExists(url, site) == false) {
            abandoned.append(url);
        }
    }
    if (abandoned.len() > 0) {
        final sorted = abandoned.sort(fun (a: str, b: str) > bool { return strLess(a, b); });
        throw "abandoned links: {sorted.len()} previously-shipped URL(s) no longer resolve. Add a redirect (frontmatter aliases:) or list them in website/retired-urls.txt: " + sorted.join(", ");
    }
}

// updateUrlLock folds this build's URLs into URL_LOCK and rewrites it sorted. It
// only adds - a URL that drops out of the build stays in the ledger so the gate
// keeps demanding a redirect or an explicit retirement for it. Called under the rw
// charm so a plain (checking) render never mutates the tree.
export fun updateUrlLock(site: Site) > void {
    var set = readURLSet(URL_LOCK);
    foreach (u in site.pageUrls.keys()) { set[u] = true; }
    var lines: [str] = mut [<str>];
    foreach (u in set.keys()) { lines.append(u); }
    final sorted = lines.sort(fun (a: str, b: str) > bool { return strLess(a, b); });
    var body = "";
    foreach (u in sorted) { body = body + u + "\n"; }
    fs.writeFile(URL_LOCK, body);
}

// Tests for the pure helpers. Run them with the `buzz-test` target
// (`magus buzz -t --embedded scribe.buzz`); living in this module, they reach its
// internal functions directly. They register but do not run during a normal render.
// Buzz's == is identity (not structural) for maps, so assert.equal does the
// value comparison: the whole aliasTarget map at once, not field-by-field.
test "Site.collectAlias trims slashes and records every alias" {
    final s = mut Site{};
    s.collectAlias("/old-path/", "new-path/");
    s.collectAlias("same", "same/");
    assert.equal(s.aliasTarget, {"old-path": "new-path/", "same": "same/"}, "both aliases recorded with slashes trimmed");
}

test "Site.addRecord marks the URL written and appends one search record" {
    final s = mut Site{};
    s.addRecord("guide/", "Guide", "", "---\ntitle: Guide\n---\nBody text.");
    assert.equal(s.pageUrls, {"guide/": true}, "url marked written");
    assert.len(s.searchRecords, 1, "one search record appended");
}

test "llmsIndexBody lists docs pages sorted by URL, base-prefixed, with descriptions" {
    final pages = mut [<DocPage>];
    pages.append(DocPage{url = "targets/", title = "Targets", desc = "What a target is"});
    pages.append(DocPage{url = "cache/", title = "Cache", desc = "The cache model"});
    pages.append(DocPage{url = "faq/", title = "FAQ", desc = ""});
    final want = "# magus\n\n"
        + "> Workspace-aware build orchestrator and content-addressed cache. "
        + "Every link below is the page's raw Markdown (its index.md sibling), "
        + "so an agent fetches clean content directly.\n\n"
        + "## Documentation\n\n"
        + "- [Cache](/cache/index.md): The cache model\n"
        + "- [FAQ](/faq/index.md)\n"
        + "- [Targets](/targets/index.md): What a target is\n";
    assert.equal(llmsIndexBody(pages, "/"), want, "llms.txt links to each page's index.md, sorted, base-prefixed, description only when present");
}

test "jsonStr escapes backslash, double-quote, newline, tab, and carriage-return" {
    assert.equal(jsonStr(""), "\"\"", "empty string");
    assert.equal(jsonStr("hello"), "\"hello\"", "plain string passthrough");
    assert.equal(jsonStr("a\\b"), "\"a\\\\b\"", "backslash escaped first");
    assert.equal(jsonStr("say \"hi\""), "\"say \\\"hi\\\"\"", "double-quote escaped");
    assert.equal(jsonStr("line1\nline2"), "\"line1\\nline2\"", "newline escaped");
    assert.equal(jsonStr("col1\tcol2"), "\"col1\\tcol2\"", "tab escaped");
    assert.equal(jsonStr("cr\r"), "\"cr\\r\"", "carriage-return escaped");
    // Backslash must be escaped before quotes so new backslashes are not re-escaped.
    assert.equal(jsonStr("a\\\"b"), "\"a\\\\\\\"b\"", "backslash then quote: backslash first");
}

test "semverSortKey produces zero-padded keys for numeric semver comparison" {
    assert.equal(semverSortKey("v0.2.0.yaml"),  "0000.0002.0000", "v0.2.0");
    assert.equal(semverSortKey("v0.10.0.yaml"), "0000.0010.0000", "v0.10.0");
    assert.equal(semverSortKey("v1.0.0.yaml"),  "0001.0000.0000", "v1.0.0");
    // v0.10.0 key > v0.2.0 key: newest-first sort is correct
    final key10 = semverSortKey("v0.10.0.yaml");
    final key2  = semverSortKey("v0.2.0.yaml");
    assert.equal(key10 > key2, true, "v0.10.0 sorts after v0.2.0 in descending pass");
}

test "releaseIndexJSON emits schema_version=1 and frozen v1 fields for a known release" {
    final s = mut Site{};
    var added: [str] = mut [<str>];
    added.append("first feature");
    var artifacts: [{str: str}] = mut [<{str: str}>];
    artifacts.append(mut {"name": "magus_v0.2.0_linux_amd64.tar.gz", "platform": "linux/amd64", "size": "12345", "sha256": "abc123"});
    s.releases.append(Release{
        version = "v0.2.0",
        date = "2026-08-01",
        notesAdded = added,
        body = "### Added\n\n- first feature",
        artifacts = artifacts,
    });
    final got = releaseIndexJSON(s);
    // Check JSON structure via indexOf so literal braces in assertions don't need escaping.
    assert.equal(got.indexOf("\"schema_version\":1") != null, true, "schema_version:1 present");
    assert.equal(got.indexOf("\"releases\":[") != null, true, "releases array present");
    assert.equal(got.indexOf("\"version\":\"v0.2.0\"") != null, true, "version present");
    assert.equal(got.indexOf("\"notes\":") != null, true, "notes field present");
    assert.equal(got.indexOf("\"added\":[\"first feature\"]") != null, true, "notes.added present");
    assert.equal(got.indexOf("\"body\":\"### Added\\n\\n- first feature\"") != null, true, "body present with escaped newlines");
    assert.equal(got.indexOf("\"platform\":\"linux/amd64\"") != null, true, "artifact platform present");
    // yanked must be absent when false (omitempty)
    assert.equal(got.indexOf("yanked") != null, false, "yanked absent when false");
    assert.equal(got.endsWith("]\}\n"), true, "ends with closing brace and newline");
}

test "extractInlineScripts finds only attribute-less <script> blocks, in order" {
    final html = "<script src=\"a.js\"></script><p>x</p><script>one();</script>"
        + "<script type=\"module\" src=\"b.js\"></script><script>two();</script>";
    final got = extractInlineScripts(html);
    assert.equal(got, ["one();", "two();"], "external scripts skipped; inline ones returned in order");
    assert.equal(extractInlineScripts("no scripts here"), [], "no match -> empty list");
}

test "scriptHash matches a known sha256-then-base64 digest" {
    // echo -n "" | openssl dgst -sha256 -binary | openssl base64
    assert.equal(scriptHash(""), "sha256-47DEQpj8HBSa+/TImW+5JCeuQeRkm5NMpJWZG3hSuFU=", "empty string's well-known SHA-256, base64-encoded");
}

test "computeCSP names every directive exactly once and includes the loopback hosts" {
    final got = computeCSP(CSP_IMG_SRC_DEFAULT);
    assert.equal(got.indexOf("default-src 'self'") != null, true, "default-src present");
    assert.equal(got.indexOf("'wasm-unsafe-eval'") != null, true, "wasm-unsafe-eval present for the playground's wasm runtime");
    assert.equal(got.indexOf("connect-src 'self' http://127.0.0.1:* http://[::1]:*") != null, true, "connect-src carries exactly the loopback wildcards");
    assert.equal(got.indexOf("object-src 'none'") != null, true, "object-src 'none'");
    assert.equal(got.indexOf("frame-src 'none'") != null, true, "frame-src 'none'");
    // Every playground.html inline <script> contributes exactly one sha256- source.
    final f = io.File.open("playground.html", io.FileMode.read);
    final n = extractInlineScripts(f.readAll()).len();
    f.close();
    var hashCount = 0;
    var rest = got;
    while (rest.indexOf("'sha256-") != null) {
        final i = rest.indexOf("'sha256-");
        rest = rest.sub(i + 1);
        hashCount = hashCount + 1;
    }
    assert.equal(hashCount, n, "one script-src hash per playground.html inline script");
}

test "computeCSP's img-src is exactly the caller's imgSrc argument - the per-page hook" {
    final withDefault = computeCSP(CSP_IMG_SRC_DEFAULT);
    assert.equal(withDefault.indexOf("img-src 'self' data:;") != null, true, "default img-src has no external host");
    assert.equal(withDefault.indexOf("github.com") != null, false, "default img-src never carries the badge hosts");
    assert.equal(withDefault.indexOf("pkg.go.dev") != null, false, "default img-src never carries the badge hosts");

    final withHome = computeCSP(CSP_IMG_SRC_HOME);
    assert.equal(withHome.indexOf("img-src 'self' data: https://github.com https://pkg.go.dev;") != null, true, "home img-src carries both badge hosts, verbatim");
}

test "cspForRedirectStub is scoped tighter than computeCSP and hashes exactly the given script" {
    final got = cspForRedirectStub("location.replace(\"../x/\");");
    assert.equal(got, "default-src 'none'; script-src '" + scriptHash("location.replace(\"../x/\");") + "'"
        + "; base-uri 'self'; form-action 'none'; object-src 'none'; frame-src 'none'", "exact policy string");
    assert.equal(got.indexOf("style-src") != null, false, "no style-src - a redirect stub has no stylesheet or style attribute");
    assert.equal(got.indexOf("img-src") != null, false, "no img-src - a redirect stub has no image");
    assert.equal(got.indexOf("connect-src") != null, false, "no connect-src - a redirect stub makes no fetch");
}
