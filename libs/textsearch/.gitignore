# Dev-only gate dependencies (typescript + biome). Not committed: this library ships
# no bundle of its own, so there is no committed artifact these produce - each consumer
# bundles the source directly.
node_modules/

# Bundled test output: `pnpm run test` esbuild-bundles src/*.test.ts here and runs it
# under node --test (which skips node_modules, so the bundle can't live there). A build
# artifact, not committed.
.testcache/
