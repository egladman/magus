// @expect: 142
// Upstream-compatible Buffer: the Zig/pointer API yeetile's FFI memory ops move
// onto. Exercises ::<T> generic-method-call syntax, writeZAt (byte-offset `at`) /
// readZAt (ELEMENT-INDEX `at`, matching upstream's asymmetry), and collect() —
// the out-param shape (alloc, write at offsets, read back) a C fn would fill in.
import "buffer";

final b = buffer.Buffer.init(16);
b.writeZAt::<int>(0, "u32", [42]);  // byte 0
b.writeZAt::<int>(8, "i64", [100]); // byte 8 (i64-aligned)
final lo: int = b.readZAt::<int>(0, "u32"); // element 0 -> byte 0
final hi: int = b.readZAt::<int>(1, "i64"); // element 1 -> byte 8
b.collect();
final __r = lo + hi;
