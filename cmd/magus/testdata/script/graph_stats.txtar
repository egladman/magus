# graph stats is the knowledge-graph shape lens: god nodes, orphans, doc coverage.
# It reads the graph (cache-first), not git history, so it needs no commits window.
exec magus graph stats
stdout 'god nodes'
stdout 'doc coverage'
stdout 'DEGREE'

# -o json exposes the three sections.
exec magus graph stats -o json
stdout '"gods"'
stdout '"coverage"'
stdout '"node_count"'

# --kind scopes every section to one node kind.
exec magus graph stats --kind spell -o json
stdout '"kind": "spell"'

# A spell the workspace DECLARES but no target runs is a genuine orphan (dead weight):
# acme's lint target uses acme (not flagged), while the declared "chore" spell has an op
# no target invokes (flagged). A built-in spell the workspace never declares is merely
# available, not an orphan - the "declared" qualifier keeps that noise out.
exec magus graph stats -o json
stdout '"reason": "declared but no target uses it"'
stdout '"label": "chore"'

# the removed lens points at the new home
! exec magus insight structure
stderr 'moved to `magus graph stats`'

-- magus.yaml --
concurrency: 4
-- magusfile.buzz --
import "magus";
import "spells/acme" as acme;
import "spells/chore" as chore;
magus.project({ "spells": [acme, chore] });
export fun lint(ctx: magus\Context, args: [str]) > void { acme.lint(); }
-- spells/acme/spell.buzz --
import "magus/target";
export fun mgs_getName() > str { return "acme"; }
fun lint(target: Target) > Command {
    return Command{bin = "acme", args = ["lint", "."]};
}
export fun mgs_listTargets() > {str: fun(Target) Command} { return {"lint": lint}; }
-- spells/chore/spell.buzz --
import "magus/target";
export fun mgs_getName() > str { return "chore"; }
fun sweep(target: Target) > Command {
    return Command{bin = "chore", args = ["sweep"]};
}
export fun mgs_listTargets() > {str: fun(Target) Command} { return {"sweep": sweep}; }
