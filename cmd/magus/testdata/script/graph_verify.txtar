# graph verify reports a missing skill without failing
exec magus graph verify --dir .
stdout 'not installed'

# after install it reports up to date
exec magus agent install claude
exec magus graph verify --dir .
stdout 'up to date'

# a stale install (older footer) is reported, and --strict makes it a non-zero exit
cp stale.md .claude/skills/magus/SKILL.md
exec magus graph verify --dir .
stdout 'STALE'
! exec magus graph verify --dir . --strict
stdout 'STALE'

-- stale.md --
---
name: magus-knowledge-graph
---
body
<!-- generated by: magus agent install; agent-skill-version: 0; knowledge-schema-version: 1; do not edit -->
