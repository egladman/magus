# graph export assembles the deterministic domain graph and emits a routing
# summary by default. It must build implicitly (cache-first) with no build verb.
exec magus graph export
stdout 'knowledge graph'
stdout 'nodes by kind'
stdout 'edges by relation'
stdout 'project'
stdout 'target'
stdout 'spell'
stdout 'diagnostic'

# the store is persisted under the cache dir (shards authoritative + a manifest)
exists .magus/knowledge/manifest.json

# -o json emits the merged node-link graph external graph tools read directly:
# nodes carry id/kind, links carry source/target/relation, plus the schema version.
exec magus graph export -o json
stdout '"schema_version"'
stdout '"directed": true'
stdout '"kind": "project"'
stdout '"kind": "target"'
stdout '"kind": "spell"'
stdout '"kind": "charm"'
stdout '"kind": "diagnostic"'
stdout 'spell:acme'
stdout '"relation": "depends_on"'
stdout '"relation": "uses"'
stdout '"relation": "references"'
stdout '"confidence": "extracted"'

# -o graphml emits GraphML for external graph viewers: declared keys, directed
# graph, node/edge data elements.
exec magus graph export -o graphml
stdout '<graphml xmlns='
stdout 'edgedefault="directed"'
stdout '<node id="spell:acme">'
stdout '<data key="relation">uses</data>'

# dot/mermaid on the whole graph is refused: too many nodes to lay out. The
# error points at --select and the whole-graph formats that do work.
! exec magus graph export -o dot
stderr 'requires --select'
! exec magus graph export -o mermaid
stderr 'requires --select'

# --select narrows the export to a query's neighborhood, sharing the query
# engine. With a scope, dot and mermaid render.
exec magus graph export --select 'spell:acme' -o mermaid
stdout 'graph TD'
stdout 'classDef kind_spell'
stdout '"contains"'
# the neighborhood is scoped: an unrelated diagnostic node is not pulled in.
! stdout 'MGS'

exec magus graph export --select 'spell:acme' -o dot
stdout 'digraph knowledge'
stdout '"spell:acme"'

# the same neighborhood in json/graphml is a valid export of just the subgraph.
exec magus graph export --select 'spell:acme' -o json
stdout '"schema_version"'
stdout 'spell:acme'

# a query that resolves to nothing yields an empty graph and a plain-ASCII note.
exec magus graph export --select 'zzznotarealnode' -o json
stderr 'no nodes matched'
stdout '"node_count": 0'

# the removed spelling points at the new home
! exec magus describe knowledge
stderr 'moved to `magus graph export`'

-- magus.yaml --
concurrency: 4
-- magusfile.buzz --
import "magus";
import "spells/acme" as acme;
magus.project({ "spells": [acme] });
export fun lint(args: [str]) > void { acme.lint(); }
export fun build(args: [str]) > void {
    magus.needs(magus.target.literal("lint"));
    if (magus.has_charm("rw")) { acme.lint(); }
}
-- spells/acme/spell.buzz --
import "magus/target";
import "magus/charm";
export fun mgs_getName() > str { return "acme"; }
fun lint(target: Target) > Command {
    final args = ["lint", "."];
    return Command{bin = "acme", args = args, charms = {
        "rw": after(args, "lint", ["--fix"]),
    }};
}
export fun mgs_listTargets() > {str: fun(Target) Command} { return {"lint": lint}; }
