// @expect: 2
// Regression: the member-access inline cache (mcache) is indexed by instruction
// ip alone, so two different chunks can each have an OpGetMember at the same ip
// on the same object type but for different fields. The cache entry must be
// keyed by (chunk, def), not def alone, or one chunk's field index is served to
// the other (here: the top-level `root.first` read aliased a function chunk's
// `.id` access and returned field 0). Minimized from a tiling-tree example; the
// exact statement layout below is what aligns the colliding ips — keep it.
enum Orient { Horiz, Vert }
enum Pick { Auto, Horiz, Vert }
object Node {
    id: int = 0,
    orient: Orient = Orient.Horiz,
    ratio: double = 0.5,
    pick: Pick = Pick.Auto,
    first: Node? = null,
    second: Node? = null,
    x: double = 0.0,
    y: double = 0.0,
    w: double = 0.0,
    h: double = 0.0,
    fun isLeaf() > bool {
        return this.first == null;
    }
}
fun makeLeaf(id: int) > Node {
    return mut Node{ id = id };
}
fun splitLeaf(node: Node, id: int) > void {
    final old = mut Node{ id = node.id, x = node.x, y = node.y, w = node.w, h = node.h };
    node.id = 0;
    node.first = old;
    node.second = makeLeaf(id);
}
fun countLeaves(node: Node?) > int {
    if (node == null) {
        return 0;
    }
    final n = node!;
    if (n.isLeaf()) {
        return 1;
    }
    return countLeaves(n.first) + countLeaves(n.second);
}
final root = makeLeaf(1);
splitLeaf(root, 2);
final __r = countLeaves(root);
