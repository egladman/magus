# yeetile configuration — copy to ~/.config/yeetile/config
#
# One plain-text file, i3-style: `set` variables, a few directives, and
# `bind <chord> <command>` lines. Whole-line comments start with '#'.
# Unknown lines warn and are skipped.

# $mod is substituted into later lines, exactly like i3.
# Modifiers: cmd (super), alt (option), ctrl (control), shift.
set $mod cmd+ctrl

# Gaps default to ZERO — windows get every pixel. Opt in if you like air:
# gaps inner 10
# gaps outer 12
top_padding 36

# How often yeetile rescans for opened and closed windows.
poll_interval_ms 800

# Hover to focus, like X11 — macOS still doesn't offer this natively.
# Geometry-only (the WM already knows every frame), throttled, never raises,
# and deliberately defers while you're typing. The event taps behind it are
# watchdogged every tick (rebuilt if macOS invalidates them, re-enabled if
# disabled), so it doesn't quietly die the way hover-focus tools used to.
focus_follows_mouse on

# Which displays tile (1-based, main first): pick any subset, or `all`.
# Each tiled display runs its own tree; every UNlisted display stays stock
# macOS — drag a window there and yeetile lets go of it, drag it back (or
# between tiled displays) and it re-homes. Focus crosses displays with the
# normal focus left/right/up/down keys.
tile_displays all
# tile_displays 1 3
# tile_display 2          # legacy single-display form

# High-contrast border around the focused window (i3-style; drawn as
# click-through overlay strips, follows drags at poll cadence).
# border on
# border_width 3

# Hold this chord to peek at every keybinding; release to dismiss.
cheatsheet $mod+slash

# Directional focus and movement (vim keys, like i3).
bind $mod+h focus left
bind $mod+j focus down
bind $mod+k focus up
bind $mod+l focus right
bind $mod+shift+h move left
bind $mod+shift+j move down
bind $mod+shift+k move up
bind $mod+shift+l move right

# Cycle through windows in tree order (works even in a single column).
bind $mod+tab focus next
bind $mod+shift+tab focus prev

# Workspaces 1-9: $mod+N switches, $mod+shift+N sends the focused window.
# Pressing the current workspace's number bounces back to the previous one.
# (Parked workspaces minimize their windows — macOS Spaces APIs are private.)
bind $mod+1 workspace 1
bind $mod+2 workspace 2
bind $mod+3 workspace 3
bind $mod+4 workspace 4
bind $mod+5 workspace 5
bind $mod+shift+1 move workspace 1
bind $mod+shift+2 move workspace 2
bind $mod+shift+3 move workspace 3
bind $mod+shift+4 move workspace 4
bind $mod+shift+5 move workspace 5

# The next window opened at the focused pane splits this way
# (default: automatic, along the pane's longer side).
bind $mod+s split horizontal
bind $mod+v split vertical

# Grow or shrink the focused pane's share of its split; the arrow-key
# variants resize along a specific axis (nearest split of that orientation).
bind $mod+equal resize grow
bind $mod+minus resize shrink
bind $mod+right resize grow width
bind $mod+left resize shrink width
bind $mod+down resize grow height
bind $mod+up resize shrink height

# Toggle the focused window over the whole tiling area; the native variant
# is macOS's own green-button fullscreen (the window takes its own Space and
# leaves management until it returns).
bind $mod+f fullscreen
bind $mod+shift+f fullscreen native

# Stacked layout: every window full-size, focused on top; cycle with
# focus next/prev. Toggle per workspace.
bind $mod+w stacking toggle

# Golden-ratio mode: the focused pane always takes the phi share (~62%) of
# its splits, reflowing as focus moves. min_width/min_height clamp it so no
# pane ever drops below these sizes. Toggleable live.
bind $mod+g golden toggle
# golden on
min_width 100
min_height 80

# Float the focused window (the tiler leaves it alone until toggled back).
bind $mod+shift+space floating toggle

# Scratchpad: stash the focused window, pop it back centered (i3-style).
bind $mod+shift+grave move scratchpad
bind $mod+grave scratchpad show

# Reset every split to 50/50.
bind $mod+b balance

# Re-scan and re-apply the layout right now.
bind $mod+t retile

# dmenu-style launcher bar: $mod+d fuzzy-picks an application, $mod+shift+d
# takes a free-text shell command, and $mod+e takes a line of Buzz that runs
# INSIDE the live window manager (same interpreter session: the tree, the
# registry, and every command are in scope — `balance(root!)` reflows live).
bind $mod+d launcher
bind $mod+shift+d launcher run
bind $mod+e launcher eval

# eval also works as a bind command: one-liners against the live WM.
# bind $mod+x eval std\print("windows: {managed.len()}")

# Binding modes, i3-style: $mod+m enters resize mode (h/j/k/l resize, escape
# or return exits); the bar and tray show [resize] while it's active. Define
# your own with bind_mode:
# bind $mod+shift+g mode gaps
# bind_mode gaps equal gaps inner 10
# bind_mode gaps escape mode default

# Marks: vim registers for windows. Tag the focused window, jump back later
# (across workspaces and displays).
bind $mod+shift+a mark a
bind $mod+a goto a

# Window switcher (rofi-style): fuzzy-pick any managed window and jump.
bind $mod+o launcher windows

# Layout undo: step back through tree mutations (move/resize/balance/…).
bind $mod+z undo

# Show a script's output on the bar: anything that writes a line to a file.
# status_file /tmp/yeetile-status
#   (e.g. cron/launchd: date '+%a %H:%M' > /tmp/yeetile-status)

# The inspector ($mod+i) overlays the live state: every screen's split tree
# with apps at the leaves, the window registry, the effective config —
# refreshed while open. Read-only twin of the buzz> prompt.
bind $mod+i inspector

# The API page ($mod+shift+i): every command and session-global, served by
# the live WM — eval's result also echoes on the bar, Retool-console style.
bind $mod+shift+i api

# Menu-bar presence (top right): a ▦ glyph showing the current workspace.
tray on

# Launch things directly, i3-style: everything after `exec` goes to /bin/sh.
bind $mod+return exec open -a Terminal

# Rectangle-style snapping for floating windows ships on Rectangle's own
# default chords (ctrl+alt+arrows/u/i/j/k/d/f/g/e/t/return/c) — see the
# built-in defaults. `snap <pos>` floats the focused window first.

# Prefer writing config in Buzz? ~/.config/yeetile/config.buzz runs after
# this file with a setter API in scope (see config.example.buzz).

# Close the focused window (presses its close button, so apps can prompt).
# The command `yeetus` (deletus) does the same thing, because of course.
bind $mod+shift+q kill

# Status bar along the bottom edge: workspaces, focused title, window count.
bar on

# Window rules (i3's for_window): when a new window matches the app name
# and/or title, run a command against it. Bare/quoted values match as
# case-insensitive substrings; /slash-wrapped/ values are PCRE regexes
# (inline flags, lookaround, backreferences — regexp2 underneath).
# rule app=Music floating toggle
# rule app="Visual Studio Code" move workspace 2
# rule title=/^Untitled [0-9]+$/ floating toggle
#
# Rules that need real logic go in ~/.config/yeetile/rules.buzz — a Buzz
# script run inside the live WM (see rules.example.buzz). Live-reloads too;
# `rules apply` re-runs everything over existing windows.

# Save the split layout of every workspace; restore reshapes the current
# workspace, matching windows to the snapshot by app name. Export goes full
# circle: it writes the live arrangement back as *window rules* — editable
# Buzz in ~/.config/yeetile/rules.generated.buzz — so each app reopens where
# you put it, with nothing to hand-tweak.
bind $mod+shift+s layout save
bind $mod+shift+r layout restore
bind $mod+shift+x layout export

# Autostart: bare exec lines run once when yeetile starts (not on reload).
# exec open -a Terminal

# Nothing watches this file: edit, then press $mod+r. The reload validates
# everything first (a broken config.buzz keeps the previous configuration),
# and on success snapshots this file to config.last-good for easy revert.
bind $mod+r reload
bind $mod+shift+e quit
