// layout_test.buzz — tests for the tiling tree. Pure Buzz, runs anywhere:
//
//     go run ./cmd/buzz -t -L examples/yeetile examples/yeetile/layout_test.buzz

import "std";
import "serialize";
import "layout";

test "insert splits the focused leaf in place" {
    final root = makeLeaf(1);
    std\assert(insertAt(root, target: 1, id: 2), message: "insert at the root leaf");
    std\assert(!root.isLeaf(), message: "root became a container");
    std\assert(root.first!.id == 1, message: "old window is the first child");
    std\assert(root.second!.id == 2, message: "new window is the second child");
    std\assert(countLeaves(root) == 2, message: "two windows managed");
}

test "assign splits frames along the orientation, gap between panes" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    assign(root, x: 0.0, y: 0.0, w: 110.0, h: 50.0, gap: 10.0, minW: 0.0, minH: 0.0);
    std\assert(root.first!.w == 50.0, message: "first pane takes ratio of the width minus gap");
    std\assert(root.second!.x == 60.0, message: "second pane starts after pane + gap");
    std\assert(root.second!.w == 50.0, message: "second pane takes the rest");
    std\assert(root.first!.h == 50.0, message: "horizontal split keeps full height");
}

test "auto orientation splits the longer side" {
    final wide = makeLeaf(1);
    assign(wide, x: 0.0, y: 0.0, w: 200.0, h: 100.0, gap: 0.0, minW: 0.0, minH: 0.0);
    insertAt(wide, target: 1, id: 2);
    std\assert(wide.orient == Orient.Horiz, message: "wide leaf splits side-by-side");

    final tall = makeLeaf(1);
    assign(tall, x: 0.0, y: 0.0, w: 100.0, h: 200.0, gap: 0.0, minW: 0.0, minH: 0.0);
    insertAt(tall, target: 1, id: 2);
    std\assert(tall.orient == Orient.Vert, message: "tall leaf stacks");
}

test "remove collapses the surviving sibling into the parent" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    insertAt(root, target: 2, id: 3);
    std\assert(countLeaves(root) == 3, message: "three windows before");
    std\assert(removeAt(root, target: 2), message: "remove the middle window");
    std\assert(countLeaves(root) == 2, message: "two windows after");
    std\assert(findLeaf(root, target: 2) == null, message: "window 2 is gone");
    std\assert(findLeaf(root, target: 1) != null and findLeaf(root, target: 3) != null, message: "the others survive");
}

test "neighbor finds the window in the requested direction" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    assign(root, x: 0.0, y: 0.0, w: 210.0, h: 100.0, gap: 10.0, minW: 0.0, minH: 0.0);
    std\assert(neighbor(root, fromId: 1, dx: 1.0, dy: 0.0) == 2, message: "window 2 is right of window 1");
    std\assert(neighbor(root, fromId: 2, dx: 0.0 - 1.0, dy: 0.0) == 1, message: "window 1 is left of window 2");
    std\assert(neighbor(root, fromId: 1, dx: 0.0 - 1.0, dy: 0.0) == 0, message: "nothing left of window 1");
    std\assert(neighbor(root, fromId: 1, dx: 0.0, dy: 1.0) == 0, message: "nothing below in a horizontal split");
}

test "grow adjusts the innermost split and clamps" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    std\assert(grow(root, target: 1, delta: 0.05), message: "grow the first pane");
    std\assert(root.ratio == 0.55, message: "ratio moved toward the first pane");
    foreach (i in 0..20) {
        grow(root, target: 1, delta: 0.05);
    }
    std\assert(root.ratio == 0.9, message: "ratio clamps at 0.9");
}

test "swap exchanges leaf ids without touching geometry" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    assign(root, x: 0.0, y: 0.0, w: 210.0, h: 100.0, gap: 10.0, minW: 0.0, minH: 0.0);
    final beforeX = findLeaf(root, target: 1)!.x;
    std\assert(swapIds(root, a: 1, b: 2), message: "swap the two windows");
    std\assert(findLeaf(root, target: 2)!.x == beforeX, message: "window 2 now occupies window 1's pane");
}

test "layout snapshots round-trip through json" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    grow(root, target: 1, delta: 0.2);
    findLeaf(root, target: 1)!.tag = "Terminal";
    findLeaf(root, target: 2)!.tag = "Safari";

    final js = serialize\jsonEncode(encodeTree(root));
    final back = decodeTree(serialize\jsonDecode(js));
    std\assert(back != null, message: "tree decodes");
    final t = back!;
    std\assert(!t.isLeaf(), message: "split survives");
    std\assert(t.orient == Orient.Horiz, message: "orientation survives");
    std\assert(t.ratio == 0.7, message: "ratio survives");
    std\assert(t.first!.tag == "Terminal" and t.second!.tag == "Safari", message: "leaf tags survive in order");
    std\assert(t.first!.id == 0, message: "decoded leaves await matching");
}

test "empty trees round-trip as empty" {
    final js = serialize\jsonEncode(encodeTree(null));
    std\assert(decodeTree(serialize\jsonDecode(js)) == null, message: "empty marker decodes to null");
}

test "pruneZeroLeaves collapses around unmatched leaves" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    insertAt(root, target: 2, id: 3);
    findLeaf(root, target: 2)!.id = 0; // pretend window 2 had no match
    final pruned = pruneZeroLeaves(root);
    std\assert(pruned != null, message: "something survives");
    std\assert(countLeaves(pruned) == 2, message: "two matched leaves remain");
    std\assert(findLeaf(pruned!, target: 1) != null and findLeaf(pruned!, target: 3) != null, message: "the right ones");

    final lone = makeLeaf(0);
    std\assert(pruneZeroLeaves(lone) == null, message: "a fully unmatched tree prunes to null");
}

test "growAxis resizes along the requested axis only" {
    // Horizontal split [1 | (2 stacked over 3)]: window 3's width lives in
    // the outer split, its height in the inner one.
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    final right = root.second!;
    right.pick = Pick.Vert;
    insertAt(root, target: 2, id: 3);

    std\assert(growAxis(root, target: 3, orient: Orient.Vert, delta: 0.1), message: "height resize finds the stack");
    std\assert(root.second!.ratio == 0.4, message: "inner vertical ratio moved toward window 3");
    std\assert(root.ratio == 0.5, message: "outer horizontal split untouched");

    std\assert(growAxis(root, target: 3, orient: Orient.Horiz, delta: 0.1), message: "width resize climbs to the outer split");
    std\assert(root.ratio == 0.4, message: "outer ratio moved toward the right column");

    final lone = makeLeaf(7);
    std\assert(!growAxis(lone, target: 7, orient: Orient.Horiz, delta: 0.1), message: "a lone window has nothing to resize");
}

test "applyGolden gives the focused side the golden share" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    assign(root, x: 0.0, y: 0.0, w: 1000.0, h: 500.0, gap: 0.0, minW: 0.0, minH: 0.0);
    std\assert(applyGolden(root, target: 1, minW: 100.0, minH: 80.0), message: "focused window found");
    std\assert(root.ratio == 0.618, message: "first child takes phi");
    std\assert(applyGolden(root, target: 2, minW: 100.0, minH: 80.0), message: "focus moves");
    std\assert(root.ratio > 0.38 and root.ratio < 0.385, message: "second child takes phi, ratio flips");
    std\assert(!applyGolden(root, target: 99, minW: 100.0, minH: 80.0), message: "unknown window untouched");
}

test "applyGolden honors the minimum window size" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    assign(root, x: 0.0, y: 0.0, w: 400.0, h: 300.0, gap: 0.0, minW: 0.0, minH: 0.0);
    // phi would leave the sibling 0.382 * 400 = 152.8px, under the 170px
    // minimum, so the ratio clamps to 1 - 170/400 = 0.575.
    applyGolden(root, target: 1, minW: 170.0, minH: 80.0);
    std\assert(root.ratio == 0.575, message: "clamped so the sibling keeps its 170px");
    // A split too narrow to honor the minimum twice is left alone.
    assign(root, x: 0.0, y: 0.0, w: 300.0, h: 300.0, gap: 0.0, minW: 0.0, minH: 0.0);
    root.ratio = 0.44;
    applyGolden(root, target: 1, minW: 200.0, minH: 80.0);
    std\assert(root.ratio == 0.44, message: "impossible minimum leaves the split untouched");
}

test "snapFrame covers the Rectangle catalog" {
    final l = snapFrame("left", bx: 0.0, by: 0.0, bw: 1200.0, bh: 600.0)!;
    std\assert(l[0] == 0.0 and l[2] == 600.0 and l[3] == 600.0, message: "left half");
    final br = snapFrame("bottomright", bx: 0.0, by: 0.0, bw: 1200.0, bh: 600.0)!;
    std\assert(br[0] == 600.0 and br[1] == 300.0 and br[2] == 600.0, message: "bottom-right quarter");
    final ct = snapFrame("center-third", bx: 0.0, by: 0.0, bw: 1200.0, bh: 600.0)!;
    std\assert(ct[0] == 400.0 and ct[2] == 400.0, message: "center third");
    final tt = snapFrame("last-two-thirds", bx: 0.0, by: 0.0, bw: 1200.0, bh: 600.0)!;
    std\assert(tt[0] == 400.0 and tt[2] == 800.0, message: "last two thirds");
    // Bounds with an origin (a non-main tiled display) offset correctly.
    final r = snapFrame("right", bx: 2000.0, by: 100.0, bw: 1000.0, bh: 500.0)!;
    std\assert(r[0] == 2500.0 and r[1] == 100.0, message: "origin-aware");
    std\assert(snapFrame("diagonal", bx: 0.0, by: 0.0, bw: 1.0, bh: 1.0) == null, message: "unknown position");
}

test "treeLines renders the inspector view" {
    final root = makeLeaf(1);
    root.pick = Pick.Horiz;
    insertAt(root, target: 1, id: 2);
    findLeaf(root, target: 1)!.tag = "Terminal";
    final lines = treeLines(root, prefix: "");
    std\assert(lines.len() == 3, message: "split plus two leaves");
    std\assert(lines[0].indexOf("H split") != null, message: "orientation shown");
    std\assert(lines[1] == "  ◻ Terminal", message: "tagged leaf shows its app");
    std\assert(lines[2] == "  ◻ #2", message: "untagged leaf shows its id");
    std\assert(treeLines(null, prefix: "")[0] == "(empty)", message: "empty tree says so");
}

test "cloneTree copies ids and is independent" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    grow(root, target: 1, delta: 0.1);
    final copy = cloneTree(root)!;
    std\assert(copy.ratio == 0.6, message: "ratio copied");
    std\assert(copy.first!.id == 1 and copy.second!.id == 2, message: "ids preserved");
    grow(root, target: 1, delta: 0.1);
    std\assert(copy.ratio == 0.6, message: "copy unaffected by later edits");
}

test "pruneMissing collapses around closed windows" {
    final root = makeLeaf(1);
    insertAt(root, target: 1, id: 2);
    insertAt(root, target: 2, id: 3);
    final pruned = pruneMissing(cloneTree(root), keep: [1, 3]);
    std\assert(countLeaves(pruned) == 2, message: "closed window dropped");
    std\assert(findLeaf(pruned!, target: 2) == null, message: "the right one");
    std\assert(pruneMissing(cloneTree(root), keep: [9]) == null, message: "nothing left prunes to null");
}
