// config_test.buzz — tests for the config parser. Pure Buzz, runs anywhere:
//
//     go run ./cmd/buzz -t -L examples/bubblegum examples/bubblegum/config_test.buzz

import "std";
import "io";
import "os";
import "fs";
import "config";

// The round-trip test below plays the WM's role: generated rules call
// onWindowRule and the typed command constructors, which in the real session
// are defined by bubblegum.buzz. Stubs let them return easily-testable values.
var capturedHook: any = null;

fun onWindowRule(f: any) > void {
    capturedHook = f;
}

fun moveToWorkspace(n: int) > any { return "ws:{n}"; }
fun floating()              > any { return "float"; }
fun floatOn()               > any { return "float:on"; }
fun floatOff()              > any { return "float:off"; }
fun frame(x: double, y: double, w: double, h: double) > any { return "frame:{x},{y},{w},{h}"; }

test "parseChord resolves modifiers and key" {
    final chord = parseChord("cmd+shift+h");
    std\assert(chord != null, message: "chord parses");
    std\assert(chord![0] == 1048576 + 131072, message: "cmd+shift flags summed");
    std\assert(chord![1] == 4, message: "h is keycode 4");
    std\assert(parseChord("hyper+h") == null, message: "unknown modifier rejected");
    std\assert(parseChord("cmd+meh") == null, message: "unknown key rejected");
}

test "parseConfig reads directives, comments, and binds" {
    final c = parseConfig("# comment\n"
        + "gaps inner 4\n"
        + "gaps outer 6\n"
        + "top_padding 30\n"
        + "poll_interval_ms 500\n"
        + "bind cmd+return exec open -a Terminal\n");
    std\assert(c.gapInner == 4.0, message: "gaps inner");
    std\assert(c.gapOuter == 6.0, message: "gaps outer");
    std\assert(c.topPadding == 30.0, message: "top_padding");
    std\assert(c.pollMs == 500, message: "poll interval");
    std\assert(c.binds.len() == 1, message: "one bind");
    final b = bindAt(c.binds, i: 0);
    std\assert(b.keycode == 36, message: "return key");
    std\assert(b.command == "exec open -a Terminal", message: "command keeps its spaces");
}

test "exec lines collect as startup commands" {
    final c = parseConfig("exec open -a Terminal\nexec borders width 2\nbind cmd+h focus left\n");
    std\assert(c.execs.len() == 2, message: "two autostart commands");
    final first: str = c.execs[0];
    std\assert(first == "open -a Terminal", message: "command text intact");
    std\assert(c.binds.len() == 1, message: "binds unaffected");
}

test "set variables substitute inside chords" {
    final c = parseConfig("set $mod cmd+alt\nbind $mod+k focus up\n");
    std\assert(c.binds.len() == 1, message: "bind parsed through $mod");
    final b = bindAt(c.binds, i: 0);
    std\assert(b.flags == 1048576 + 524288, message: "cmd+alt flags");
    std\assert(b.keycode == 40, message: "k keycode");
}

test "unknown lines are skipped, not fatal" {
    final c = parseConfig("frobnicate 12\nbind cmd+h focus left\n");
    std\assert(c.binds.len() == 1, message: "good line still parsed");
}

test "built-in defaults parse cleanly" {
    final c = parseConfig(defaultConfigText());
    std\assert(c.binds.len() == 80, message: "all default binds parse");
    std\assert(c.gapInner == 8.0, message: "gaps default to 8 inner");
}

test "missing config file falls back to defaults via catch" {
    final c = loadConfig("/definitely/not/here/bubblegum-test-config");
    std\assert(c.binds.len() == 80, message: "built-in defaults loaded");
}

test "workspace binds carry the full command" {
    final c = parseConfig("set $mod cmd\nbind $mod+3 workspace 3\nbind $mod+shift+3 move workspace 3\n");
    std\assert(c.binds.len() == 2, message: "both binds parse");
    std\assert(bindAt(c.binds, i: 0).command == "workspace 3", message: "switch command intact");
    std\assert(bindAt(c.binds, i: 1).command == "move workspace 3", message: "move command intact");
    std\assert(bindAt(c.binds, i: 0).keycode == 20, message: "digit 3 keycode");
}

test "readConfigText snapshots drive change detection" {
    final path = os\tmpDir() + "/bubblegum-test-config-snapshot";
    std\assert(readConfigText(path + "-missing") == null, message: "missing file reads as null");

    var f = io\File.open(path, mode: io\FileMode.write);
    f.write("gaps inner 4\n");
    f.close();
    final before = readConfigText(path);
    std\assert(before != null, message: "file reads back");
    std\assert(readConfigText(path) == before, message: "unchanged file compares equal");

    f = io\File.open(path, mode: io\FileMode.write);
    f.write("gaps inner 8\n");
    f.close();
    std\assert(readConfigText(path) != before, message: "edited file compares different");
    fs\delete(path);
    std\assert(readConfigText(path) == null, message: "deleted file reads as null again");
}

test "rules parse bare and quoted criteria" {
    final r = parseRule("app=Terminal floating toggle");
    std\assert(r != null, message: "bare value parses");
    std\assert(r!.app == "Terminal" and r!.command == "floating toggle", message: "fields split");

    final q = parseRule("app=\"Visual Studio Code\" title=\"Settings\" move workspace 3");
    std\assert(q != null, message: "quoted values parse");
    std\assert(q!.app == "Visual Studio Code", message: "quoted app keeps its spaces");
    std\assert(q!.title == "Settings" and q!.command == "move workspace 3", message: "title + command split");

    std\assert(parseRule("app=Terminal") == null, message: "a rule needs a command");
    std\assert(parseRule("floating toggle") == null, message: "a rule needs a criterion");
}

test "ruleMatches is substring and case-insensitive" {
    final r = parseRule("app=code title=settings floating")!;
    std\assert(ruleMatches(r, app: "Visual Studio Code", title: "User Settings"), message: "both criteria hit");
    std\assert(!ruleMatches(r, app: "Visual Studio Code", title: "Editor"), message: "title criterion misses");
    std\assert(!ruleMatches(r, app: "Terminal", title: "User Settings"), message: "app criterion misses");
}

test "config collects rules and the bar toggle" {
    final c = parseConfig("bar off\nrule app=Finder workspace 2\nrule app=Music floating\n");
    std\assert(!c.barOn, message: "bar off parsed");
    std\assert(c.rules.len() == 2, message: "two rules collected");
    std\assert(ruleAt(c.rules, i: 0).app == "Finder", message: "first rule intact");
    final d = parseConfig("gaps inner 4\n");
    std\assert(d.barOn, message: "bar defaults to on");
}

test "regex rule criteria compile and match" {
    final r = parseRule("title=/^Untitled [0-9]+$/ floating toggle");
    std\assert(r != null, message: "regex rule parses");
    std\assert(ruleMatches(r!, app: "TextEdit", title: "Untitled 12"), message: "regex hits");
    std\assert(!ruleMatches(r!, app: "TextEdit", title: "Readme"), message: "regex misses");
    std\assert(!ruleMatches(r!, app: "TextEdit", title: "an Untitled 12 story"), message: "anchors respected");

    final ci = parseRule("app=/(?i)^code$/ move workspace 2");
    std\assert(ci != null and ruleMatches(ci!, app: "Code", title: "x"), message: "inline flags work");
    std\assert(parseRule("app=/[unclosed/ floating") == null, message: "bad regex rejects the rule");
}

test "tile_display directive parses" {
    std\assert(parseConfig("tile_display 2\n").tileDisplay == 2, message: "numeric display");
    std\assert(parseConfig("tile_display main\n").tileDisplay == 1, message: "main keyword");
    std\assert(parseConfig("gaps inner 4\n").tileDisplay == 1, message: "defaults to main");
}

test "focus_follows_mouse directive parses" {
    final c = parseConfig("focus_follows_mouse on\n");
    std\assert(c.ffmOn, message: "ffm on");
    std\assert(!parseConfig("gaps inner 4\n").ffmOn, message: "ffm defaults off");
}

test "golden and minimum-size directives parse" {
    final c = parseConfig("golden on\nmin_width 240\nmin_height 160\n");
    std\assert(c.goldenOn, message: "golden on");
    std\assert(c.minWidth == 240.0 and c.minHeight == 160.0, message: "minimums set");
    final d = parseConfig("gaps inner 4\n");
    std\assert(!d.goldenOn, message: "golden defaults off");
    std\assert(d.minWidth == 460.0, message: "default minimum");
    std\assert(c.gapInner == 8.0 and c.gapOuter == 0.0, message: "gaps default to 8 inner, 0 outer");
    std\assert(d.gapInner == 4.0, message: "gaps opt-in works");
}

test "splitCommands splits hook results into commands" {
    final cmds = splitCommands("floating toggle; move workspace 3 ;; ");
    std\assert(cmds.len() == 2, message: "two commands, empties dropped");
    std\assert(cmds[0] == "floating toggle" and cmds[1] == "move workspace 3", message: "trimmed");
    std\assert(splitCommands("") .len() == 0, message: "empty in, none out");
}

test "escapeBuzz neutralizes quotes, backslashes, and interpolation" {
    std\assert(escapeBuzz("Plain App") == "Plain App", message: "untouched");
    std\assert(escapeBuzz("say \"hi\"") == "say \\\"hi\\\"", message: "quotes escaped");
    std\assert(escapeBuzz("a\\b") == "a\\\\b", message: "backslash escaped");
    std\assert(escapeBuzz("odd \{name}") == "odd \\\{name}", message: "open brace can't interpolate");
}

test "exported rules are runnable Buzz that reproduces the placement" {
    final src = rulesSource(["Terminal", "My \"App\""], commands: ["moveToWorkspace(2)", "floating()"]);
    std\assert(src.indexOf("onWindowRule(fun (app: str, title: str, id: int) > [any]") != null, message: "hook shape");
    std\assert(src.indexOf("app == \"Terminal\"") != null, message: "first app literal");
    std\assert(src.indexOf("return [moveToWorkspace(2)];") != null, message: "first command in body");
    // My "App" gets its quotes escaped for embedding in a Buzz string literal.
    std\assert(src.indexOf("My \\\"App\\\"") != null, message: "quoted app name escaped");
    std\assert(src.indexOf("return [floating()];") != null, message: "second command in body");
    std\assert(src.indexOf("return [];") != null, message: "fallthrough case");
}

test "tile_displays takes a set, all, or falls back to tile_display" {
    final c = parseConfig("tile_displays 1 3\n");
    std\assert(c.tileDisplays.len() == 2, "two displays picked");
    final first: int = c.tileDisplays[0];
    final second: int = c.tileDisplays[1];
    std\assert(first == 1 and second == 3, "picks preserved in order");
    std\assert(parseConfig("tile_displays all\n").tileAll, "all keyword");
    final d = parseConfig("tile_display 2\n");
    std\assert(d.tileDisplays.len() == 0 and d.tileDisplay == 2, "legacy single pick");
}

test "border and cheatsheet directives parse" {
    final c = parseConfig("border on\nborder_width 5\ncheatsheet cmd+alt+b\n");
    std\assert(c.borderOn and c.borderWidth == 5.0, "border configured");
    std\assert(c.cheatKey == 11, "cheat key is b");
    std\assert(c.cheatFlags == 1048576 + 524288, "cheat mods cmd+alt");
    std\assert(!parseConfig("gaps inner 1\n").borderOn, "border defaults off");
}

test "chordName round-trips binds for the cheat sheet" {
    std\assert(chordName(1048576 + 131072, 4) == "cmd+shift+h", "mods plus letter");
    std\assert(chordName(0, 36) == "return", "bare key");
    std\assert(keyName(44) == "slash", "named punctuation");
}

test "binding modes parse and stay scoped" {
    final c = parseConfig("bind cmd+h focus left\nbind_mode resize h resize shrink width\nbind_mode resize escape mode default\n");
    std\assert(c.binds.len() == 3, "all binds collected");
    std\assert(bindAt(c.binds, 0).mode == "", "plain binds live in the default mode");
    std\assert(bindAt(c.binds, 1).mode == "resize", "mode binds tagged");
    std\assert(bindAt(c.binds, 1).flags == 0 and bindAt(c.binds, 1).keycode == 4, "bare-key chord inside a mode");
    std\assert(bindAt(c.binds, 2).command == "mode default", "exit bind intact");
}

test "status_file directive parses" {
    final c = parseConfig("status_file /tmp/status\n");
    std\assert(c.statusFile == "/tmp/status", "path stored");
    std\assert(parseConfig("gaps inner 1\n").statusFile == "", "off by default");
}
