// platform/macos/objc/msgStr.buzz — objc_msgSend, shape: id msg(id, SEL, char*).
// See msg0.buzz for why each shape binds a uniquely-named shim wrapper.
namespace msgStr;

import "ffi";

zdef("bubblegum", "fn yt_send_string(self: ?*anyopaque, op: ?*anyopaque, s: [*:0]const u8) ?*anyopaque;");

export fun sendString(self: ud?, op: ud?, s: str) > ud? {
    return yt_send_string(self, op: op, s: ffi\cstr(s));
}
