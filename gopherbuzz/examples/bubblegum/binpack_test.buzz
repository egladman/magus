// binpack_test.buzz — the workspace bin-packer that rules hooks use to spread
// unplaced windows. Pure logic, runs anywhere:
//
//     go run ../../cmd/buzz -t -L . binpack_test.buzz

import "std";
import "config";

test "binPackWorkspace picks the first under-cap workspace in range" {
    // ws1=2, ws2=0, ws3=1, rest 0  (counts are 0-based: index i is workspace i+1)
    final counts = [2, 0, 1, 0, 0, 0, 0, 0, 0];
    std\assert(config\binPackWorkspace(counts, lo: 2, hi: 7, cap: 2) == 2, message: "ws2 is under cap");
    std\assert(config\binPackWorkspace(counts, lo: 1, hi: 7, cap: 2) == 2, message: "skips full ws1 (at cap 2)");
    std\assert(config\binPackWorkspace(counts, lo: 3, hi: 7, cap: 2) == 3, message: "ws3 has room (1 < 2)");
    std\assert(config\binPackWorkspace(counts, lo: 3, hi: 7, cap: 1) == 4, message: "cap 1: ws3 full, ws4 free");
}

test "binPackWorkspace returns 0 when every workspace in range is full" {
    final full = [2, 2, 2, 2, 2, 2, 2, 0, 0];
    std\assert(config\binPackWorkspace(full, lo: 1, hi: 7, cap: 2) == 0, message: "no room in 1..7");
    // out-of-range workspaces (8, 9) still have room, but they're outside the scan
    std\assert(config\binPackWorkspace(full, lo: 8, hi: 9, cap: 2) == 8, message: "scans only the given range");
}

test "promptTarget asks only when the current workspace is over cap" {
    // curWs (index 0 = ws1) holds 4 windows, cap 3 -> over cap, offer the first
    // workspace with room. ws2 is empty, so it wins.
    final crowded = [4, 0, 0, 0, 0, 0, 0, 0, 0];
    std\assert(config\promptTarget(crowded, curWs: 0, cap: 3) == 2, message: "ws1 over cap -> offer ws2");
    // Exactly at cap is not "over" — no prompt.
    final atCap = [3, 0, 0, 0, 0, 0, 0, 0, 0];
    std\assert(config\promptTarget(atCap, curWs: 0, cap: 3) == 0, message: "at cap (3) is fine, no prompt");
    // Under cap — no prompt.
    std\assert(config\promptTarget([2, 0, 0, 0, 0, 0, 0, 0, 0], curWs: 0, cap: 3) == 0, message: "under cap, no prompt");
}

test "promptTarget is off when cap <= 0" {
    final crowded = [9, 9, 9, 9, 9, 9, 9, 9, 9];
    std\assert(config\promptTarget(crowded, curWs: 0, cap: 0) == 0, message: "cap 0 disables the prompt");
    std\assert(config\promptTarget(crowded, curWs: 0, cap: 0 - 1) == 0, message: "negative cap disables the prompt");
}

test "promptTarget returns 0 when nowhere is less crowded" {
    // Every workspace is at/over cap 3 -> nowhere to move it, so don't prompt.
    final full = [4, 3, 3, 3, 3, 3, 3, 3, 3];
    std\assert(config\promptTarget(full, curWs: 0, cap: 3) == 0, message: "all full -> no offer");
    // The only workspace with room is the current one (already over cap is false
    // here so this stays untriggered); a genuinely crowded curWs with only itself
    // free can't happen, but guard the off-by-one: curWs over cap, one peer free.
    final onePeer = [4, 3, 3, 1, 3, 3, 3, 3, 3];
    std\assert(config\promptTarget(onePeer, curWs: 0, cap: 3) == 4, message: "ws4 has room -> offer ws4");
}

test "binPackWorkspace fills a range cap-per-workspace as windows arrive" {
    // Simulate adopting 5 windows into ws3..5 at cap 2, updating counts each time.
    final counts = mut [0, 0, 0, 0, 0, 0, 0, 0, 0];
    final placed = mut [<int>];
    foreach (_ in 0..5) {
        final ws = config\binPackWorkspace(counts, lo: 3, hi: 5, cap: 2);
        placed.append(ws);
        counts[ws - 1] = counts[ws - 1] + 1;
    }
    // 2 into ws3, 2 into ws4, 1 into ws5
    std\assert(placed[0] == 3 and placed[1] == 3, message: "first two -> ws3");
    std\assert(placed[2] == 4 and placed[3] == 4, message: "next two -> ws4");
    std\assert(placed[4] == 5, message: "fifth -> ws5");
}
