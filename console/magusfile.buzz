import "magus";
// Modules the targets use: fs (node_modules guard), os (pnpm/esbuild), vcs (drift gate).
import "fs";
import "os";
import "vcs";
// The shared DOM-free browser client lib (libs/textsearch) holds the search grammar the
// Reference drawer imports from source. Affected tracking is glob-based (not
// import-graph), so this handle lets lint pull in textsearch.lint (type-check + biome) - a
// lib edit then marks the console affected and re-checks it through the target graph.
import "project/../libs/textsearch" as textsearch;

// magusfile binds this file's own exported targets (build, typecheck, test, ci); ts adds the
// TypeScript spell so the app's src/ is symbol-capable - its `scip` op indexes it (via tsconfig.json)
// for the knowledge graph. ts is opaque (pnpm owns the dependency graph; informational) and does not
// run in ci, which uses the custom targets below; it just makes the TypeScript browsable as symbols.
import "magus/spell/magusfile";
import "magus/spell/ts";

// The console is the standalone native PWA (dashboard, logs, graph, activity as tabs + tiling). It owns
// its whole stack - a hand-authored index.html/manifest/sw, its own esbuild build (via pnpm scripts),
// and vendored copies of the shared lib/ui/proto/styles - with NO dependency on the docs site. This
// magusfile registers it as a first-class magus project so `magus affected ci` covers it.
magus.project({
    "spells": [magusfile, ts],
    // Affected/drift tracks this sources glob, not the import graph, so every input must be named to be
    // watched. The client is TypeScript (esbuild strips the types) plus per-surface CSS and the
    // scaffold fragments the surfaces fetch; the hand-authored shell (index.html/manifest/sw) and the
    // build manifests (package.json + pnpm-lock.yaml, where the esbuild deps are pinned) round it out.
    // pnpm is the package manager - NOT npm; .npmrc's minimum-release-age gate is the reason.
    "sources": ["magusfile.buzz", "*.buzz",
                "src/**/*.ts", "src/**/*.css", "src/**/*.html",
                "index.html", "manifest.webmanifest", "sw.js",
                "package.json", "pnpm-lock.yaml", "tsconfig.json"],
    "outputs": ["gen/**"],
    "targets": {
        // build rebuilds the committed gen/ and gates on drift, so it must run every time (skip_cache)
        // and alone (exclusive) so a peer mutating gen/ cannot trip its git-status check.
        "build": {"skip_cache": true, "exclusive": true},
    },
});

export fun preflight(ctx: magus\Context, args: [str]) > void {}

// install restores the pinned build-only deps with pnpm (esbuild + the surfaces' d3/uplot/protobuf
// clients), honoring .npmrc's minimum-release-age supply-chain gate. Guarded on node_modules so a warm
// local tree skips it while a cold CI checkout installs. NOT npm - pnpm, for the release-age gate.
fun install() > void {
    if (!fs.isDir("node_modules")) {
        os.exec("pnpm", ["install", "--frozen-lockfile"], ".", {});
    }
}

// test runs the node:test suite over the bundled *.test.ts (the shell/view/tiling/keymap unit tests).
export fun test(ctx: magus\Context, args: [str]) > void {
    ctx.needs(preflight);
    install();
    os.exec("pnpm", ["run", "test"], ".", {});
}

// build bundles the whole app into gen/ (esbuild via pnpm: the surface bundles + CSS, then copy-static
// assembles index/manifest/sw + scaffolds + assets) and gates on drift: a clean checkout only goes
// dirty when a source edit was not rebuilt and committed. The `rw` charm (`build:rw`) keeps the result
// instead of gating. esbuild is pinned (mise), so the output is byte-stable and the gate holds.
export fun build(ctx: magus\Context, args: [str]) > void {
    ctx.needs(preflight);
    final clean_before = vcs.isDirty(["gen"]) == false;
    install();
    os.exec("pnpm", ["run", "build"], ".", {});
    if (ctx.has_charm("rw")) {
        return;
    }
    if (clean_before and vcs.isDirty(["gen"])) {
        throw "build: gen/ drifted; re-run `magus run build:rw console` and commit";
    }
}

// lint is the console's static-analysis gate: it runs the TypeScript type-check (tsc --noEmit), the
// same way a Go project's lint runs `go vet`. Composing tsc into lint (rather than a standalone
// `typecheck` target) means `magus affected ci`, which needs lint, always covers it - a type error
// fails lint. The console has no separate linter yet; if one lands it composes in here beside tsc.
export fun lint(ctx: magus\Context, args: [str]) > void {
    ctx.needs(preflight);
    // The Reference drawer imports the search grammar from the shared libs/textsearch
    // source, so gate its type-check + biome here: a lib edit fails console lint too.
    ctx.needs(textsearch.lint);
    install();
    os.exec("pnpm", ["run", "typecheck"], ".", {});
}

// 'ci' is the anchor `magus affected ci` keys off: the lint gate (tsc), the unit tests, and the
// build-plus-drift-gate, all first-class ci steps.
export fun ci(ctx: magus\Context, args: [str]) > void {
    ctx.needs(lint, test, build);
}
