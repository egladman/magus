# Build-only dependencies for the playground's CodeMirror editor bundle. The
# bundled output (gen/playground/editor.js) is a committed artifact, like
# gen/playground/buzz.wasm; the node_modules that produce it are not.
node_modules/

# Bundled test output: `pnpm run test` esbuild-bundles src/lib/*.test.ts here and
# runs it under node --test (which skips node_modules, so the bundle can't live
# there). A build artifact, not committed.
.testcache/

# Local dev data blob (not committed): the docs search index the standalone dev console fetches.
gen/search-index.json

# NOTE: gen/graph/graph.json IS committed. GitHub Pages publishes the committed console/gen/ bytes
# verbatim (no build step at deploy), so the demo graph the Graph Explorer fetches must ship in gen/.
# copy-static (package.json) refreshes it from ../docs/graph.json on every build; the build drift gate
# keeps it in sync.
